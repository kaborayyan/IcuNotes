@using IcuNotes.Models
@using IcuNotes.Constants
@using Microsoft.AspNetCore.Components.Forms
@using MudBlazor

@*
    OverviewSection.razor

    This component contains:
    1) Patient overview fields
    2) Admission unit selection
    3) Admission unit catalog manager
    4) Patient timeline rows

    Important architecture note:
    - This component edits UI state only.
    - PatientDetails.razor still owns saving, reloading, and dirty tracking.
    - No database, service, or model code is used directly here.

    MudBlazor migration note:
    - Bootstrap cards, rows, inputs, alerts, and buttons were replaced.
    - AdmissionUnitsManager is intentionally kept outside the overview EditForm.
    - If AdmissionUnitsManager still uses Bootstrap internally, we will migrate it later as its own file.
*@

@if (Patient is not null)
{
    <MudStack Spacing="3">

        @* Section introduction.
           This gives the section a clear mobile-friendly entry point instead of a plain heading. *@
        <MudPaper Elevation="0" Outlined="true" Class="pa-3">
            <MudStack Spacing="1">
                <MudText Typo="Typo.h6">Overview</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Core patient details, admission unit, and timeline events.
                </MudText>
            </MudStack>
        </MudPaper>

        @if (!string.IsNullOrWhiteSpace(admissionUnitStatusMessage))
        {
            <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Dense="true">
                @admissionUnitStatusMessage
            </MudAlert>
        }

        @*
            This form contains ONLY fields that belong to the current patient overview.

            AdmissionUnitsManager is intentionally outside this EditForm.

            Why?
            If AdmissionUnitsManager is inside this EditForm, its internal input controls
            can receive the OverviewEditContext automatically from Blazor.
            Then editing the catalog could mark Overview as dirty even though the patient
            itself was not changed.
        *@
        <EditForm EditContext="OverviewEditContext">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <MudPaper Elevation="0" Outlined="true" Class="pa-3">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.subtitle1">Patient details</MudText>

                    <MudGrid Spacing="2">

                        @* Patient name can be wider because names may be long. *@
                        <MudItem xs="12" sm="6">
                            <MudTextField T="string"
                                          Label="Name"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          FullWidth="true"
                                          Immediate="true"
                                          Disabled="@IsSaving"
                                          Value="@Patient.Name"
                                          ValueChanged="HandlePatientNameChangedAsync" />

                            <ValidationMessage For="@(() => Patient.Name)" />
                        </MudItem>

                        @* Bed is short, so it gets a compact column on larger screens. *@
                        <MudItem xs="6" sm="3">
                            <MudSelect T="string"
                                       Label="Bed"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       FullWidth="true"
                                       Disabled="@IsSaving"
                                       Value="@Patient.Bed"
                                       ValueChanged="HandlePatientBedChangedAsync">
                                <MudSelectItem T="string" Value="@string.Empty">
                                    Select bed
                                </MudSelectItem>

                                @foreach (var bed in BedOptions.All)
                                {
                                    <MudSelectItem T="string" Value="@bed">
                                        @bed
                                    </MudSelectItem>
                                }
                            </MudSelect>

                            <ValidationMessage For="@(() => Patient.Bed)" />
                        </MudItem>

                        @* Age is usually a short value, so it stays compact on mobile. *@
                        <MudItem xs="6" sm="3">
                            <MudNumericField T="int?"
                                             Label="Age"
                                             Variant="Variant.Outlined"
                                             Margin="Margin.Dense"
                                             FullWidth="true"
                                             HideSpinButtons="true"
                                             Min="@((int?)0)"
                                             Disabled="@IsSaving"
                                             Value="@Patient.Age"
                                             ValueChanged="HandlePatientAgeChangedAsync" />

                            <ValidationMessage For="@(() => Patient.Age)" />
                        </MudItem>

                        @* Weight is also a short value, so it does not need a full row. *@
                        <MudItem xs="6" sm="3">
                            <MudNumericField T="decimal?"
                                             Label="Weight"
                                             Variant="Variant.Outlined"
                                             Margin="Margin.Dense"
                                             FullWidth="true"
                                             HideSpinButtons="true"
                                             Min="@((decimal?)0m)"
                                             Disabled="@IsSaving"
                                             Value="@Patient.Weight"
                                             ValueChanged="HandlePatientWeightChangedAsync" />

                            <ValidationMessage For="@(() => Patient.Weight)" />
                        </MudItem>

                        @* Diagnosis may be long, so it gets the full width. *@
                        <MudItem xs="12">
                            <MudTextField T="string"
                                          Label="Diagnosis"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          FullWidth="true"
                                          Immediate="true"
                                          Disabled="@IsSaving"
                                          Value="@Patient.Diagnosis"
                                          ValueChanged="HandlePatientDiagnosisChangedAsync" />

                            <ValidationMessage For="@(() => Patient.Diagnosis)" />
                        </MudItem>

                        @* Admission unit selection belongs to the patient overview.
                           Catalog editing itself stays outside this EditForm. *@
                        <MudItem xs="12" sm="8">
                            <MudSelect T="int?"
                                       Label="Admission unit"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       FullWidth="true"
                                       Disabled="@IsSaving"
                                       Value="@Patient.AdmissionUnitCatalogId"
                                       ValueChanged="HandleAdmissionUnitSelectionChangedAsync">
                                <MudSelectItem T="int?" Value="@((int?)null)">
                                    Select admission unit
                                </MudSelectItem>

                                @foreach (var unit in AdmissionUnits)
                                {
                                    <MudSelectItem T="int?" Value="@((int?)unit.Id)">
                                        @unit.Name
                                    </MudSelectItem>
                                }
                            </MudSelect>

                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                                Saved from the bottom Save button.
                            </MudText>
                        </MudItem>
                    </MudGrid>
                </MudStack>
            </MudPaper>
        </EditForm>

        @*
            This reusable manager handles the shared Admission Unit catalog only.

            It is outside the Overview EditForm on purpose.
            The dropdown above selects the unit for this patient.
            This manager adds/edits the shared catalog rows.
        *@
        <MudPaper Elevation="0" Outlined="true" Class="pa-3">
            <MudStack Spacing="2">
                <MudText Typo="Typo.subtitle1">Admission unit catalog</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Add or correct admission unit names here, then select the patient&apos;s unit above.
                </MudText>

                <AdmissionUnitsManager AdmissionUnits="AdmissionUnits"
                                       IsDisabled="IsSaving"
                                       OnAdmissionUnitsChanged="HandleAdmissionUnitsChangedAsync"
                                       OnStatusMessage="HandleAdmissionUnitStatusMessageAsync" />
            </MudStack>
        </MudPaper>

        @* Timeline is part of Overview, but it has its own EditContext for dirty tracking. *@
        <MudPaper Elevation="0" Outlined="true" Class="pa-3">
            <MudStack Spacing="2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2">
                    <div>
                        <MudText Typo="Typo.subtitle1">Timeline</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Important admission, transfer, and clinical milestone dates.
                        </MudText>
                    </div>

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Add"
                               Disabled="@IsSaving"
                               OnClick="HandleAddTimelineEventAsync">
                        Add
                    </MudButton>
                </MudStack>

                @if (OrderedDateEvents.Any())
                {
                    <EditForm EditContext="TimelineEditContext">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <MudStack Spacing="2">
                            @for (var i = 0; i < OrderedDateEvents.Count; i++)
                            {
                                var item = OrderedDateEvents[i];

                                <MudPaper @key="item" Elevation="0" Outlined="true" Class="pa-3">
                                    <MudStack Spacing="2">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2">
                                            <MudChip T="string"
                                                     Size="Size.Small"
                                                     Color="Color.Default"
                                                     Variant="Variant.Outlined">
                                                Event @(i + 1)
                                            </MudChip>

                                            <MudButton Variant="Variant.Outlined"
                                                       Color="Color.Error"
                                                       Size="Size.Small"
                                                       Disabled="@IsSaving"
                                                       OnClick="() => HandleRemoveTimelineEventAsync(item)">
                                                Delete Date
                                            </MudButton>
                                        </MudStack>

                                        <MudGrid Spacing="2">
                                            @* MudDatePicker uses DateTime? internally.
                                               The helper method below keeps this safe and still notifies
                                               TimelineEditContext so the parent dirty flag works. *@
                                            <MudItem xs="12" sm="4">
                                                <MudDatePicker Label="Event date"
                                                               Variant="Variant.Outlined"
                                                               Margin="Margin.Dense"
                                                               Date="@GetTimelineEventDate(item)"
                                                               DateChanged="@(date => HandleTimelineDateChangedAsync(item, date))"
                                                               Disabled="@IsSaving"
                                                               Editable="true" />
                                            </MudItem>

                                            <MudItem xs="12" sm="8">
                                                <MudTextField T="string"
                                                              Label="Title"
                                                              Variant="Variant.Outlined"
                                                              Margin="Margin.Dense"
                                                              FullWidth="true"
                                                              Immediate="true"
                                                              Disabled="@IsSaving"
                                                              Value="@item.Title"
                                                              ValueChanged="@(value => HandleTimelineTitleChangedAsync(item, value))" />
                                            </MudItem>
                                        </MudGrid>
                                    </MudStack>
                                </MudPaper>
                            }
                        </MudStack>
                    </EditForm>
                }
                else
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                        No timeline events added yet.
                    </MudAlert>
                }
            </MudStack>
        </MudPaper>
    </MudStack>
}

@code {
    // This is the main Patient object passed from the parent page.
    [Parameter, EditorRequired]
    public Patient Patient { get; set; } = default!;

    // This shared catalog fills the Admission Unit dropdown and the AdmissionUnitsManager component.
    [Parameter, EditorRequired]
    public List<AdmissionUnitCatalog> AdmissionUnits { get; set; } = new();

    // This list contains the ordered timeline rows shown in the Overview section.
    [Parameter, EditorRequired]
    public List<PatientDateEvent> OrderedDateEvents { get; set; } = new();

    // This EditContext is created by PatientDetails.razor.
    // It tracks changes in the patient overview fields.
    [Parameter, EditorRequired]
    public EditContext OverviewEditContext { get; set; } = default!;

    // This EditContext is created by PatientDetails.razor.
    // It tracks changes in the timeline fields.
    [Parameter, EditorRequired]
    public EditContext TimelineEditContext { get; set; } = default!;

    // PatientDetails.razor passes this value while saving/reloading.
    // We use it here only to disable buttons that should not be clicked during saving.
    [Parameter]
    public bool IsSaving { get; set; }

    // OverviewSection does not own the Save button or the official dirty state.
    // It only tells PatientDetails.razor: "Something in Overview changed."
    // PatientDetails.razor will then mark the Overview section as dirty.
    [Parameter]
    public EventCallback OnSectionChanged { get; set; }

    // The parent page still owns timeline row creation.
    // This component only displays the button and forwards the click.
    [Parameter, EditorRequired]
    public EventCallback OnAddTimelineEvent { get; set; }

    // The parent page still owns timeline row removal.
    // This component only forwards the selected row to the parent.
    [Parameter, EditorRequired]
    public EventCallback<PatientDateEvent> OnRemoveTimelineEvent { get; set; }

    // This message is used only for admission-unit catalog actions.
    // It does not mean the patient overview was changed or saved.
    private string? admissionUnitStatusMessage;

    // This forwards the add-timeline-row request to PatientDetails.razor.
    // Adding a timeline row changes the Overview section, so we also notify the parent.
    private async Task HandleAddTimelineEventAsync()
    {
        await OnAddTimelineEvent.InvokeAsync();
        await NotifyOverviewChangedAsync();
    }

    // This forwards the remove-timeline-row request to PatientDetails.razor.
    // Removing a timeline row changes the Overview section, so we also notify the parent.
    private async Task HandleRemoveTimelineEventAsync(PatientDateEvent item)
    {
        await OnRemoveTimelineEvent.InvokeAsync(item);
        await NotifyOverviewChangedAsync();
    }

    // These small handlers replace plain @bind-Value.
    //
    // Why?
    // MudBlazor updates the value correctly, but the parent PatientDetails.razor
    // should also receive a clear "Overview changed" notification.
    // This keeps dirty tracking explicit and easy to debug.
    private async Task HandlePatientNameChangedAsync(string value)
    {
        Patient.Name = value;
        OverviewEditContext.NotifyFieldChanged(new FieldIdentifier(Patient, nameof(Patient.Name)));
        await NotifyOverviewChangedAsync();
    }

    private async Task HandlePatientBedChangedAsync(string value)
    {
        Patient.Bed = value;
        OverviewEditContext.NotifyFieldChanged(new FieldIdentifier(Patient, nameof(Patient.Bed)));
        await NotifyOverviewChangedAsync();
    }

    private async Task HandlePatientAgeChangedAsync(int? value)
    {
        Patient.Age = value;
        OverviewEditContext.NotifyFieldChanged(new FieldIdentifier(Patient, nameof(Patient.Age)));
        await NotifyOverviewChangedAsync();
    }

    private async Task HandlePatientWeightChangedAsync(decimal? value)
    {
        Patient.Weight = value;
        OverviewEditContext.NotifyFieldChanged(new FieldIdentifier(Patient, nameof(Patient.Weight)));
        await NotifyOverviewChangedAsync();
    }

    private async Task HandlePatientDiagnosisChangedAsync(string value)
    {
        Patient.Diagnosis = value;
        OverviewEditContext.NotifyFieldChanged(new FieldIdentifier(Patient, nameof(Patient.Diagnosis)));
        await NotifyOverviewChangedAsync();
    }

    private async Task HandleAdmissionUnitSelectionChangedAsync(int? value)
    {
        Patient.AdmissionUnitCatalogId = value;
        OverviewEditContext.NotifyFieldChanged(new FieldIdentifier(Patient, nameof(Patient.AdmissionUnitCatalogId)));
        await NotifyOverviewChangedAsync();
    }

    // MudDatePicker stores dates as nullable DateTime values.
    // This helper keeps the markup simple and works whether the event date is already set or not.
    private static DateTime? GetTimelineEventDate(PatientDateEvent item)
    {
        return item.EventDate;
    }

    // We manually update the timeline event date because MudDatePicker uses DateTime?.
    // After changing the value, we notify both:
    // 1) TimelineEditContext, for normal Blazor validation/field-change tracking.
    // 2) PatientDetails.razor, so the bottom Save button can become enabled.
    private async Task HandleTimelineDateChangedAsync(PatientDateEvent item, DateTime? selectedDate)
    {
        item.EventDate = selectedDate ?? DateTime.Today;

        TimelineEditContext.NotifyFieldChanged(new FieldIdentifier(item, nameof(item.EventDate)));

        await NotifyOverviewChangedAsync();
    }

    private async Task HandleTimelineTitleChangedAsync(PatientDateEvent item, string value)
    {
        item.Title = value;

        TimelineEditContext.NotifyFieldChanged(new FieldIdentifier(item, nameof(item.Title)));

        await NotifyOverviewChangedAsync();
    }

    // Central helper for this section.
    // The section does not decide what "dirty" means globally.
    // It only reports a local change to the parent page.
    private Task NotifyOverviewChangedAsync()
    {
        return OnSectionChanged.InvokeAsync();
    }

    // This receives the refreshed catalog list from AdmissionUnitsManager.
    // The patient is not changed here.
    private Task HandleAdmissionUnitsChangedAsync(List<AdmissionUnitCatalog> refreshedAdmissionUnits)
    {
        AdmissionUnits.Clear();
        AdmissionUnits.AddRange(refreshedAdmissionUnits);

        return Task.CompletedTask;
    }

    // This receives success messages from AdmissionUnitsManager.
    // Example: "Admission unit saved to catalog."
    private Task HandleAdmissionUnitStatusMessageAsync(string message)
    {
        admissionUnitStatusMessage = message;
        return Task.CompletedTask;
    }
}