@using IcuNotes.Models
@using IcuNotes.Constants
@using Microsoft.AspNetCore.Components.Forms

@* This component contains the Overview section UI.
   Timeline is shown inside the Overview section too. *@
@if (Patient is not null)
{
    <div>
        <div class="mb-3">
            <h5 class="mb-0">Overview</h5>
        </div>

        @if (!string.IsNullOrWhiteSpace(admissionUnitStatusMessage))
        {
            <div class="alert alert-success py-2">
                @admissionUnitStatusMessage
            </div>
        }

        @* This form should contain ONLY fields that belong to the current Patient overview.

           Important:
           AdmissionUnitsManager is intentionally NOT inside this EditForm anymore.

           Why?
           If AdmissionUnitsManager is inside this EditForm, its modal InputText controls receive
           the OverviewEditContext automatically from Blazor. Then typing inside the modal marks
           Overview as dirty even though the patient was not changed.

           By keeping AdmissionUnitsManager outside the EditForm, catalog editing is separated
           from patient overview editing. *@
        <EditForm EditContext="OverviewEditContext">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Name</label>
                    <InputText class="form-control"
                               @bind-Value="Patient.Name" />
                    <ValidationMessage For="@(() => Patient.Name)" />
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">Bed</label>
                    <InputSelect class="form-select"
                                 @bind-Value="Patient.Bed">
                        <option value="">-- Select Bed --</option>

                        @foreach (var bed in BedOptions.All)
                        {
                            <option value="@bed">@bed</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => Patient.Bed)" />
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Age</label>
                    <InputNumber class="form-control"
                                 @bind-Value="Patient.Age" />
                    <ValidationMessage For="@(() => Patient.Age)" />
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">Weight</label>
                    <InputNumber class="form-control"
                                 @bind-Value="Patient.Weight" />
                    <ValidationMessage For="@(() => Patient.Weight)" />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Diagnosis</label>
                <InputText class="form-control"
                           @bind-Value="Patient.Diagnosis" />
                <ValidationMessage For="@(() => Patient.Diagnosis)" />
            </div>

            <div class="mb-3">
                <label class="form-label">Admission Unit</label>
                <InputSelect class="form-select"
                             @bind-Value="Patient.AdmissionUnitCatalogId">
                    <option value="">-- Select Admission Unit --</option>

                    @foreach (var unit in AdmissionUnits)
                    {
                        <option value="@unit.Id">@unit.Name</option>
                    }
                </InputSelect>

                <div class="form-text">
                    Selecting a unit here changes the current patient and will be saved from the bottom bar.
                </div>
            </div>

        </EditForm>

        @* This reusable manager handles the shared Admission Unit catalog only.

           It is outside the Overview EditForm on purpose.

           Clean separation:
           - This manager adds/edits catalog rows.
           - The dropdown above selects the admission unit for this patient.
           - The bottom Save button saves the patient's selected admission unit. *@
        <AdmissionUnitsManager AdmissionUnits="AdmissionUnits"
                               IsDisabled="IsSaving"
                               OnAdmissionUnitsChanged="HandleAdmissionUnitsChangedAsync"
                               OnStatusMessage="HandleAdmissionUnitStatusMessageAsync" />

        <hr class="my-4" />

        @* Timeline is part of Overview, but it has its own EditContext for dirty tracking. *@
        <div>
            <div class="mb-3">
                <h5 class="mb-0">Timeline</h5>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-3">
                <div></div>

                <button type="button"
                        class="btn btn-outline-primary"
                        @onclick="HandleAddTimelineEventAsync"
                        disabled="@IsSaving">
                    Add Timeline Event
                </button>
            </div>

            @if (OrderedDateEvents.Any())
            {
                <EditForm EditContext="TimelineEditContext">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    @foreach (var item in OrderedDateEvents)
                    {
                        <div class="border rounded p-3 mb-3">
                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Event Date</label>
                                    <InputDate class="form-control"
                                               @bind-Value="item.EventDate" />
                                </div>

                                <div class="col-md-8 mb-3">
                                    <label class="form-label">Title</label>
                                    <InputText class="form-control"
                                               @bind-Value="item.Title" />
                                </div>
                            </div>

                            <div class="d-flex gap-2">
                                <button type="button"
                                        class="btn btn-outline-danger btn-sm"
                                        @onclick="() => HandleRemoveTimelineEventAsync(item)">
                                    Remove From Page
                                </button>
                            </div>
                        </div>
                    }

                </EditForm>
            }
            else
            {
                <div class="alert alert-light border">
                    No timeline events added yet.
                </div>

            }
        </div>
    </div>
}

@code {
    // This is the main Patient object passed from the parent page.
    [Parameter, EditorRequired]
    public Patient Patient { get; set; } = default!;

    // This shared catalog fills the Admission Unit dropdown and the AdmissionUnitsManager modals.
    [Parameter, EditorRequired]
    public List<AdmissionUnitCatalog> AdmissionUnits { get; set; } = new();

    // This list contains the ordered timeline rows shown in the Overview section.
    [Parameter, EditorRequired]
    public List<PatientDateEvent> OrderedDateEvents { get; set; } = new();

    // This EditContext is created by PatientDetails.razor.
    // It tracks changes in the patient overview fields.
    [Parameter, EditorRequired]
    public EditContext OverviewEditContext { get; set; } = default!;

    // This EditContext is created by PatientDetails.razor.
    // It tracks changes in the timeline fields.
    [Parameter, EditorRequired]
    public EditContext TimelineEditContext { get; set; } = default!;

    // PatientDetails.razor passes this value while saving/reloading.
    // We use it here only to disable buttons that should not be clicked during saving.
    [Parameter]
    public bool IsSaving { get; set; }

    // The parent page still owns timeline row creation.
    // This component only displays the button and forwards the click.
    [Parameter, EditorRequired]
    public EventCallback OnAddTimelineEvent { get; set; }

    // The parent page still owns timeline row removal.
    // This component only forwards the selected row to the parent.
    [Parameter, EditorRequired]
    public EventCallback<PatientDateEvent> OnRemoveTimelineEvent { get; set; }

    // This message is used only for admission-unit catalog actions.
    // It does not mean the patient overview was changed or saved.
    private string? admissionUnitStatusMessage;

    // This forwards the add-timeline-row request to PatientDetails.razor.
    private Task HandleAddTimelineEventAsync()
    {
        return OnAddTimelineEvent.InvokeAsync();
    }

    // This forwards the remove-timeline-row request to PatientDetails.razor.
    private Task HandleRemoveTimelineEventAsync(PatientDateEvent item)
    {
        return OnRemoveTimelineEvent.InvokeAsync(item);
    }

    // This receives the refreshed catalog list from AdmissionUnitsManager.
    // The patient is not changed here.
    private Task HandleAdmissionUnitsChangedAsync(List<AdmissionUnitCatalog> refreshedAdmissionUnits)
    {
        AdmissionUnits.Clear();
        AdmissionUnits.AddRange(refreshedAdmissionUnits);

        return Task.CompletedTask;
    }

    // This receives success messages from AdmissionUnitsManager.
    // Example: "Admission unit saved to catalog."
    private Task HandleAdmissionUnitStatusMessageAsync(string message)
    {
        admissionUnitStatusMessage = message;
        return Task.CompletedTask;
    }
}
