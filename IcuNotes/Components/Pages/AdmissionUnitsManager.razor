@using IcuNotes.Models
@using Microsoft.AspNetCore.Components.Forms
@inject IcuNotes.Services.PatientService PatientService

@*
    AdmissionUnitsManager.razor

    This component manages the shared Admission Unit catalog only.

    Important design rule:
    - This component adds and edits AdmissionUnitCatalog rows.
    - It does NOT decide which admission unit belongs to the current patient.
    - The current patient's selected admission unit is Overview data,
      so that must stay inside OverviewSection.razor.

    MudBlazor migration notes:
    - Bootstrap buttons and modals were replaced with MudBlazor components.
    - Instead of opening modal windows, this version uses an inline expandable panel.
    - This is simpler and safer on mobile because the user stays inside the Overview page.
    - No JavaScript is used.
*@

<MudStack Spacing="2">

    @*
        Two compact actions.

        MudGrid keeps the buttons equal width on mobile.
        This replaces the old Bootstrap row/col button layout.
    *@
    <MudGrid Spacing="2">
        <MudItem xs="6">
            <MudButton FullWidth="true"
                       Variant="Variant.Outlined"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       Disabled="@IsBusy"
                       OnClick="OpenAddAdmissionUnitModal">
                Add Unit
            </MudButton>
        </MudItem>

        <MudItem xs="6">
            <MudButton FullWidth="true"
                       Variant="Variant.Outlined"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Edit"
                       Disabled="@IsBusy"
                       OnClick="OpenEditAdmissionUnitModal">
                Edit Unit
            </MudButton>
        </MudItem>
    </MudGrid>

    @*
        Add Admission Unit panel.

        This replaces the old Bootstrap modal.
        The panel appears inline under the buttons, which is more predictable
        inside a mobile-first patient details page.
    *@
    @if (showAddAdmissionUnitModal)
    {
        <MudPaper Elevation="0"
                  Outlined="true"
                  Class="pa-3 rounded-lg">

            <MudStack Spacing="2">
                <MudStack Row="true"
                          AlignItems="AlignItems.Center"
                          Justify="Justify.SpaceBetween"
                          Spacing="2">

                    <MudText Typo="Typo.subtitle2">
                        Add admission unit
                    </MudText>

                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                   Color="Color.Default"
                                   Size="Size.Small"
                                   Disabled="@IsBusy"
                                   OnClick="CloseAddAdmissionUnitModal"
                                   AriaLabel="Close add admission unit panel" />
                </MudStack>

                @if (!string.IsNullOrWhiteSpace(newAdmissionUnitErrorMessage))
                {
                    <MudAlert Severity="Severity.Warning"
                              Dense="true"
                              Variant="Variant.Outlined">
                        @newAdmissionUnitErrorMessage
                    </MudAlert>
                }

                @*
                    MudTextField is used instead of InputText.

                    Why?
                    This component is a catalog manager, not part of the patient
                    Overview EditForm. Keeping this as an independent MudBlazor
                    field avoids accidental interaction with the parent EditContext.
                *@
                <MudTextField T="string"
                              Label="Admission unit name"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Immediate="true"
                              Disabled="@IsBusy"
                              @bind-Value="newAdmissionUnitName" />

                <MudGrid Spacing="2">
                    <MudItem xs="6">
                        <MudButton FullWidth="true"
                                   Variant="Variant.Outlined"
                                   Color="Color.Default"
                                   Disabled="@IsBusy"
                                   OnClick="CloseAddAdmissionUnitModal">
                            Cancel
                        </MudButton>
                    </MudItem>

                    <MudItem xs="6">
                        <MudButton FullWidth="true"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Disabled="@IsBusy"
                                   OnClick="SaveNewAdmissionUnitAsync">
                            @if (IsBusy)
                            {
                                <MudProgressCircular Indeterminate="true"
                                                     Size="Size.Small"
                                                     Class="me-2" />
                                <span>Saving</span>
                            }
                            else
                            {
                                <span>Save</span>
                            }
                        </MudButton>
                    </MudItem>
                </MudGrid>
            </MudStack>
        </MudPaper>
    }

    @*
        Edit Admission Unit panel.

        This also replaces the old Bootstrap modal.
        It stays inline so the user can quickly edit the catalog without
        visually leaving the Overview section.
    *@
    @if (showEditAdmissionUnitModal)
    {
        <MudPaper Elevation="0"
                  Outlined="true"
                  Class="pa-3 rounded-lg">

            <MudStack Spacing="2">
                <MudStack Row="true"
                          AlignItems="AlignItems.Center"
                          Justify="Justify.SpaceBetween"
                          Spacing="2">

                    <MudText Typo="Typo.subtitle2">
                        Edit admission unit
                    </MudText>

                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                   Color="Color.Default"
                                   Size="Size.Small"
                                   Disabled="@IsBusy"
                                   OnClick="CloseEditAdmissionUnitModal"
                                   AriaLabel="Close edit admission unit panel" />
                </MudStack>

                @if (!string.IsNullOrWhiteSpace(editAdmissionUnitErrorMessage))
                {
                    <MudAlert Severity="Severity.Warning"
                              Dense="true"
                              Variant="Variant.Outlined">
                        @editAdmissionUnitErrorMessage
                    </MudAlert>
                }

                @if (!AdmissionUnits.Any())
                {
                    <MudAlert Severity="Severity.Info"
                              Dense="true"
                              Variant="Variant.Outlined">
                        No admission units in the catalog yet.
                    </MudAlert>
                }
                else
                {
                    <MudSelect T="int"
                               Label="Select unit"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Disabled="@IsBusy"
                               Value="@selectedAdmissionUnitToEditId"
                               ValueChanged="OnSelectedAdmissionUnitToEditChanged">

                        @foreach (var unit in AdmissionUnits)
                        {
                            <MudSelectItem T="int" Value="@unit.Id">
                                @unit.Name
                            </MudSelectItem>
                        }
                    </MudSelect>

                    @*
                        MudTextField is used instead of InputText for the same
                        reason as the Add panel: this is catalog state, not
                        patient Overview form state.
                    *@
                    <MudTextField T="string"
                                  Label="Unit name"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Immediate="true"
                                  Disabled="@IsBusy"
                                  @bind-Value="editAdmissionUnitName" />
                }

                <MudGrid Spacing="2">
                    <MudItem xs="6">
                        <MudButton FullWidth="true"
                                   Variant="Variant.Outlined"
                                   Color="Color.Default"
                                   Disabled="@IsBusy"
                                   OnClick="CloseEditAdmissionUnitModal">
                            Cancel
                        </MudButton>
                    </MudItem>

                    <MudItem xs="6">
                        <MudButton FullWidth="true"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Disabled="@(IsBusy || !AdmissionUnits.Any())"
                                   OnClick="SaveEditedAdmissionUnitAsync">
                            @if (IsBusy)
                            {
                                <MudProgressCircular Indeterminate="true"
                                                     Size="Size.Small"
                                                     Class="me-2" />
                                <span>Saving</span>
                            }
                            else
                            {
                                <span>Save</span>
                            }
                        </MudButton>
                    </MudItem>
                </MudGrid>
            </MudStack>
        </MudPaper>
    }

</MudStack>

@code {
    // This shared catalog fills the Admission Unit dropdown in Overview
    // and the Edit Admission Unit panel here.
    [Parameter, EditorRequired]
    public List<AdmissionUnitCatalog> AdmissionUnits { get; set; } = new();

    // This follows the same idea as MedicationsManager:
    // the parent can disable this manager while another save operation is happening.
    [Parameter]
    public bool IsDisabled { get; set; }

    // Temporary compatibility with the old OverviewSection parameter name.
    // Later we can remove IsSaving and use only IsDisabled, like MedicationsManager.
    [Parameter]
    public bool IsSaving { get; set; }

    // This callback lets the parent know that the catalog list has changed.
    [Parameter]
    public EventCallback<List<AdmissionUnitCatalog>> OnAdmissionUnitsChanged { get; set; }

    // Optional callback for showing a success message in the parent page.
    [Parameter]
    public EventCallback<string> OnStatusMessage { get; set; }

    // These old parameters are kept only so older parent code does not break.
    // They are intentionally NOT used anymore.
    // This separates the catalog manager from the patient overview.
    [Parameter]
    public Patient? Patient { get; set; }

    [Parameter]
    public EditContext? OverviewEditContext { get; set; }

    [Parameter]
    public EventCallback OnSaveAdmissionUnitSelection { get; set; }

    // This local state controls the Add Admission Unit panel.
    private bool showAddAdmissionUnitModal;
    private string newAdmissionUnitName = string.Empty;
    private string? newAdmissionUnitErrorMessage;

    // This local state controls the Edit Admission Unit panel.
    private bool showEditAdmissionUnitModal;
    private int selectedAdmissionUnitToEditId;
    private string editAdmissionUnitName = string.Empty;
    private string? editAdmissionUnitErrorMessage;

    // This local flag prevents double-clicking the panel save buttons.
    private bool isWorking;

    // This combined flag is used by buttons and panel actions.
    private bool IsBusy => IsDisabled || IsSaving || isWorking;

    // This method opens the Add panel in a clean empty state.
    private void OpenAddAdmissionUnitModal()
    {
        showEditAdmissionUnitModal = false;

        newAdmissionUnitName = string.Empty;
        newAdmissionUnitErrorMessage = null;

        showAddAdmissionUnitModal = true;
    }

    // This method closes the Add panel and clears old validation messages.
    private void CloseAddAdmissionUnitModal()
    {
        if (IsBusy)
            return;

        showAddAdmissionUnitModal = false;
        newAdmissionUnitErrorMessage = null;
    }

    // This method opens the Edit panel and preloads the first available unit.
    // Notice that it no longer uses Patient.AdmissionUnitCatalogId.
    // The selected patient admission unit belongs to Overview, not to this manager.
    private void OpenEditAdmissionUnitModal()
    {
        showAddAdmissionUnitModal = false;

        editAdmissionUnitErrorMessage = null;
        showEditAdmissionUnitModal = true;

        if (AdmissionUnits.Any())
        {
            var unitIdToLoad = selectedAdmissionUnitToEditId > 0
                ? selectedAdmissionUnitToEditId
                : AdmissionUnits.First().Id;

            LoadAdmissionUnitForEdit(unitIdToLoad);
        }
        else
        {
            selectedAdmissionUnitToEditId = 0;
            editAdmissionUnitName = string.Empty;
        }
    }

    // This method closes the Edit panel and clears temporary selection state.
    private void CloseEditAdmissionUnitModal()
    {
        if (IsBusy)
            return;

        showEditAdmissionUnitModal = false;
        selectedAdmissionUnitToEditId = 0;
        editAdmissionUnitName = string.Empty;
        editAdmissionUnitErrorMessage = null;
    }

    // This method reacts when the user chooses another catalog row in the MudSelect.
    private void OnSelectedAdmissionUnitToEditChanged(int admissionUnitId)
    {
        if (admissionUnitId <= 0)
            return;

        LoadAdmissionUnitForEdit(admissionUnitId);
    }

    // This helper loads the selected catalog row into the edit textbox.
    private void LoadAdmissionUnitForEdit(int admissionUnitId)
    {
        selectedAdmissionUnitToEditId = admissionUnitId;

        var selectedAdmissionUnit = AdmissionUnits
            .FirstOrDefault(x => x.Id == admissionUnitId);

        if (selectedAdmissionUnit is null)
        {
            editAdmissionUnitName = string.Empty;
            return;
        }

        editAdmissionUnitName = selectedAdmissionUnit.Name;
    }

    // This method saves a new shared Admission Unit catalog row.
    // It does NOT auto-select the new unit for the current patient.
    // Therefore, it does NOT mark Overview as dirty.
    private async Task SaveNewAdmissionUnitAsync()
    {
        try
        {
            newAdmissionUnitErrorMessage = null;

            if (string.IsNullOrWhiteSpace(newAdmissionUnitName))
            {
                newAdmissionUnitErrorMessage = "Admission unit name is required.";
                return;
            }

            isWorking = true;

            await PatientService.AddAdmissionUnitIfMissingAsync(new AdmissionUnitCatalog
            {
                Name = newAdmissionUnitName.Trim()
            });

            await RefreshAdmissionUnitsAsync();

            showAddAdmissionUnitModal = false;
            newAdmissionUnitName = string.Empty;
            newAdmissionUnitErrorMessage = null;

            if (OnStatusMessage.HasDelegate)
            {
                await OnStatusMessage.InvokeAsync("Admission unit saved to catalog.");
            }
        }
        catch (Exception ex)
        {
            newAdmissionUnitErrorMessage = ex.Message;
        }
        finally
        {
            isWorking = false;
        }
    }

    // This method saves edits to an existing shared Admission Unit catalog row.
    // This is also catalog-only. It does not change the current patient.
    private async Task SaveEditedAdmissionUnitAsync()
    {
        try
        {
            editAdmissionUnitErrorMessage = null;

            if (selectedAdmissionUnitToEditId <= 0)
            {
                editAdmissionUnitErrorMessage = "Please select an admission unit first.";
                return;
            }

            if (string.IsNullOrWhiteSpace(editAdmissionUnitName))
            {
                editAdmissionUnitErrorMessage = "Admission unit name is required.";
                return;
            }

            isWorking = true;

            await PatientService.UpdateAdmissionUnitAsync(new AdmissionUnitCatalog
            {
                Id = selectedAdmissionUnitToEditId,
                Name = editAdmissionUnitName.Trim()
            });

            await RefreshAdmissionUnitsAsync();

            // Reload the selected row from the refreshed list so the panel has the saved value.
            LoadAdmissionUnitForEdit(selectedAdmissionUnitToEditId);

            showEditAdmissionUnitModal = false;
            editAdmissionUnitErrorMessage = null;

            if (OnStatusMessage.HasDelegate)
            {
                await OnStatusMessage.InvokeAsync("Admission unit updated in catalog.");
            }
        }
        catch (Exception ex)
        {
            editAdmissionUnitErrorMessage = ex.Message;
        }
        finally
        {
            isWorking = false;
        }
    }

    // This helper refreshes the catalog list after add/edit.
    // We update the existing list in-place so any component using the same list object
    // can see the refreshed data.
    private async Task RefreshAdmissionUnitsAsync()
    {
        var refreshedAdmissionUnits = await PatientService.GetAdmissionUnitsAsync();

        AdmissionUnits.Clear();
        AdmissionUnits.AddRange(refreshedAdmissionUnits);

        if (OnAdmissionUnitsChanged.HasDelegate)
        {
            await OnAdmissionUnitsChanged.InvokeAsync(refreshedAdmissionUnits);
        }
    }
}
