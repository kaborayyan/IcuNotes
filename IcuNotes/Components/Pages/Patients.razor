@page "/patients"
@using IcuNotes.Models
@using IcuNotes.Constants
@inject IcuNotes.Services.PatientService PatientService

<PageTitle>Patients</PageTitle>

<!--
    Patients.razor

    This page is intentionally simple.

    Its job is:
    1) show active ICU patients
    2) allow quick creation of a new patient using only Name and Bed
    3) send the user to PatientDetails.razor for full editing
    4) allow archiving a patient

    UI approach in this version:
    - The add-new-patient form is inside a modal.
    - The patient list uses Bootstrap cards instead of a table.
    - The page uses Bootstrap classes as much as possible.
    - No custom CSS is used here.
    - No Bootstrap JavaScript is required.
-->

<div class="container-fluid px-0">

    <!-- Page header -->
    <div class="row g-2 align-items-center mb-3">
        <div class="col-12 col-sm">
            <h3 class="mb-1">Active Patients</h3>

            <div class="text-muted small">
                Quick list of currently active ICU patients
            </div>
        </div>

        <div class="col-12 col-sm-auto">
            <!--
                This opens a Blazor-controlled modal.

                We are using Bootstrap modal CSS classes,
                but we are NOT using Bootstrap modal JavaScript.
            -->
            <button type="button"
                    class="btn btn-primary w-100"
                    @onclick="OpenAddPatientModal">
                + Add Patient
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="alert @statusCssClass">
            @statusMessage
        </div>
    }

    @if (patients.Count == 0)
    {
        <!-- Bootstrap card used as a simple empty state -->
        <div class="card">
            <div class="card-body text-center text-muted">
                No active patients found.
            </div>
        </div>
    }
    else
    {
        <!--
            Patient list.

            We are using cards instead of a table because tables become cramped
            on small mobile screens.

            Each card only shows:
            - Name
            - Bed
            - View / Edit button
            - Archive button
        -->
        <div class="vstack gap-2">
            @foreach (var patient in patients)
            {
                <div class="card">
                    <div class="card-body py-3">

                        <div class="row g-2 align-items-center">

                            <!-- Patient name and bed -->
                            <div class="col-12 col-sm">
                                <div class="fw-semibold fs-5">
                                    @patient.Name
                                </div>

                                @if (!string.IsNullOrWhiteSpace(patient.Bed))
                                {
                                    <span class="badge bg-light text-dark border">
                                        Bed @patient.Bed
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-muted border">
                                        No bed
                                    </span>
                                }
                            </div>

                            <!-- View / Edit button -->
                            <div class="col-6 col-sm-auto">
                                <!--
                                    PatientDetails.razor is the main page for editing.
                                -->
                                <a class="btn btn-sm btn-info w-100"
                                       href="/patients/@patient.Id">
                                    View / Edit
                                </a>
                            </div>

                            <!-- Archive button -->
                            <div class="col-6 col-sm-auto">
                                <button type="button"
                                        class="btn btn-sm btn-outline-secondary w-100"
                                        @onclick="() => ArchivePatient(patient.Id)">
                                    Archive
                                </button>
                            </div>

                        </div>

                    </div>
                </div>
            }
        </div>
    }
</div>

@if (showAddPatientModal)
{
    <!--
        Blazor-controlled Bootstrap-style modal.

        Important:
        Bootstrap normally expects JavaScript to open/close modals.

        Here we avoid JavaScript by conditionally rendering the modal only when
        showAddPatientModal is true.

        The class "show d-block" makes the modal visible.
    -->
    <div class="modal fade show d-block"
         tabindex="-1"
         role="dialog"
         aria-modal="true"
         @onclick="CloseAddPatientModal">

        <!--
            modal-dialog-centered:
            Keeps the modal vertically centered.

            modal-dialog-scrollable:
            Allows scrolling inside the modal if the screen is small.

            @onclick:stopPropagation:
            Prevents clicks inside the modal from closing it.
            Clicking outside the modal closes it.
        -->
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable"
             @onclick:stopPropagation="true">

            <div class="modal-content">

                <div class="modal-header">
                    <div>
                        <h5 class="modal-title">Add New Patient</h5>

                        <div class="text-muted small">
                            Only name and bed are needed here.
                        </div>
                    </div>

                    <button type="button"
                            class="btn-close"
                            aria-label="Close"
                            @onclick="CloseAddPatientModal">
                    </button>
                </div>

                <EditForm Model="newPatientModel" OnValidSubmit="HandleValidSubmit">
                    <DataAnnotationsValidator />

                    <div class="modal-body">

                        <!--
                            ValidationSummary shows validation errors from the Patient model.
                            For example, if Name is required and left empty.
                        -->
                        <ValidationSummary />

                        <div class="mb-3">
                            <label class="form-label">Name</label>

                            <InputText class="form-control"
                                       placeholder="Patient name"
                                       @bind-Value="newPatientModel.Name" />

                            <ValidationMessage For="@(() => newPatientModel.Name)" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Bed</label>

                            <InputSelect class="form-select"
                                         @bind-Value="newPatientModel.Bed">
                                <option value="">-- Select Bed --</option>

                                @foreach (var bed in BedOptions.All)
                                {
                                    <option value="@bed">@bed</option>
                                }
                            </InputSelect>

                            <ValidationMessage For="@(() => newPatientModel.Bed)" />
                        </div>

                    </div>

                    <div class="modal-footer">

                        <button type="submit"
                                class="btn btn-primary">
                            Add Patient
                        </button>

                        <button type="button"
                                class="btn btn-outline-secondary"
                                @onclick="ClearForm">
                            Clear
                        </button>

                        <button type="button"
                                class="btn btn-secondary"
                                @onclick="CloseAddPatientModal">
                            Cancel
                        </button>

                    </div>
                </EditForm>

            </div>
        </div>
    </div>

    <!--
        Bootstrap modal backdrop.

        This is only the dark background layer.
        It is rendered manually because we are not using Bootstrap JavaScript.
    -->
    <div class="modal-backdrop fade show"></div>
}

@code {
    // CSS class used by the status message area.
    private string statusCssClass = "alert-info";

    // List of active patients shown on the page.
    private List<Patient> patients = new();

    // This model is used only for quick creation of a new patient.
    // Full editing happens later in PatientDetails.razor.
    private Patient newPatientModel = new();

    // Simple feedback message shown to the user.
    private string? statusMessage;

    // Controls whether the Add Patient modal is visible.
    private bool showAddPatientModal;

    protected override async Task OnInitializedAsync()
    {
        /*
            Keep catalog seeding here.

            Even though this page no longer displays admission units,
            the app still needs the admission unit catalog elsewhere,
            especially in PatientDetails.razor.
        */
        await PatientService.SeedAdmissionUnitsIfEmptyAsync();

        // Load active patients.
        await LoadPatientsAsync();
    }

    private async Task LoadPatientsAsync()
    {
        // Read the current active patients from the database.
        patients = await PatientService.GetAllAsync();
    }

    private void OpenAddPatientModal()
    {
        /*
            Start with a fresh model every time the modal opens.

            This prevents old typed values from appearing if the user
            opened the modal before and then cancelled.
        */
        newPatientModel = new Patient();

        // Show the modal.
        showAddPatientModal = true;
    }

    private void CloseAddPatientModal()
    {
        // Hide the modal.
        showAddPatientModal = false;

        // Clear any typed values.
        ClearForm();
    }

    private void ClearForm()
    {
        // Start with a fresh empty model.
        newPatientModel = new Patient();
    }

    private void SetStatus(string message, string cssClass = "alert-info")
    {
        statusMessage = message;
        statusCssClass = cssClass;
    }

    private async Task HandleValidSubmit()
    {
        /*
            Add a new patient using only the quick-entry fields
            that belong on this page.
        */
        await PatientService.AddAsync(newPatientModel);

        SetStatus("Patient added successfully.", "alert-success");

        // Refresh the list so the new patient appears.
        await LoadPatientsAsync();

        // Close the modal after successful add.
        showAddPatientModal = false;

        // Prepare a clean model for the next patient.
        ClearForm();
    }

    private async Task ArchivePatient(int id)
    {
        // Move the patient from active patients to archived patients.
        await PatientService.ArchiveAsync(id);

        // Refresh the list after archiving.
        await LoadPatientsAsync();

        SetStatus("Patient archived successfully.", "alert-success");
    }
}