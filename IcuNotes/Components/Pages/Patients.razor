@page "/patients"
@using IcuNotes.Models
@using IcuNotes.Constants
@inject IcuNotes.Services.PatientService PatientService

<PageTitle>Patients</PageTitle>

<h3>Patients</h3>

<!--
    This page is now intentionally simple.

    Its job is:
    1) quickly add a new patient using only Name and Bed
    2) show the patient list
    3) send the user to PatientDetails for real editing
-->

<div class="card p-3 mb-4">
    <h4>Add New Patient</h4>

    <EditForm Model="newPatientModel" OnValidSubmit="HandleValidSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label class="form-label">Name</label>

            <!--
                InputText is enough here because this page only needs
                a quick patient name entry.
            -->
            <InputText class="form-control"
                       @bind-Value="newPatientModel.Name" />

            <ValidationMessage For="@(() => newPatientModel.Name)" />
        </div>

        <div class="mb-3">
            <label class="form-label">Bed</label>

            <!--
                Bed selection stays here because it is part of the
                quick-create workflow.
            -->
            <InputSelect class="form-select"
                         @bind-Value="newPatientModel.Bed">
                <option value="">-- Select Bed --</option>

                @foreach (var bed in BedOptions.All)
                {
                    <option value="@bed">@bed</option>
                }
            </InputSelect>

            <ValidationMessage For="@(() => newPatientModel.Bed)" />
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">
                Add Patient
            </button>

            <button type="button" class="btn btn-secondary" @onclick="ClearForm">
                Clear
            </button>
        </div>
    </EditForm>
</div>

@if (!string.IsNullOrWhiteSpace(statusMessage))
{
    <div class="alert @statusCssClass">
        @statusMessage
    </div>
}

@if (patients.Count == 0)
{
    <p>No active patients found.</p>
}
else
{
    <table class="table table-striped table-bordered align-middle">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Bed</th>
                <th>Diagnosis</th>
                <th>Admission Unit</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var patient in patients)
            {
                <tr>
                    <td>@patient.Id</td>
                    <td>@patient.Name</td>
                    <td>@patient.Bed</td>
                    <td>
                        @if (!string.IsNullOrWhiteSpace(patient.Diagnosis))
                        {
                            @patient.Diagnosis
                        }
                        else
                        {
                            <span class="text-muted">Not added</span>
                        }
                    </td>
                    <td>
                        @if (!string.IsNullOrWhiteSpace(GetAdmissionUnitName(patient.AdmissionUnitCatalogId)))
                        {
                            @GetAdmissionUnitName(patient.AdmissionUnitCatalogId)
                        }
                        else
                        {
                            <span class="text-muted">Not added</span>
                        }
                    </td>
                    <td>
                        <!--
                            PatientDetails is now the main place for editing,
                            so this button opens the details page.
                        -->
                        <a class="btn btn-sm btn-info me-2"
                               href="/patients/@patient.Id">
                            View / Edit
                        </a>

                        <button class="btn btn-sm btn-secondary"
                                @onclick="() => ArchivePatient(patient.Id)">
                            Archive
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    // CSS class used by the status message area.
    private string statusCssClass = "alert-info";

    // List of active patients shown in the table.
    private List<Patient> patients = new();

    // List of admission units used only to display the unit name in the table.
    private List<AdmissionUnitCatalog> admissionUnits = new();

    // This model is used only for quick creation of a new patient.
    // It is no longer used for editing.
    private Patient newPatientModel = new();

    // Simple feedback message shown to the user.
    private string? statusMessage;

    protected override async Task OnInitializedAsync()
    {
        // Keep catalog seeding here so admission units remain available
        // throughout the app, especially when we expand PatientDetails.
        await PatientService.SeedAdmissionUnitsIfEmptyAsync();

        // Load admission unit names for display in the table.
        admissionUnits = await PatientService.GetAdmissionUnitsAsync();

        // Load active patients.
        await LoadPatientsAsync();
    }

    // Helper method to show a message to the user.
    private void SetStatus(string message, string cssClass = "alert-info")
    {
        statusMessage = message;
        statusCssClass = cssClass;
    }

    private async Task LoadPatientsAsync()
    {
        // Read the current active patients from the database.
        patients = await PatientService.GetAllAsync();
    }

    private async Task HandleValidSubmit()
    {
        // Add a new patient using only the quick-entry fields
        // that belong on this page.
        await PatientService.AddAsync(newPatientModel);

        SetStatus("Patient added successfully.", "alert-success");

        // Refresh the table so the new patient appears.
        await LoadPatientsAsync();

        // Clear the form after successful add.
        ClearForm();
    }

    private void ClearForm()
    {
        // Start with a fresh empty model.
        newPatientModel = new Patient();
    }

    private async Task ArchivePatient(int id)
    {
        // Move the patient from active patients to archived patients.
        await PatientService.ArchiveAsync(id);

        // Refresh the table after archiving.
        await LoadPatientsAsync();

        SetStatus("Patient archived successfully.", "alert-success");
    }

    private string? GetAdmissionUnitName(int? admissionUnitCatalogId)
    {
        // No selected unit.
        if (!admissionUnitCatalogId.HasValue)
            return null;

        // Find the matching catalog row and return its name.
        return admissionUnits
            .FirstOrDefault(x => x.Id == admissionUnitCatalogId.Value)
            ?.Name;
    }
}