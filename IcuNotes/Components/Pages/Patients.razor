@page "/patients"
@using IcuNotes.Models
@using IcuNotes.Constants
@using MudBlazor
@inject IcuNotes.Services.PatientService PatientService

<PageTitle>Patients</PageTitle>

<!--
    This page still has the next responsibilities:
    1) show active ICU patients
    2) allow quick creation of a new patient using only Name and Bed
    3) send the user to PatientDetails.razor for full editing
    4) allow archiving a patient    
-->

<MudContainer MaxWidth="MaxWidth.False" Class="pa-0">
    <MudStack Spacing="3">

        <!-- Page header -->
        <MudPaper Elevation="1" Class="rounded-lg">
            <MudCardContent Class="py-3">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="8">
                        <MudText Typo="Typo.h5">
                            Active Patients
                        </MudText>

                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Quick list of currently active ICU patients
                        </MudText>
                    </MudItem>

                    <MudItem xs="12" sm="4">
                        <!--
                        Opens a MudBlazor drawer instead of a Bootstrap modal.
                        No JavaScript is needed.
                    -->
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   FullWidth="true"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="OpenAddPatientPanel">
                            Add Patient
                        </MudButton>
                    </MudItem>
                </MudGrid>
                </MudCardContent>
            
        </MudPaper>

        @if (!string.IsNullOrWhiteSpace(statusMessage))
        {
            <MudAlert Severity="statusSeverity"
                      Variant="Variant.Filled"
                      Dense="true">
                @statusMessage
            </MudAlert>
        }

        @if (patients.Count == 0)
        {
            <!-- Empty state -->
            <MudPaper Elevation="0" Class="pa-6 rounded-lg">
                <MudStack AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.PersonOff"
                             Size="Size.Large"
                             Color="Color.Secondary" />

                    <MudText Typo="Typo.body1" Color="Color.Secondary">
                        No active patients found.
                    </MudText>
                </MudStack>
            </MudPaper>
        }
        else
        {
            <!--
                Patient list.

                Cards are still better than a table on mobile screens.
                MudBlazor cards give us a cleaner Material Design look.
            -->
            <MudStack Spacing="2">
                @foreach (var patient in patients)
                {
                    <MudCard Elevation="1" Class="rounded-lg">
                        <MudCardContent Class="py-3">
                            <MudGrid Spacing="2">

                                <!-- Patient name and bed -->
                                <MudItem xs="12" sm="6">
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.h6">
                                            @patient.Name
                                        </MudText>

                                        @if (!string.IsNullOrWhiteSpace(patient.Bed))
                                        {
                                            <MudChip T="string"
                                                     Size="Size.Small"
                                                     Variant="Variant.Outlined"
                                                     Color="Color.Primary">
                                                Bed @patient.Bed
                                            </MudChip>
                                        }
                                        else
                                        {
                                            <MudChip T="string"
                                                     Size="Size.Small"
                                                     Variant="Variant.Outlined"
                                                     Color="Color.Secondary">
                                                No bed
                                            </MudChip>
                                        }
                                    </MudStack>
                                </MudItem>

                                <!-- View / Edit button -->
                                <MudItem xs="6" sm="3">
                                    <!-- PatientDetails.razor is the main page for editing. -->
                                    <MudButton Href="@($"/patients/{patient.Id}")"
                                               Variant="Variant.Filled"
                                               Color="Color.Info"
                                               Size="Size.Small"
                                               FullWidth="true"
                                               StartIcon="@Icons.Material.Filled.Edit">
                                        View / Edit
                                    </MudButton>
                                </MudItem>

                                <!-- Archive button -->
                                <MudItem xs="6" sm="3">
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Secondary"
                                               Size="Size.Small"
                                               FullWidth="true"
                                               StartIcon="@Icons.Material.Filled.Archive"
                                               OnClick="() => ArchivePatient(patient.Id)">
                                        Archive
                                    </MudButton>
                                </MudItem>

                            </MudGrid>
                        </MudCardContent>
                    </MudCard>
                }
            </MudStack>
        }
    </MudStack>
</MudContainer>

<!--
    Add Patient panel.

    This replaces the Bootstrap modal.
    A bottom drawer works well on phones because the form appears near the thumb area.
-->
<MudDrawer @bind-Open="showAddPatientPanel"
           Anchor="Anchor.Bottom"
           Variant="DrawerVariant.Temporary"
           Elevation="8">

    <MudPaper Elevation="0" Class="pa-4">
        <MudStack Spacing="3">

            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <div>
                    <MudText Typo="Typo.h6">
                        Add New Patient
                    </MudText>

                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Only name and bed are needed here.
                    </MudText>
                </div>

                <MudIconButton Icon="@Icons.Material.Filled.Close"
                               Color="Color.Default"
                               Edge="Edge.End"
                               OnClick="CloseAddPatientPanel" />
            </MudStack>

            <EditForm Model="newPatientModel" OnValidSubmit="HandleValidSubmit">
                <DataAnnotationsValidator />

                <MudStack Spacing="3">
                    <!--
                        ValidationSummary shows validation errors from the Patient model.
                        For example, if Name is required and left empty.
                    -->
                    <ValidationSummary />

                    <MudTextField T="string"
                                  Label="Name"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Immediate="true"
                                  @bind-Value="newPatientModel.Name"
                                  For="@(() => newPatientModel.Name)" />

                    <MudSelect T="string"
                               Label="Bed"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Clearable="true"
                               @bind-Value="newPatientModel.Bed"
                               For="@(() => newPatientModel.Bed)">

                        @foreach (var bed in BedOptions.All)
                        {
                            <MudSelectItem T="string" Value="@bed">
                                @bed
                            </MudSelectItem>
                        }
                    </MudSelect>

                    <MudGrid Spacing="2">
                        <MudItem xs="12" sm="4">
                            <MudButton ButtonType="ButtonType.Submit"
                                       Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       FullWidth="true"
                                       StartIcon="@Icons.Material.Filled.Save">
                                Add Patient
                            </MudButton>
                        </MudItem>

                        <MudItem xs="6" sm="4">
                            <MudButton ButtonType="ButtonType.Button"
                                       Variant="Variant.Outlined"
                                       Color="Color.Secondary"
                                       FullWidth="true"
                                       OnClick="ClearForm">
                                Clear
                            </MudButton>
                        </MudItem>

                        <MudItem xs="6" sm="4">
                            <MudButton ButtonType="ButtonType.Button"
                                       Variant="Variant.Text"
                                       Color="Color.Secondary"
                                       FullWidth="true"
                                       OnClick="CloseAddPatientPanel">
                                Cancel
                            </MudButton>
                        </MudItem>
                    </MudGrid>
                </MudStack>
            </EditForm>

        </MudStack>
    </MudPaper>
</MudDrawer>

@code {
    // List of active patients shown on the page.
    private List<Patient> patients = new();

    // This model is used only for quick creation of a new patient.
    // Full editing happens later in PatientDetails.razor.
    private Patient newPatientModel = new();

    // Simple feedback message shown to the user.
    private string? statusMessage;

    // MudBlazor alert severity used by the status message area.
    private Severity statusSeverity = Severity.Info;

    // Controls whether the Add Patient bottom drawer is visible.
    private bool showAddPatientPanel;

    protected override async Task OnInitializedAsync()
    {
        /*
            Keep catalog seeding here.

            Even though this page no longer displays admission units,
            the app still needs the admission unit catalog elsewhere,
            especially in PatientDetails.razor.
        */
        await PatientService.SeedAdmissionUnitsIfEmptyAsync();

        // Load active patients.
        await LoadPatientsAsync();
    }

    private async Task LoadPatientsAsync()
    {
        // Read the current active patients from the database.
        patients = await PatientService.GetAllAsync();
    }

    private void OpenAddPatientPanel()
    {
        /*
            Start with a fresh model every time the panel opens.

            This prevents old typed values from appearing if the user
            opened the panel before and then cancelled.
        */
        newPatientModel = new Patient();

        // Show the Add Patient panel.
        showAddPatientPanel = true;
    }

    private void CloseAddPatientPanel()
    {
        // Hide the Add Patient panel.
        showAddPatientPanel = false;

        // Clear any typed values.
        ClearForm();
    }

    private void ClearForm()
    {
        // Start with a fresh empty model.
        newPatientModel = new Patient();
    }

    private void SetStatus(string message, Severity severity = Severity.Info)
    {
        statusMessage = message;
        statusSeverity = severity;
    }

    private async Task HandleValidSubmit()
    {
        /*
            Add a new patient using only the quick-entry fields
            that belong on this page.
        */
        await PatientService.AddAsync(newPatientModel);

        SetStatus("Patient added successfully.", Severity.Success);

        // Refresh the list so the new patient appears.
        await LoadPatientsAsync();

        // Close the panel after successful add.
        showAddPatientPanel = false;

        // Prepare a clean model for the next patient.
        ClearForm();
    }

    private async Task ArchivePatient(int id)
    {
        // Move the patient from active patients to archived patients.
        await PatientService.ArchiveAsync(id);

        // Refresh the list after archiving.
        await LoadPatientsAsync();

        SetStatus("Patient archived successfully.", Severity.Success);
    }
}
