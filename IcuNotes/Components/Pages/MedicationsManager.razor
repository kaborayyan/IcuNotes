@using IcuNotes.Models
@inject IcuNotes.Services.PatientService PatientService

@*
    This component manages the shared medication catalog.

    It is reused inside clinical sections such as Neurology, Cardiology,
    GastroIntestinal, and future sections.

    Important design choice:
    - This component does not use Bootstrap modals anymore.
    - It uses inline MudBlazor panels instead.
    - Inline panels are easier on mobile because the user stays inside the current section.
    - No JavaScript is needed.
*@

<MudPaper Elevation="0" Class="pa-3 rounded-lg">
    <MudStack Spacing="2">

        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2">
            <MudStack Spacing="0">
                <MudText Typo="Typo.subtitle2">Medication catalog</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Shared medication names and default frequencies.
                </MudText>
            </MudStack>

            <MudChip T="string"
                     Size="Size.Small"
                     Color="Color.Info"
                     Variant="Variant.Outlined">
                @Medications.Count
            </MudChip>
        </MudStack>

        @* Main actions. MudGrid keeps the two buttons equal on mobile. *@
        <MudGrid Spacing="2">
            <MudItem xs="6">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           FullWidth="true"
                           StartIcon="@Icons.Material.Filled.Add"
                           Disabled="@IsBusy"
                           OnClick="OpenAddMedicationPanel">
                    Add
                </MudButton>
            </MudItem>

            <MudItem xs="6">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Secondary"
                           FullWidth="true"
                           StartIcon="@Icons.Material.Filled.Edit"
                           Disabled="@IsBusy"
                           OnClick="OpenEditMedicationPanel">
                    Edit
                </MudButton>
            </MudItem>
        </MudGrid>

        @if (showAddMedicationPanel)
        {
            <MudPaper Elevation="1" Class="pa-3 rounded-lg">
                <MudStack Spacing="2">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.subtitle2">Add medication</MudText>

                        <MudIconButton Icon="@Icons.Material.Filled.Close"
                                       Size="Size.Small"
                                       Color="Color.Default"
                                       Disabled="@IsBusy"
                                       OnClick="CloseAddMedicationPanel"
                                       AriaLabel="Close add medication panel" />
                    </MudStack>

                    @* This warning shows validation or service errors inside the add panel. *@
                    @if (!string.IsNullOrWhiteSpace(newMedicationErrorMessage))
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true">
                            @newMedicationErrorMessage
                        </MudAlert>
                    }

                    <MudTextField @bind-Value="newMedicationName"
                                  Label="Medication name"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Immediate="true"
                                  Disabled="@IsBusy" />

                    <MudTextField @bind-Value="newMedicationFrequency"
                                  Label="Default frequency"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Immediate="true"
                                  Disabled="@IsBusy"
                                  HelperText="Examples: mcg/kg/min, BD, TID, q8h" />

                    <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="1">
                        <MudButton Variant="Variant.Text"
                                   Color="Color.Default"
                                   Disabled="@IsBusy"
                                   OnClick="CloseAddMedicationPanel">
                            Cancel
                        </MudButton>

                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Disabled="@IsBusy"
                                   OnClick="SaveNewMedicationAsync">
                            @if (isWorking)
                            {
                                <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="me-2" />
                            }
                            Save
                        </MudButton>
                    </MudStack>
                </MudStack>
            </MudPaper>
        }

        @if (showEditMedicationPanel)
        {
            <MudPaper Elevation="1" Class="pa-3 rounded-lg">
                <MudStack Spacing="2">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.subtitle2">Edit medication</MudText>

                        <MudIconButton Icon="@Icons.Material.Filled.Close"
                                       Size="Size.Small"
                                       Color="Color.Default"
                                       Disabled="@IsBusy"
                                       OnClick="CloseEditMedicationPanel"
                                       AriaLabel="Close edit medication panel" />
                    </MudStack>

                    @* This warning shows validation or service errors inside the edit panel. *@
                    @if (!string.IsNullOrWhiteSpace(editMedicationErrorMessage))
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true">
                            @editMedicationErrorMessage
                        </MudAlert>
                    }

                    @if (!Medications.Any())
                    {
                        <MudAlert Severity="Severity.Info" Dense="true" Variant="Variant.Outlined">
                            No medications in the catalog yet. Add one first.
                        </MudAlert>
                    }
                    else
                    {
                        <MudSelect T="int"
                                   @bind-Value="SelectedMedicationToEditId"
                                   Label="Select medication"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Disabled="@IsBusy">
                            @foreach (var medication in Medications)
                            {
                                <MudSelectItem T="int" Value="@medication.Id">
                                    @medication.Name
                                </MudSelectItem>
                            }
                        </MudSelect>

                        <MudTextField @bind-Value="editMedicationName"
                                      Label="Medication name"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Immediate="true"
                                      Disabled="@IsBusy" />

                        <MudTextField @bind-Value="editMedicationFrequency"
                                      Label="Default frequency"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Immediate="true"
                                      Disabled="@IsBusy"
                                      HelperText="Examples: mcg/kg/min, BD, TID, q8h" />

                        <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="1">
                            <MudButton Variant="Variant.Text"
                                       Color="Color.Default"
                                       Disabled="@IsBusy"
                                       OnClick="CloseEditMedicationPanel">
                                Cancel
                            </MudButton>

                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Disabled="@IsBusy"
                                       OnClick="SaveEditedMedicationAsync">
                                @if (isWorking)
                                {
                                    <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="me-2" />
                                }
                                Save
                            </MudButton>
                        </MudStack>
                    }
                </MudStack>
            </MudPaper>
        }
    </MudStack>
</MudPaper>

@code {
    // The parent passes the current shared medication list into this component.
    [Parameter, EditorRequired]
    public List<Medication> Medications { get; set; } = new();

    // The parent can disable this manager while another save operation is happening.
    [Parameter]
    public bool IsDisabled { get; set; }

    // This callback sends the refreshed medication catalog back to the parent.
    [Parameter, EditorRequired]
    public EventCallback<List<Medication>> OnMedicationsChanged { get; set; }

    // This optional callback lets the parent show a success message after catalog changes.
    [Parameter]
    public EventCallback<string> OnStatusMessage { get; set; }

    // These fields store the Add Medication panel state.
    private bool showAddMedicationPanel;
    private string newMedicationName = string.Empty;
    private string newMedicationFrequency = string.Empty;
    private string? newMedicationErrorMessage;

    // These fields store the Edit Medication panel state.
    private bool showEditMedicationPanel;
    private int selectedMedicationToEditId;
    private string editMedicationName = string.Empty;
    private string editMedicationFrequency = string.Empty;
    private string? editMedicationErrorMessage;

    // This property lets MudSelect use normal @bind-Value syntax.
    // When the selected medication changes, the edit fields are loaded automatically.
    private int SelectedMedicationToEditId
    {
        get => selectedMedicationToEditId;
        set
        {
            if (selectedMedicationToEditId == value)
                return;

            LoadMedicationForEdit(value);
        }
    }

    // This local flag prevents double-click saves inside the manager itself.
    private bool isWorking;

    // This combined flag is used by buttons and panel actions.
    private bool IsBusy => IsDisabled || isWorking;

    // This method opens the Add Medication panel and resets old errors and values.
    private void OpenAddMedicationPanel()
    {
        showEditMedicationPanel = false;
        newMedicationName = string.Empty;
        newMedicationFrequency = string.Empty;
        newMedicationErrorMessage = null;
        showAddMedicationPanel = true;
    }

    // This method closes the Add Medication panel and clears its old error message.
    private void CloseAddMedicationPanel()
    {
        showAddMedicationPanel = false;
        newMedicationErrorMessage = null;
    }

    // This method opens the Edit Medication panel and preloads one medication for editing.
    private void OpenEditMedicationPanel()
    {
        showAddMedicationPanel = false;
        editMedicationErrorMessage = null;
        showEditMedicationPanel = true;

        if (Medications.Any())
        {
            LoadMedicationForEdit(Medications.First().Id);
        }
        else
        {
            selectedMedicationToEditId = 0;
            editMedicationName = string.Empty;
            editMedicationFrequency = string.Empty;
        }
    }

    // This method closes the Edit Medication panel and clears its working values.
    private void CloseEditMedicationPanel()
    {
        showEditMedicationPanel = false;
        selectedMedicationToEditId = 0;
        editMedicationName = string.Empty;
        editMedicationFrequency = string.Empty;
        editMedicationErrorMessage = null;
    }

    // This helper copies the selected medication values into the edit fields.
    private void LoadMedicationForEdit(int medicationId)
    {
        selectedMedicationToEditId = medicationId;

        var selectedMedication = Medications.FirstOrDefault(x => x.Id == medicationId);

        if (selectedMedication is null)
        {
            editMedicationName = string.Empty;
            editMedicationFrequency = string.Empty;
            return;
        }

        editMedicationName = selectedMedication.Name;
        editMedicationFrequency = selectedMedication.Frequency ?? string.Empty;
    }

    // This method saves a new medication into the shared catalog and refreshes the list.
    private async Task SaveNewMedicationAsync()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(newMedicationName))
            {
                newMedicationErrorMessage = "Medication name is required.";
                return;
            }

            isWorking = true;

            await PatientService.AddMedicationIfMissingAsync(new Medication
            {
                Name = newMedicationName.Trim(),
                Frequency = string.IsNullOrWhiteSpace(newMedicationFrequency)
                    ? null
                    : newMedicationFrequency.Trim()
            });

            var refreshedMedications = await PatientService.GetMedicationsAsync();
            await OnMedicationsChanged.InvokeAsync(refreshedMedications);

            showAddMedicationPanel = false;
            newMedicationName = string.Empty;
            newMedicationFrequency = string.Empty;
            newMedicationErrorMessage = null;

            if (OnStatusMessage.HasDelegate)
            {
                await OnStatusMessage.InvokeAsync("Medication catalog updated successfully.");
            }
        }
        catch (Exception ex)
        {
            newMedicationErrorMessage = ex.Message;
        }
        finally
        {
            isWorking = false;
        }
    }

    // This method saves edits to one medication and refreshes the shared catalog list.
    private async Task SaveEditedMedicationAsync()
    {
        try
        {
            editMedicationErrorMessage = null;

            if (selectedMedicationToEditId <= 0)
            {
                editMedicationErrorMessage = "Please select a medication first.";
                return;
            }

            if (string.IsNullOrWhiteSpace(editMedicationName))
            {
                editMedicationErrorMessage = "Medication name is required.";
                return;
            }

            isWorking = true;

            await PatientService.UpdateMedicationAsync(new Medication
            {
                Id = selectedMedicationToEditId,
                Name = editMedicationName.Trim(),
                Frequency = string.IsNullOrWhiteSpace(editMedicationFrequency)
                    ? null
                    : editMedicationFrequency.Trim()
            });

            var refreshedMedications = await PatientService.GetMedicationsAsync();
            await OnMedicationsChanged.InvokeAsync(refreshedMedications);

            LoadMedicationForEdit(selectedMedicationToEditId);
            showEditMedicationPanel = false;
            editMedicationErrorMessage = null;

            if (OnStatusMessage.HasDelegate)
            {
                await OnStatusMessage.InvokeAsync("Medication catalog entry updated successfully.");
            }
        }
        catch (Exception ex)
        {
            editMedicationErrorMessage = ex.Message;
        }
        finally
        {
            isWorking = false;
        }
    }
}