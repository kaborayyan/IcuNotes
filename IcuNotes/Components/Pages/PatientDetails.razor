    private string? GetMedicationFrequency(int medicationId)
    {
        if (medicationId <= 0)
            return null;

        return medications
            .FirstOrDefault(x => x.Id == medicationId)
            ?.Frequency;
    }

    private void OpenAddMedicationModal()
    {
        showEditMedicationModal = false;
        newMedicationName = string.Empty;
        newMedicationFrequency = string.Empty;
        newMedicationErrorMessage = null;
        showAddMedicationModal = true;
    }

    private void CloseAddMedicationModal()
    {
        showAddMedicationModal = false;
        newMedicationErrorMessage = null;
    }

    private void OpenEditMedicationModal()
    {
        showAddMedicationModal = false;
        editMedicationErrorMessage = null;
        showEditMedicationModal = true;

        if (medications.Any())
        {
            // Preload the first medication so the modal opens in a usable state.
            LoadMedicationForEdit(medications.First().Id);
        }
        else
        {
            selectedMedicationToEditId = 0;
            editMedicationName = string.Empty;
            editMedicationFrequency = string.Empty;
        }
    }

    private void CloseEditMedicationModal()
    {
        showEditMedicationModal = false;
        selectedMedicationToEditId = 0;
        editMedicationName = string.Empty;
        editMedicationFrequency = string.Empty;
        editMedicationErrorMessage = null;
    }

    private void OnSelectedMedicationToEditChanged(ChangeEventArgs e)
    {
        if (e.Value is null)
            return;

        if (int.TryParse(e.Value.ToString(), out var medicationId))
        {
            LoadMedicationForEdit(medicationId);
        }
    }

    private void LoadMedicationForEdit(int medicationId)
    {
        selectedMedicationToEditId = medicationId;

        var selectedMedication = medications
            .FirstOrDefault(x => x.Id == medicationId);

        if (selectedMedication is null)
        {
            editMedicationName = string.Empty;
            editMedicationFrequency = string.Empty;
            return;
        }

        editMedicationName = selectedMedication.Name;
        editMedicationFrequency = selectedMedication.Frequency ?? string.Empty;
    }

    private async Task SaveNewMedicationAsync()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(newMedicationName))
            {
                newMedicationErrorMessage = "Medication name is required.";
                return;
            }

            isSaving = true;

            await PatientService.AddMedicationIfMissingAsync(new Medication
            {
                Name = newMedicationName.Trim(),
                Frequency = string.IsNullOrWhiteSpace(newMedicationFrequency)
                    ? null
                    : newMedicationFrequency.Trim()
            });

            medications = await PatientService.GetMedicationsAsync();

            showAddMedicationModal = false;
            newMedicationName = string.Empty;
            newMedicationFrequency = string.Empty;
            newMedicationErrorMessage = null;

            statusMessage = "Medication catalog updated successfully.";
            statusCssClass = "alert-success";
        }
        catch (Exception ex)
        {
            newMedicationErrorMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task SaveEditedMedicationAsync()
    {
        try
        {
            editMedicationErrorMessage = null;

            if (selectedMedicationToEditId <= 0)
            {
                editMedicationErrorMessage = "Please select a medication first.";
                return;
            }

            if (string.IsNullOrWhiteSpace(editMedicationName))
            {
                editMedicationErrorMessage = "Medication name is required.";
                return;
            }

            isSaving = true;

            await PatientService.UpdateMedicationAsync(new Medication
            {
                Id = selectedMedicationToEditId,
                Name = editMedicationName.Trim(),
                Frequency = string.IsNullOrWhiteSpace(editMedicationFrequency)
                    ? null
                    : editMedicationFrequency.Trim()
            });

            medications = await PatientService.GetMedicationsAsync();

            // Reload the current selection from the refreshed medication list.
            LoadMedicationForEdit(selectedMedicationToEditId);

            showEditMedicationModal = false;
            editMedicationErrorMessage = null;

            statusMessage = "Medication catalog entry updated successfully.";
            statusCssClass = "alert-success";
        }
        catch (Exception ex)
        {
            editMedicationErrorMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    // Return a friendly label for enum values using [Display(Name = "...")].
    private static string GetEnumDisplayName<TEnum>(TEnum value) where TEnum : struct, Enum
    {
        var memberInfo = typeof(TEnum).GetMember(value.ToString()).FirstOrDefault();

        if (memberInfo is null)
            return value.ToString();

        var displayAttribute = memberInfo
            .GetCustomAttributes(typeof(DisplayAttribute), false)
            .OfType<DisplayAttribute>()
            .FirstOrDefault();

        return displayAttribute?.Name ?? value.ToString();
    }

    private void DisposeEditContexts()
    {
        if (overviewEditContext is not null)
            overviewEditContext.OnFieldChanged -= HandleOverviewFieldChanged;

        if (summaryEditContext is not null)
            summaryEditContext.OnFieldChanged -= HandleSummaryFieldChanged;

        if (timelineEditContext is not null)
            timelineEditContext.OnFieldChanged -= HandleTimelineFieldChanged;

        if (neurologyEditContext is not null)
            neurologyEditContext.OnFieldChanged -= HandleNeurologyFieldChanged;
    }

    public void Dispose()
    {
        DisposeEditContexts();
    }

    private class TimelineEditorModel
    {
        public List<PatientDateEvent> Events { get; set; } = new();
    }
