@page "/patients/{id:int}"
@using IcuNotes.Models
@using Microsoft.AspNetCore.Components.Forms
@using MudBlazor
@inject IcuNotes.Services.PatientService PatientService
@implements IDisposable

<PageTitle>Patient Details</PageTitle>

@*
    This page is the coordinator for the patient details screen.

    It owns:
    - loading the patient
    - creating EditContext objects
    - tracking dirty states
    - saving and reloading sections

    The MudBlazor page shell has been moved into smaller UI components:
    - PatientDetailsHeader.razor
    - PatientDetailsActionBar.razor
*@

@if (isLoading)
{
    <MudContainer MaxWidth="MaxWidth.False"
                  Style="padding: 0.5rem 0.75rem 0;">
        <MudAlert Severity="Severity.Info"
                  Variant="Variant.Outlined"
                  Dense="true"
                  Icon="@Icons.Material.Filled.Info">
            Loading patient details...
        </MudAlert>
    </MudContainer>
}
else if (patient is null)
{
    <MudContainer MaxWidth="MaxWidth.False"
                  Style="padding: 0.5rem 0.75rem 0;">
        <MudStack Spacing="2">
            <MudAlert Severity="Severity.Warning"
                      Variant="Variant.Outlined"
                      Dense="true"
                      Icon="@Icons.Material.Filled.Warning">
                Patient not found.
            </MudAlert>

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Secondary"
                       Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.ArrowBack"
                       Href="/patients">
                Back to Patients
            </MudButton>
        </MudStack>
    </MudContainer>
}
else
{
    <MudContainer MaxWidth="MaxWidth.False"
                  Class="patient-details-page"
                  Style="padding: 0.5rem 0.75rem 0;">

        <PatientDetailsHeader PatientName="@patient.Name"
                              Bed="@patient.Bed"
                              ActiveSection="@activeTab"
                              IsOverviewDirty="@isOverviewDirty"
                              IsTimelineDirty="@isTimelineDirty"
                              IsSummaryDirty="@isSummaryDirty"
                              IsNeurologyDirty="@isNeurologyDirty"
                              IsCardiologyDirty="@isCardiologyDirty"
                              IsGastroIntestinalDirty="@isGastroIntestinalDirty"
                              OnSectionChanged="SelectTab" />

        @* Render Overview through its own child component.
           Overview also contains the timeline. *@
        @if (activeTab == "overview")
        {
            <OverviewSection Patient="patient"
                             AdmissionUnits="admissionUnits"
                             OrderedDateEvents="orderedDateEvents"
                             OverviewEditContext="overviewEditContext!"
                             TimelineEditContext="timelineEditContext!"
                             IsSaving="isSaving"
                             OnAddTimelineEvent="AddTimelineEventCallbackAsync"
                             OnRemoveTimelineEvent="RemoveTimelineEventCallbackAsync" />
        }
        @* Render Summary through its own child component.
           The parent page still owns save logic and dirty tracking. *@
        else if (activeTab == "summary")
        {
            <SummarySection Patient="patient"
                            SummaryEditContext="summaryEditContext!" />
        }
        @* Render Neurology through its own child component.
           The parent page still owns save logic and dirty tracking. *@
        else if (activeTab == "neurology")
        {
            <NeurologySection Patient="patient"
                              Medications="medications"
                              NeurologyEditContext="neurologyEditContext!"
                              IsSaving="isSaving"
                              OnAddNeurologyMedication="AddNeurologyMedication"
                              OnRemoveNeurologyMedication="RemoveNeurologyMedication"
                              OnMedicationsChanged="HandleMedicationsChangedAsync"
                              OnStatusMessage="HandleChildStatusMessageAsync" />
        }
        @* Render Cardiology through its own child component.
           The parent page owns save logic, dirty tracking, reload,
           and medication add/remove logic. *@
        else if (activeTab == "cardiology")
        {
            <CardiologySection Patient="patient"
                               Medications="medications"
                               CardiologyEditContext="cardiologyEditContext!"
                               IsSaving="isSaving"
                               OnAddCardiologyMedication="AddCardiologyMedication"
                               OnRemoveCardiologyMedication="RemoveCardiologyMedication"
                               OnMedicationsChanged="HandleMedicationsChangedAsync"
                               OnStatusMessage="HandleChildStatusMessageAsync" />
        }
        @* Render GIT through its own child component.
           The parent page still owns save logic, dirty tracking, reload,
           and formula / IV fluid / medication row add-remove logic. *@
        else if (activeTab == "gastrointestinal")
        {
            <GastroIntestinalSection Patient="patient"
                                     Medications="medications"
                                     GastroIntestinalEditContext="gastroIntestinalEditContext!"
                                     IsSaving="isSaving"
                                     OnAddGastroIntestinalItem="AddGastroIntestinalItem"
                                     OnRemoveGastroIntestinalItem="RemoveGastroIntestinalItem"
                                     OnMedicationsChanged="HandleMedicationsChangedAsync"
                                     OnStatusMessage="HandleChildStatusMessageAsync" />
        }
    </MudContainer>

    <PatientDetailsActionBar StatusText="@GetActiveSectionStatusText()"
                             StatusColor="@GetActiveSectionStatusColor()"
                             ActiveSectionName="@GetActiveSectionName()"
                             IsActiveSectionDirty="@IsActiveSectionDirty()"
                             IsSaving="@isSaving"
                             OnReload="ReloadPatientAsync"
                             OnSave="SaveActiveSectionAsync" />
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Patient? patient;
    private string? statusMessage;
    private Color statusColor = Color.Info;
    private bool isLoading = true;
    private bool isSaving = false;
    private string activeTab = "overview";

    private List<PatientDateEvent> orderedDateEvents = new();
    private List<AdmissionUnitCatalog> admissionUnits = new();
    private List<Medication> medications = new();

    // These flags are the source for the notification badges.
    // A dirty section means the user changed something but has not saved yet.
    private bool isOverviewDirty;
    private bool isSummaryDirty;
    private bool isTimelineDirty;
    private bool isNeurologyDirty;
    private bool isCardiologyDirty;
    private bool isGastroIntestinalDirty;

    // Separate EditContexts let us know which section changed.
    // Each section has its own EditContext so we can show the correct Unsaved badge.
    private EditContext? overviewEditContext;
    private EditContext? summaryEditContext;
    private EditContext? timelineEditContext;
    private EditContext? neurologyEditContext;
    private EditContext? cardiologyEditContext;
    private EditContext? gastroIntestinalEditContext;

    protected override async Task OnParametersSetAsync()
    {
        await LoadPatientAsync();
    }

    private async Task LoadPatientAsync()
    {
        isLoading = true;

        admissionUnits = await PatientService.GetAdmissionUnitsAsync();
        medications = await PatientService.GetMedicationsAsync();
        patient = await PatientService.GetByIdAsync(Id);

        if (patient is null)
        {
            statusMessage = "The requested patient was not found.";
            statusColor = Color.Warning;
            orderedDateEvents = new List<PatientDateEvent>();
        }
        else
        {
            EnsurePatientChildObjects();

            CreateEditContexts();
            ResetDirtyFlags();

            statusMessage = null;
            statusColor = Color.Info;
        }

        isLoading = false;
    }

    // Make sure all child objects exist before the page tries to bind to them.
    private void EnsurePatientChildObjects()
    {
        if (patient is null)
            return;

        EnsurePatientChildObjects(patient);

        orderedDateEvents = patient.PatientDateEvents
            .OrderBy(e => e.EventDate)
            .ToList();
    }

    // This helper can prepare any Patient object, not only the one currently displayed.
    // We use it when saving a clean database copy of the patient.
    private static void EnsurePatientChildObjects(Patient targetPatient)
    {
        targetPatient.PatientSummary ??= new PatientSummary
        {
            PatientId = targetPatient.Id
        };

        targetPatient.PatientDateEvents ??= new List<PatientDateEvent>();

        targetPatient.Neurology ??= new Neurology
        {
            PatientId = targetPatient.Id
        };

        targetPatient.Neurology.PatientId = targetPatient.Id;
        targetPatient.Neurology.Medications ??= new List<NeurologyMedication>();

        targetPatient.Cardiology ??= new Cardiology
        {
            PatientId = targetPatient.Id
        };

        targetPatient.Cardiology.PatientId = targetPatient.Id;
        targetPatient.Cardiology.Medications ??= new List<CardiologyMedication>();

        targetPatient.GastroIntestinal ??= new GastroIntestinal
        {
            PatientId = targetPatient.Id
        };

        targetPatient.GastroIntestinal.PatientId = targetPatient.Id;
        targetPatient.GastroIntestinal.Items ??= new List<GastroIntestinalItem>();
    }

    // Create one EditContext per section and subscribe to change tracking.
    private void CreateEditContexts()
    {
        if (patient is null)
            return;

        DisposeEditContexts();

        overviewEditContext = new EditContext(patient);
        overviewEditContext.OnFieldChanged += HandleOverviewFieldChanged;

        summaryEditContext = new EditContext(patient.PatientSummary!);
        summaryEditContext.OnFieldChanged += HandleSummaryFieldChanged;

        timelineEditContext = new EditContext(new TimelineEditorModel
        {
            Events = orderedDateEvents
        });
        timelineEditContext.OnFieldChanged += HandleTimelineFieldChanged;

        neurologyEditContext = new EditContext(patient.Neurology!);
        neurologyEditContext.OnFieldChanged += HandleNeurologyFieldChanged;

        cardiologyEditContext = new EditContext(patient.Cardiology!);
        cardiologyEditContext.OnFieldChanged += HandleCardiologyFieldChanged;

        gastroIntestinalEditContext = new EditContext(patient.GastroIntestinal!);
        gastroIntestinalEditContext.OnFieldChanged += HandleGastroIntestinalFieldChanged;
    }

    private void HandleOverviewFieldChanged(object? sender, FieldChangedEventArgs e)
    {
        isOverviewDirty = true;
        InvokeAsync(StateHasChanged);
    }

    private void HandleSummaryFieldChanged(object? sender, FieldChangedEventArgs e)
    {
        isSummaryDirty = true;
        InvokeAsync(StateHasChanged);
    }

    private void HandleTimelineFieldChanged(object? sender, FieldChangedEventArgs e)
    {
        isTimelineDirty = true;
        InvokeAsync(StateHasChanged);
    }

    private void HandleNeurologyFieldChanged(object? sender, FieldChangedEventArgs e)
    {
        isNeurologyDirty = true;
        InvokeAsync(StateHasChanged);
    }

    private void HandleCardiologyFieldChanged(object? sender, FieldChangedEventArgs e)
    {
        isCardiologyDirty = true;
        InvokeAsync(StateHasChanged);
    }

    private void HandleGastroIntestinalFieldChanged(object? sender, FieldChangedEventArgs e)
    {
        isGastroIntestinalDirty = true;
        InvokeAsync(StateHasChanged);
    }

    private void ResetDirtyFlags()
    {
        isOverviewDirty = false;
        isSummaryDirty = false;
        isTimelineDirty = false;
        isNeurologyDirty = false;
        isCardiologyDirty = false;
        isGastroIntestinalDirty = false;
    }

    // Every section save uses a fresh database copy.
    // This prevents an unsaved change in another section from being saved accidentally.
    private async Task<Patient> GetCleanPatientForSaveAsync()
    {
        var patientToSave = await PatientService.GetByIdAsync(Id);

        if (patientToSave is null)
            throw new InvalidOperationException("The patient could not be found in the database.");

        EnsurePatientChildObjects(patientToSave);

        return patientToSave;
    }

    // Copy only the small Overview fields.
    // Do not copy Summary, Neurology, Cardiology, GIT, or Timeline here.
    private static void CopyOverviewFields(Patient sourcePatient, Patient targetPatient)
    {
        targetPatient.Name = sourcePatient.Name;
        targetPatient.Bed = sourcePatient.Bed;
        targetPatient.Age = sourcePatient.Age;
        targetPatient.Weight = sourcePatient.Weight;
        targetPatient.Diagnosis = sourcePatient.Diagnosis;
        targetPatient.AdmissionUnitCatalogId = sourcePatient.AdmissionUnitCatalogId;
    }

    private static void CopySummarySection(Patient sourcePatient, Patient targetPatient)
    {
        if (sourcePatient.PatientSummary is null)
            return;

        targetPatient.PatientSummary ??= new PatientSummary
        {
            PatientId = targetPatient.Id
        };

        targetPatient.PatientSummary.PatientId = targetPatient.Id;
        targetPatient.PatientSummary.CombinedHistory = sourcePatient.PatientSummary.CombinedHistory;
        targetPatient.PatientSummary.EventsTodo = sourcePatient.PatientSummary.EventsTodo;
    }

    private static void CopyTimelineSection(IEnumerable<PatientDateEvent> sourceEvents, Patient targetPatient)
    {
        targetPatient.PatientDateEvents = sourceEvents
            .Select(item => new PatientDateEvent
            {
                Id = item.Id,
                PatientId = targetPatient.Id,
                EventDate = item.EventDate,
                Title = item.Title
            })
            .OrderBy(item => item.EventDate)
            .ToList();
    }

    private static void CopyNeurologySection(Patient sourcePatient, Patient targetPatient)
    {
        if (sourcePatient.Neurology is null)
            return;

        targetPatient.Neurology ??= new Neurology
        {
            PatientId = targetPatient.Id
        };

        targetPatient.Neurology.PatientId = targetPatient.Id;
        targetPatient.Neurology.GcsEye = sourcePatient.Neurology.GcsEye;
        targetPatient.Neurology.GcsVerbal = sourcePatient.Neurology.GcsVerbal;
        targetPatient.Neurology.GcsMotor = sourcePatient.Neurology.GcsMotor;
        targetPatient.Neurology.Pupils = sourcePatient.Neurology.Pupils;
        targetPatient.Neurology.MotorStatus = sourcePatient.Neurology.MotorStatus;

        targetPatient.Neurology.Medications = sourcePatient.Neurology.Medications
            .Select(item => new NeurologyMedication
            {
                Id = item.Id,
                Category = item.Category,
                MedicationId = item.MedicationId,
                Dose = item.Dose
            })
            .ToList();
    }

    private static void CopyCardiologySection(Patient sourcePatient, Patient targetPatient)
    {
        if (sourcePatient.Cardiology is null)
            return;

        targetPatient.Cardiology ??= new Cardiology
        {
            PatientId = targetPatient.Id
        };

        targetPatient.Cardiology.PatientId = targetPatient.Id;
        targetPatient.Cardiology.HeartRate = sourcePatient.Cardiology.HeartRate;
        targetPatient.Cardiology.SystolicBloodPressure = sourcePatient.Cardiology.SystolicBloodPressure;
        targetPatient.Cardiology.DiastolicBloodPressure = sourcePatient.Cardiology.DiastolicBloodPressure;
        targetPatient.Cardiology.CentralVenousPressure = sourcePatient.Cardiology.CentralVenousPressure;
        targetPatient.Cardiology.InferiorVenaCava = sourcePatient.Cardiology.InferiorVenaCava;
        targetPatient.Cardiology.CardiacIndex = sourcePatient.Cardiology.CardiacIndex;
        targetPatient.Cardiology.CardiacOutput = sourcePatient.Cardiology.CardiacOutput;
        targetPatient.Cardiology.SystemicVascularResistance = sourcePatient.Cardiology.SystemicVascularResistance;
        targetPatient.Cardiology.PulmonaryCapillaryWedgePressure = sourcePatient.Cardiology.PulmonaryCapillaryWedgePressure;
        targetPatient.Cardiology.Notes = sourcePatient.Cardiology.Notes;

        targetPatient.Cardiology.Medications = sourcePatient.Cardiology.Medications
            .Select(item => new CardiologyMedication
            {
                Id = item.Id,
                Category = item.Category,
                MedicationId = item.MedicationId,
                Dose = item.Dose
            })
            .ToList();
    }

    private static void CopyGastroIntestinalSection(Patient sourcePatient, Patient targetPatient)
    {
        if (sourcePatient.GastroIntestinal is null)
            return;

        targetPatient.GastroIntestinal ??= new GastroIntestinal
        {
            PatientId = targetPatient.Id
        };

        targetPatient.GastroIntestinal.PatientId = targetPatient.Id;
        targetPatient.GastroIntestinal.FeedingRoute = sourcePatient.GastroIntestinal.FeedingRoute;
        targetPatient.GastroIntestinal.LastBowelMotionDate = sourcePatient.GastroIntestinal.LastBowelMotionDate;
        targetPatient.GastroIntestinal.IntraAbdominalPressure = sourcePatient.GastroIntestinal.IntraAbdominalPressure;
        targetPatient.GastroIntestinal.AbdominalGirth = sourcePatient.GastroIntestinal.AbdominalGirth;
        targetPatient.GastroIntestinal.HasGiBleeding = sourcePatient.GastroIntestinal.HasGiBleeding;
        targetPatient.GastroIntestinal.GitNotes = sourcePatient.GastroIntestinal.GitNotes;

        targetPatient.GastroIntestinal.Items = sourcePatient.GastroIntestinal.Items
            .Select(item => new GastroIntestinalItem
            {
                Id = item.Id,
                Category = item.Category,
                MedicationId = item.MedicationId,
                DoseOrRate = item.DoseOrRate
            })
            .ToList();
    }

    private async Task<Patient?> GetSavedPatientFromDatabaseAsync()
    {
        var savedPatient = await PatientService.GetByIdAsync(Id);

        if (savedPatient is not null)
            EnsurePatientChildObjects(savedPatient);

        return savedPatient;
    }

    private async Task RefreshOverviewFieldsFromDatabaseAsync()
    {
        if (patient is null)
            return;

        var savedPatient = await GetSavedPatientFromDatabaseAsync();

        if (savedPatient is null)
            return;

        CopyOverviewFields(savedPatient, patient);
        CreateEditContexts();
    }

    private async Task RefreshSummaryFromDatabaseAsync()
    {
        if (patient is null)
            return;

        var savedPatient = await GetSavedPatientFromDatabaseAsync();

        if (savedPatient is null)
            return;

        CopySummarySection(savedPatient, patient);
        CreateEditContexts();
    }

    private async Task RefreshTimelineFromDatabaseAsync()
    {
        if (patient is null)
            return;

        var savedPatient = await GetSavedPatientFromDatabaseAsync();

        if (savedPatient is null)
            return;

        CopyTimelineSection(savedPatient.PatientDateEvents, patient);

        orderedDateEvents = patient.PatientDateEvents
            .OrderBy(item => item.EventDate)
            .ToList();

        CreateEditContexts();
    }

    private async Task RefreshNeurologyFromDatabaseAsync()
    {
        if (patient is null)
            return;

        var savedPatient = await GetSavedPatientFromDatabaseAsync();

        if (savedPatient is null)
            return;

        CopyNeurologySection(savedPatient, patient);
        CreateEditContexts();
    }

    private async Task RefreshCardiologyFromDatabaseAsync()
    {
        if (patient is null)
            return;

        var savedPatient = await GetSavedPatientFromDatabaseAsync();

        if (savedPatient is null)
            return;

        CopyCardiologySection(savedPatient, patient);
        CreateEditContexts();
    }

    private async Task RefreshGastroIntestinalFromDatabaseAsync()
    {
        if (patient is null)
            return;

        var savedPatient = await GetSavedPatientFromDatabaseAsync();

        if (savedPatient is null)
            return;

        CopyGastroIntestinalSection(savedPatient, patient);
        CreateEditContexts();
    }

    private async Task SaveOverviewAsync()
    {
        if (patient is null)
            return;

        try
        {
            isSaving = true;

            var patientToSave = await GetCleanPatientForSaveAsync();

            CopyOverviewFields(patient, patientToSave);

            await PatientService.UpdateAsync(patientToSave);
            await RefreshOverviewFieldsFromDatabaseAsync();

            isOverviewDirty = false;

            statusMessage = "Overview saved successfully.";
            statusColor = Color.Success;
        }
        catch (Exception ex)
        {
            statusMessage = $"Error while saving Overview: {ex.Message}";
            statusColor = Color.Error;
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task SaveSummaryAsync()
    {
        if (patient is null)
            return;

        try
        {
            isSaving = true;

            var patientToSave = await GetCleanPatientForSaveAsync();

            CopySummarySection(patient, patientToSave);

            await PatientService.UpdateAsync(patientToSave);
            await RefreshSummaryFromDatabaseAsync();

            isSummaryDirty = false;

            statusMessage = "Summary saved successfully.";
            statusColor = Color.Success;
        }
        catch (Exception ex)
        {
            statusMessage = $"Error while saving Summary: {ex.Message}";
            statusColor = Color.Error;
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task SaveTimelineAsync()
    {
        if (patient is null)
            return;

        try
        {
            isSaving = true;

            var patientToSave = await GetCleanPatientForSaveAsync();

            CopyTimelineSection(orderedDateEvents, patientToSave);

            await PatientService.UpdateAsync(patientToSave);
            await RefreshTimelineFromDatabaseAsync();

            isTimelineDirty = false;

            statusMessage = "Timeline saved successfully.";
            statusColor = Color.Success;
        }
        catch (Exception ex)
        {
            statusMessage = $"Error while saving Timeline: {ex.Message}";
            statusColor = Color.Error;
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task SaveNeurologyAsync()
    {
        if (patient is null)
            return;

        try
        {
            isSaving = true;

            // Make sure the neurology section exists and is linked to this patient.
            patient.Neurology ??= new Neurology
            {
                PatientId = patient.Id
            };

            patient.Neurology.PatientId = patient.Id;
            patient.Neurology.Medications ??= new List<NeurologyMedication>();

            var patientToSave = await GetCleanPatientForSaveAsync();

            CopyNeurologySection(patient, patientToSave);

            await PatientService.UpdateAsync(patientToSave);
            await RefreshNeurologyFromDatabaseAsync();

            isNeurologyDirty = false;

            statusMessage = "Neurology saved successfully.";
            statusColor = Color.Success;
        }
        catch (Exception ex)
        {
            statusMessage = $"Error while saving Neurology: {ex.Message}";
            statusColor = Color.Error;
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task SaveCardiologyAsync()
    {
        if (patient is null)
            return;

        try
        {
            isSaving = true;

            // Make sure the cardiology section exists and is linked to this patient.
            patient.Cardiology ??= new Cardiology
            {
                PatientId = patient.Id
            };

            patient.Cardiology.PatientId = patient.Id;
            patient.Cardiology.Medications ??= new List<CardiologyMedication>();

            var patientToSave = await GetCleanPatientForSaveAsync();

            CopyCardiologySection(patient, patientToSave);

            await PatientService.UpdateAsync(patientToSave);
            await RefreshCardiologyFromDatabaseAsync();

            isCardiologyDirty = false;

            statusMessage = "Cardiology saved successfully.";
            statusColor = Color.Success;
        }
        catch (Exception ex)
        {
            statusMessage = $"Error while saving Cardiology: {ex.Message}";
            statusColor = Color.Error;
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task SaveGastroIntestinalAsync()
    {
        if (patient is null)
            return;

        try
        {
            isSaving = true;

            // Make sure the GIT section exists and is linked to this patient.
            patient.GastroIntestinal ??= new GastroIntestinal
            {
                PatientId = patient.Id
            };

            patient.GastroIntestinal.PatientId = patient.Id;
            patient.GastroIntestinal.Items ??= new List<GastroIntestinalItem>();

            var patientToSave = await GetCleanPatientForSaveAsync();

            CopyGastroIntestinalSection(patient, patientToSave);

            await PatientService.UpdateAsync(patientToSave);
            await RefreshGastroIntestinalFromDatabaseAsync();

            isGastroIntestinalDirty = false;

            statusMessage = "GIT saved successfully.";
            statusColor = Color.Success;
        }
        catch (Exception ex)
        {
            statusMessage = $"Error while saving GIT: {ex.Message}";
            statusColor = Color.Error;
        }
        finally
        {
            isSaving = false;
        }
    }

    // This small wrapper lets the child Overview component ask the parent page
    // to add a new timeline row while keeping the actual logic in this file.
    private Task AddTimelineEventCallbackAsync()
    {
        AddTimelineEvent();
        return Task.CompletedTask;
    }

    // This small wrapper lets the child Overview component ask the parent page
    // to remove one timeline row while keeping the actual logic in this file.
    private Task RemoveTimelineEventCallbackAsync(PatientDateEvent item)
    {
        RemoveTimelineEvent(item);
        return Task.CompletedTask;
    }

    // This method adds a new timeline row to the in-memory list before saving it to the database.
    private void AddTimelineEvent()
    {
        if (patient is null)
            return;

        var newEvent = new PatientDateEvent
        {
            PatientId = patient.Id,
            EventDate = DateTime.Today
        };

        orderedDateEvents.Add(newEvent);
        orderedDateEvents = orderedDateEvents
            .OrderBy(e => e.EventDate)
            .ToList();

        CreateEditContexts();
        isTimelineDirty = true;
    }

    // This method removes one timeline row from the in-memory list before the next save.
    private void RemoveTimelineEvent(PatientDateEvent item)
    {
        orderedDateEvents.Remove(item);
        orderedDateEvents = orderedDateEvents
            .OrderBy(e => e.EventDate)
            .ToList();

        CreateEditContexts();
        isTimelineDirty = true;
    }

    private void AddNeurologyMedication(NeurologyMedicationCategory category)
    {
        if (patient?.Neurology is null)
            return;

        patient.Neurology.Medications.Add(new NeurologyMedication
        {
            Category = category
        });

        CreateEditContexts();
        isNeurologyDirty = true;
    }

    private void RemoveNeurologyMedication(NeurologyMedication item)
    {
        if (patient?.Neurology is null)
            return;

        patient.Neurology.Medications.Remove(item);

        CreateEditContexts();
        isNeurologyDirty = true;
    }

    private void AddCardiologyMedication(CardiologyMedicationCategory category)
    {
        if (patient is null)
            return;

        patient.Cardiology ??= new Cardiology
        {
            PatientId = patient.Id
        };

        patient.Cardiology.Medications ??= new List<CardiologyMedication>();

        patient.Cardiology.Medications.Add(new CardiologyMedication
        {
            Category = category
        });

        CreateEditContexts();
        isCardiologyDirty = true;
    }

    private void RemoveCardiologyMedication(CardiologyMedication item)
    {
        if (patient?.Cardiology is null)
            return;

        patient.Cardiology.Medications.Remove(item);

        CreateEditContexts();
        isCardiologyDirty = true;
    }

    private void AddGastroIntestinalItem(GastroIntestinalItemCategory category)
    {
        if (patient is null)
            return;

        patient.GastroIntestinal ??= new GastroIntestinal
        {
            PatientId = patient.Id
        };

        patient.GastroIntestinal.Items ??= new List<GastroIntestinalItem>();

        patient.GastroIntestinal.Items.Add(new GastroIntestinalItem
        {
            Category = category
        });

        CreateEditContexts();
        isGastroIntestinalDirty = true;
    }

    private void RemoveGastroIntestinalItem(GastroIntestinalItem item)
    {
        if (patient?.GastroIntestinal is null)
            return;

        patient.GastroIntestinal.Items.Remove(item);

        CreateEditContexts();
        isGastroIntestinalDirty = true;
    }

    // This method lets the shared MedicationsManager replace the parent page medication list
    // after adding or editing a catalog item.
    private Task HandleMedicationsChangedAsync(List<Medication> refreshedMedications)
    {
        medications = refreshedMedications ?? new List<Medication>();
        return Task.CompletedTask;
    }

    // This method lets child components show a success message through the parent page alert area.
    private Task HandleChildStatusMessageAsync(string message)
    {
        statusMessage = message;
        statusColor = Color.Success;
        return Task.CompletedTask;
    }

    private async Task ReloadPatientAsync()
    {
        if (patient is null || isSaving)
            return;

        try
        {
            isSaving = true;

            var savedPatient = await GetSavedPatientFromDatabaseAsync();

            if (savedPatient is null)
            {
                statusMessage = "The patient could not be found in the database.";
                statusColor = Color.Warning;
                return;
            }

            switch (activeTab)
            {
                case "overview":
                    // The Overview tab contains both overview fields and timeline rows.
                    // Reloading here discards unsaved changes in both of them only.
                    CopyOverviewFields(savedPatient, patient);
                    CopyTimelineSection(savedPatient.PatientDateEvents, patient);

                    orderedDateEvents = patient.PatientDateEvents
                        .OrderBy(item => item.EventDate)
                        .ToList();

                    isOverviewDirty = false;
                    isTimelineDirty = false;
                    break;

                case "summary":
                    CopySummarySection(savedPatient, patient);
                    isSummaryDirty = false;
                    break;

                case "neurology":
                    CopyNeurologySection(savedPatient, patient);
                    isNeurologyDirty = false;
                    break;

                case "cardiology":
                    CopyCardiologySection(savedPatient, patient);
                    isCardiologyDirty = false;
                    break;

                case "gastrointestinal":
                    CopyGastroIntestinalSection(savedPatient, patient);
                    isGastroIntestinalDirty = false;
                    break;
            }

            CreateEditContexts();

            statusMessage = $"{GetActiveSectionName()} changes reloaded.";
            statusColor = Color.Info;
        }
        catch (Exception ex)
        {
            statusMessage = $"Error while reloading {GetActiveSectionName()}: {ex.Message}";
            statusColor = Color.Error;
        }
        finally
        {
            isSaving = false;
        }
    }
    private void SelectTab(string tabName)
    {
        activeTab = tabName;

        // A save/reload message belongs to the section where it happened.
        // When the user moves to another tab, clear the old message
        // so the bottom bar can show the new section status.
        statusMessage = null;
        statusColor = Color.Info;
    }
    // The bottom bar uses this helper to show a friendly section name.
    private string GetActiveSectionName()
    {
        return activeTab switch
        {
            "overview" => "Overview",
            "summary" => "Summary",
            "neurology" => "Neurology",
            "cardiology" => "Cardiology",
            "gastrointestinal" => "GIT",
            _ => "Section"
        };
    }

    // This helper tells the bottom bar if the currently opened section has unsaved changes.
    private bool IsActiveSectionDirty()
    {
        return activeTab switch
        {
            // Overview includes both the patient overview fields and the timeline.
            // So the Overview tab is dirty if either part has unsaved changes.
            "overview" => isOverviewDirty || isTimelineDirty,
            "summary" => isSummaryDirty,
            "neurology" => isNeurologyDirty,
            "cardiology" => isCardiologyDirty,
            "gastrointestinal" => isGastroIntestinalDirty,
            _ => false
        };
    }

    // This helper gives the bottom bar a simple readable status message.
    private string GetActiveSectionStatusText()
    {
        // Dirty status is more important than an old success message.
        // Example: after editing Summary again, show "Summary has unsaved changes"
        // instead of keeping the previous "Summary saved successfully" message.
        if (activeTab == "overview")
        {
            if (isOverviewDirty && isTimelineDirty)
                return "Overview and timeline have unsaved changes.";

            if (isOverviewDirty)
                return "Overview has unsaved changes.";

            if (isTimelineDirty)
                return "Timeline has unsaved changes.";
        }
        else if (IsActiveSectionDirty())
        {
            return $"{GetActiveSectionName()} has unsaved changes.";
        }

        // If there is a recent save/reload/catalog message, show it here.
        if (!string.IsNullOrWhiteSpace(statusMessage))
            return statusMessage;

        return $"{GetActiveSectionName()} has loaded.";
    }
    // This helper gives the MudBlazor action bar the correct Material color.
    private Color GetActiveSectionStatusColor()
    {
        if (IsActiveSectionDirty())
            return Color.Warning;

        if (string.IsNullOrWhiteSpace(statusMessage))
            return Color.Secondary;

        return statusColor;
    }

    // This method is called by the fixed bottom Save button.
    // It saves only the currently active section.
    private async Task SaveActiveSectionAsync()
    {
        if (patient is null || isSaving || !IsActiveSectionDirty())
            return;

        switch (activeTab)
        {
            case "overview":
                // The Overview tab contains two saveable parts:
                // 1. Overview fields such as diagnosis/admission unit.
                // 2. Timeline rows.
                // If both are dirty, save the overview fields first, then the timeline.
                var overviewWasDirty = isOverviewDirty;
                var timelineWasDirty = isTimelineDirty;

                if (isOverviewDirty)
                {
                    await SaveOverviewAsync();

                    // If the overview save failed, the dirty flag stays true.
                    // In that case, stop here so the user sees the error clearly.
                    if (isOverviewDirty)
                        return;
                }

                if (isTimelineDirty)
                {
                    await SaveTimelineAsync();
                }

                if (overviewWasDirty && timelineWasDirty && !isOverviewDirty && !isTimelineDirty)
                {
                    statusMessage = "Overview and timeline saved successfully.";
                    statusColor = Color.Success;
                }

                break;

            case "summary":
                await SaveSummaryAsync();
                break;

            case "neurology":
                await SaveNeurologyAsync();
                break;

            case "cardiology":
                await SaveCardiologyAsync();
                break;

            case "gastrointestinal":
                await SaveGastroIntestinalAsync();
                break;
        }
    }

    private void DisposeEditContexts()
    {
        if (overviewEditContext is not null)
            overviewEditContext.OnFieldChanged -= HandleOverviewFieldChanged;

        if (summaryEditContext is not null)
            summaryEditContext.OnFieldChanged -= HandleSummaryFieldChanged;

        if (timelineEditContext is not null)
            timelineEditContext.OnFieldChanged -= HandleTimelineFieldChanged;

        if (neurologyEditContext is not null)
            neurologyEditContext.OnFieldChanged -= HandleNeurologyFieldChanged;

        if (cardiologyEditContext is not null)
            cardiologyEditContext.OnFieldChanged -= HandleCardiologyFieldChanged;

        if (gastroIntestinalEditContext is not null)
            gastroIntestinalEditContext.OnFieldChanged -= HandleGastroIntestinalFieldChanged;
    }

    public void Dispose()
    {
        DisposeEditContexts();
    }

    private class TimelineEditorModel
    {
        public List<PatientDateEvent> Events { get; set; } = new();
    }
