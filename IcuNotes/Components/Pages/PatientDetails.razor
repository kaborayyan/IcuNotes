@page "/patients/{id:int}"
@using System.ComponentModel.DataAnnotations
@using IcuNotes.Models
@using IcuNotes.Constants
@using Microsoft.AspNetCore.Components.Forms
@inject IcuNotes.Services.PatientService PatientService
@implements IDisposable

<PageTitle>Patient Details</PageTitle>

<h3 class="mb-4">Patient Details</h3>

@if (!string.IsNullOrWhiteSpace(statusMessage))
{
    <div class="alert @statusCssClass">
        @statusMessage
    </div>
}

@if (isLoading)
{
    <p>Loading patient details...</p>
}
else if (patient is null)
{
    <div class="alert alert-warning">
        Patient not found.
    </div>

    <a href="/patients" class="btn btn-secondary">Back to Patients</a>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body">

            <div class="mb-4">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-start gap-3">
                    <div>
                        <h4 class="card-title mb-1">@patient.Name</h4>

                        <div class="text-muted">
                            Patient ID: @patient.Id
                        </div>
                    </div>

                    <div class="text-md-end">
                        <div>
                            <span class="fw-bold">Bed:</span> @patient.Bed
                        </div>

                        <div>
                            <span class="fw-bold">Diagnosis:</span>
                            @if (!string.IsNullOrWhiteSpace(patient.Diagnosis))
                            {
                                @patient.Diagnosis
                            }
                            else
                            {
                                <span class="text-muted">Not added</span>
                            }
                        </div>

                        <div>
                            <span class="fw-bold">Admission Unit:</span>
                            @if (!string.IsNullOrWhiteSpace(GetSelectedAdmissionUnitName()))
                            {
                                @GetSelectedAdmissionUnitName()
                            }
                            else
                            {
                                <span class="text-muted">Not added</span>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="mb-4">
                <div class="d-flex flex-wrap gap-2">
                    <button class="@GetTabButtonClass("overview")"
                            @onclick='() => SelectTab("overview")'>
                        Overview
                        @if (isOverviewDirty)
                        {
                            <span class="badge bg-warning text-dark ms-2">Unsaved</span>
                        }
                    </button>

                    <button class="@GetTabButtonClass("summary")"
                            @onclick='() => SelectTab("summary")'>
                        Summary
                        @if (isSummaryDirty)
                        {
                            <span class="badge bg-warning text-dark ms-2">Unsaved</span>
                        }
                    </button>

                    <button class="@GetTabButtonClass("timeline")"
                            @onclick='() => SelectTab("timeline")'>
                        Timeline
                        @if (isTimelineDirty)
                        {
                            <span class="badge bg-warning text-dark ms-2">Unsaved</span>
                        }
                    </button>

                    <button class="@GetTabButtonClass("neurology")"
                            @onclick='() => SelectTab("neurology")'>
                        Neurology
                        @if (isNeurologyDirty)
                        {
                            <span class="badge bg-warning text-dark ms-2">Unsaved</span>
                        }
                    </button>
                </div>
            </div>

            @if (activeTab == "overview")
            {
                <div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="mb-0">Overview</h5>

                        @if (isOverviewDirty)
                        {
                            <span class="text-warning fw-semibold">You have unsaved overview changes.</span>
                        }
                        else
                        {
                            <span class="text-muted">Overview is saved.</span>
                        }
                    </div>

                    <EditForm EditContext="overviewEditContext" OnValidSubmit="SaveOverviewAsync">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Name</label>
                                <InputText class="form-control"
                                           @bind-Value="patient.Name" />
                                <ValidationMessage For="@(() => patient.Name)" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Bed</label>
                                <InputSelect class="form-select"
                                             @bind-Value="patient.Bed">
                                    <option value="">-- Select Bed --</option>

                                    @foreach (var bed in BedOptions.All)
                                    {
                                        <option value="@bed">@bed</option>
                                    }
                                </InputSelect>
                                <ValidationMessage For="@(() => patient.Bed)" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Age</label>
                                <InputNumber class="form-control"
                                             @bind-Value="patient.Age" />
                                <ValidationMessage For="@(() => patient.Age)" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Weight</label>
                                <InputNumber class="form-control"
                                             @bind-Value="patient.Weight" />
                                <ValidationMessage For="@(() => patient.Weight)" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Diagnosis</label>
                            <InputText class="form-control"
                                       @bind-Value="patient.Diagnosis" />
                            <ValidationMessage For="@(() => patient.Diagnosis)" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Admission Unit</label>
                            <InputSelect class="form-select"
                                         @bind-Value="patient.AdmissionUnitCatalogId">
                                <option value="">-- Select Admission Unit --</option>

                                @foreach (var unit in admissionUnits)
                                {
                                    <option value="@unit.Id">@unit.Name</option>
                                }
                            </InputSelect>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit"
                                    class="btn btn-primary"
                                    disabled="@isSaving">
                                @(isSaving ? "Saving..." : "Save Overview Changes")
                            </button>

                            <button type="button"
                                    class="btn btn-secondary"
                                    @onclick="ReloadPatientAsync"
                                    disabled="@isSaving">
                                Reload
                            </button>
                        </div>
                    </EditForm>
                </div>
            }
            else if (activeTab == "summary")
            {
                <div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="mb-0">Patient Summary</h5>

                        @if (isSummaryDirty)
                        {
                            <span class="text-warning fw-semibold">You have unsaved summary changes.</span>
                        }
                        else
                        {
                            <span class="text-muted">Summary is saved.</span>
                        }
                    </div>

                    <EditForm EditContext="summaryEditContext" OnValidSubmit="SaveSummaryAsync">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-3">
                            <label class="form-label">Combined History</label>
                            <InputTextArea class="form-control"
                                           rows="6"
                                           @bind-Value="patient.PatientSummary!.CombinedHistory" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">To Do</label>
                            <InputTextArea class="form-control"
                                           rows="5"
                                           @bind-Value="patient.PatientSummary!.EventsTodo" />
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit"
                                    class="btn btn-primary"
                                    disabled="@isSaving">
                                @(isSaving ? "Saving..." : "Save Summary Changes")
                            </button>

                            <button type="button"
                                    class="btn btn-secondary"
                                    @onclick="ReloadPatientAsync"
                                    disabled="@isSaving">
                                Reload
                            </button>
                        </div>
                    </EditForm>
                </div>
            }
            else if (activeTab == "timeline")
            {
                <div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="mb-0">Timeline</h5>

                        @if (isTimelineDirty)
                        {
                            <span class="text-warning fw-semibold">You have unsaved timeline changes.</span>
                        }
                        else
                        {
                            <span class="text-muted">Timeline is saved.</span>
                        }
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div></div>

                        <button type="button"
                                class="btn btn-outline-primary"
                                @onclick="AddTimelineEvent"
                                disabled="@isSaving">
                            Add Timeline Event
                        </button>
                    </div>

                    @if (orderedDateEvents.Any())
                    {
                        <EditForm EditContext="timelineEditContext" OnValidSubmit="SaveTimelineAsync">
                            <DataAnnotationsValidator />
                            <ValidationSummary />

                            @foreach (var item in orderedDateEvents)
                            {
                                <div class="border rounded p-3 mb-3">
                                    <div class="row">
                                        <div class="col-md-4 mb-3">
                                            <label class="form-label">Event Date</label>
                                            <InputDate class="form-control"
                                                       @bind-Value="item.EventDate" />
                                        </div>

                                        <div class="col-md-8 mb-3">
                                            <label class="form-label">Title</label>
                                            <InputText class="form-control"
                                                       @bind-Value="item.Title" />
                                        </div>
                                    </div>

                                    <div class="d-flex gap-2">
                                        <button type="button"
                                                class="btn btn-outline-danger btn-sm"
                                                @onclick="() => RemoveTimelineEvent(item)">
                                            Remove From Page
                                        </button>
                                    </div>
                                </div>
                            }

                            <div class="d-flex gap-2">
                                <button type="submit"
                                        class="btn btn-primary"
                                        disabled="@isSaving">
                                    @(isSaving ? "Saving..." : "Save Timeline Changes")
                                </button>

                                <button type="button"
                                        class="btn btn-secondary"
                                        @onclick="ReloadPatientAsync"
                                        disabled="@isSaving">
                                    Reload
                                </button>
                            </div>
                        </EditForm>
                    }
                    else
                    {
                        <div class="alert alert-light border">
                            No timeline events added yet.
                        </div>

                        <div class="d-flex gap-2">
                            <button type="button"
                                    class="btn btn-secondary"
                                    @onclick="ReloadPatientAsync"
                                    disabled="@isSaving">
                                Reload
                            </button>
                        </div>
                    }
                </div>
            }
            else if (activeTab == "neurology")
            {
                <div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="mb-0">Neurology</h5>

                        @if (isNeurologyDirty)
                        {
                            <span class="text-warning fw-semibold">You have unsaved neurology changes.</span>
                        }
                        else
                        {
                            <span class="text-muted">Neurology is saved.</span>
                        }
                    </div>

                    <div class="d-flex justify-content-end gap-2 mb-3">
                        <button type="button"
                                class="btn btn-outline-secondary"
                                @onclick="OpenAddMedicationModal"
                                disabled="@isSaving">
                            Add New Medication To Catalog
                        </button>

                        <button type="button"
                                class="btn btn-outline-secondary"
                                @onclick="OpenEditMedicationModal"
                                disabled="@isSaving">
                            Edit Medication In Catalog
                        </button>
                    </div>

                    <EditForm EditContext="neurologyEditContext" OnValidSubmit="SaveNeurologyAsync">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="border rounded p-3 mb-4">
                            <h6 class="mb-3">Glasgow Coma Scale</h6>

                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Eye</label>
                                    <InputSelect class="form-select"
                                                 @bind-Value="patient.Neurology!.GcsEye">
                                        <option value="">-- Select Eye Response --</option>

                                        @foreach (var eye in Enum.GetValues<GcsEyeResponse>())
                                        {
                                            <option value="@eye">@GetEnumDisplayName(eye)</option>
                                        }
                                    </InputSelect>
                                </div>

                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Verbal</label>
                                    <InputSelect class="form-select"
                                                 @bind-Value="patient.Neurology!.GcsVerbal">
                                        <option value="">-- Select Verbal Response --</option>

                                        @foreach (var verbal in Enum.GetValues<GcsVerbalResponse>())
                                        {
                                            <option value="@verbal">@GetEnumDisplayName(verbal)</option>
                                        }
                                    </InputSelect>
                                </div>

                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Motor</label>
                                    <InputSelect class="form-select"
                                                 @bind-Value="patient.Neurology!.GcsMotor">
                                        <option value="">-- Select Motor Response --</option>

                                        @foreach (var motor in Enum.GetValues<GcsMotorResponse>())
                                        {
                                            <option value="@motor">@GetEnumDisplayName(motor)</option>
                                        }
                                    </InputSelect>
                                </div>
                            </div>

                            <div class="alert alert-light border mb-0">
                                <span class="fw-semibold">GCS Total:</span>
                                @if (patient.Neurology.GcsTotal.HasValue)
                                {
                                    <span>@patient.Neurology.GcsTotal.Value</span>
                                }
                                else
                                {
                                    <span class="text-muted">Complete all 3 GCS fields to calculate total.</span>
                                }
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Pupils</label>
                                <InputText class="form-control"
                                           @bind-Value="patient.Neurology!.Pupils" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Motor Status</label>
                                <InputText class="form-control"
                                           @bind-Value="patient.Neurology!.MotorStatus" />
                            </div>
                        </div>

                        <div class="border rounded p-3 mb-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h6 class="mb-0">Sedation Medications</h6>

                                <button type="button"
                                        class="btn btn-outline-primary btn-sm"
                                        @onclick="() => AddNeurologyMedication(NeurologyMedicationCategory.Sedation)"
                                        disabled="@isSaving">
                                    Add Sedation Medication
                                </button>
                            </div>

                            @if (GetNeurologyMedicationsByCategory(NeurologyMedicationCategory.Sedation).Any())
                            {
                                @foreach (var item in GetNeurologyMedicationsByCategory(NeurologyMedicationCategory.Sedation))
                                {
                                    <div class="border rounded p-3 mb-3">
                                        <div class="row">
                                            <div class="col-md-7 mb-3">
                                                <label class="form-label">Medication</label>
                                                <InputSelect class="form-select"
                                                             @bind-Value="item.MedicationId">
                                                    <option value="0">-- Select Medication --</option>

                                                    @foreach (var medication in medications)
                                                    {
                                                        <option value="@medication.Id">@medication.Name</option>
                                                    }
                                                </InputSelect>

                                                @if (!string.IsNullOrWhiteSpace(GetMedicationFrequency(item.MedicationId)))
                                                {
                                                    <div class="form-text">
                                                        Default frequency: @GetMedicationFrequency(item.MedicationId)
                                                    </div>
                                                }
                                            </div>

                                            <div class="col-md-5 mb-3">
                                                <label class="form-label">Dose</label>
                                                <InputNumber TValue="decimal?"
                                                             class="form-control"
                                                             @bind-Value="item.Dose" />
                                            </div>
                                        </div>

                                        <div class="d-flex gap-2">
                                            <button type="button"
                                                    class="btn btn-outline-danger btn-sm"
                                                    @onclick="() => RemoveNeurologyMedication(item)"
                                                    disabled="@isSaving">
                                                Remove
                                            </button>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="alert alert-light border mb-0">
                                    No sedation medications added yet.
                                </div>
                            }
                        </div>

                        <div class="border rounded p-3 mb-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h6 class="mb-0">Neuro Medications</h6>

                                <button type="button"
                                        class="btn btn-outline-primary btn-sm"
                                        @onclick="() => AddNeurologyMedication(NeurologyMedicationCategory.Neuro)"
                                        disabled="@isSaving">
                                    Add Neuro Medication
                                </button>
                            </div>

                            @if (GetNeurologyMedicationsByCategory(NeurologyMedicationCategory.Neuro).Any())
                            {
                                @foreach (var item in GetNeurologyMedicationsByCategory(NeurologyMedicationCategory.Neuro))
                                {
                                    <div class="border rounded p-3 mb-3">
                                        <div class="row">
                                            <div class="col-md-7 mb-3">
                                                <label class="form-label">Medication</label>
                                                <InputSelect class="form-select"
                                                             @bind-Value="item.MedicationId">
                                                    <option value="0">-- Select Medication --</option>

                                                    @foreach (var medication in medications)
                                                    {
                                                        <option value="@medication.Id">@medication.Name</option>
                                                    }
                                                </InputSelect>

                                                @if (!string.IsNullOrWhiteSpace(GetMedicationFrequency(item.MedicationId)))
                                                {
                                                    <div class="form-text">
                                                        Default frequency: @GetMedicationFrequency(item.MedicationId)
                                                    </div>
                                                }
                                            </div>

                                            <div class="col-md-5 mb-3">
                                                <label class="form-label">Dose</label>
                                                <InputNumber TValue="decimal?"
                                                             class="form-control"
                                                             @bind-Value="item.Dose" />
                                            </div>
                                        </div>

                                        <div class="d-flex gap-2">
                                            <button type="button"
                                                    class="btn btn-outline-danger btn-sm"
                                                    @onclick="() => RemoveNeurologyMedication(item)"
                                                    disabled="@isSaving">
                                                Remove
                                            </button>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="alert alert-light border mb-0">
                                    No neuro medications added yet.
                                </div>
                            }
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit"
                                    class="btn btn-primary"
                                    disabled="@isSaving">
                                @(isSaving ? "Saving..." : "Save Neurology Changes")
                            </button>

                            <button type="button"
                                    class="btn btn-secondary"
                                    @onclick="ReloadPatientAsync"
                                    disabled="@isSaving">
                                Reload
                            </button>
                        </div>
                    </EditForm>
                </div>
            }

            <hr />

            <div class="d-flex gap-2">
                <a href="/patients" class="btn btn-secondary">Back</a>
            </div>
        </div>
    </div>
}

@if (showAddMedicationModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0, 0, 0, 0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add New Medication</h5>

                    <button type="button"
                            class="btn-close"
                            @onclick="CloseAddMedicationModal"
                            disabled="@isSaving">
                    </button>
                </div>

                <div class="modal-body">
                    @if (!string.IsNullOrWhiteSpace(newMedicationErrorMessage))
                    {
                        <div class="alert alert-warning">
                            @newMedicationErrorMessage
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label">Medication Name</label>
                        <InputText class="form-control"
                                   @bind-Value="newMedicationName" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Default Frequency</label>
                        <InputText class="form-control"
                                   @bind-Value="newMedicationFrequency" />
                        <div class="form-text">
                            Examples: mcg/kg/min, BD, TID, q8h
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button"
                            class="btn btn-secondary"
                            @onclick="CloseAddMedicationModal"
                            disabled="@isSaving">
                        Cancel
                    </button>

                    <button type="button"
                            class="btn btn-primary"
                            @onclick="SaveNewMedicationAsync"
                            disabled="@isSaving">
                        @(isSaving ? "Saving..." : "Save Medication")
                    </button>
                </div>
            </div>
        </div>
    </div>
}


@if (showEditMedicationModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0, 0, 0, 0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Medication</h5>

                    <button type="button"
                            class="btn-close"
                            @onclick="CloseEditMedicationModal"
                            disabled="@isSaving">
                    </button>
                </div>

                <div class="modal-body">
                    @if (!string.IsNullOrWhiteSpace(editMedicationErrorMessage))
                    {
                        <div class="alert alert-warning">
                            @editMedicationErrorMessage
                        </div>
                    }

                    @if (!medications.Any())
                    {
                        <div class="alert alert-light border mb-0">
                            No medications in the catalog yet.
                        </div>
                    }
                    else
                    {
                        <div class="mb-3">
                            <label class="form-label">Select Medication</label>
                            <select class="form-select"
                                    value="@selectedMedicationToEditId"
                                    @onchange="OnSelectedMedicationToEditChanged">
                                @foreach (var medication in medications)
                                {
                                    <option value="@medication.Id">@medication.Name</option>
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Medication Name</label>
                            <InputText class="form-control"
                                       @bind-Value="editMedicationName" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Default Frequency</label>
                            <InputText class="form-control"
                                       @bind-Value="editMedicationFrequency" />
                            <div class="form-text">
                                Examples: mcg/kg/min, BD, TID, q8h
                            </div>
                        </div>
                    }
                </div>

                <div class="modal-footer">
                    <button type="button"
                            class="btn btn-secondary"
                            @onclick="CloseEditMedicationModal"
                            disabled="@isSaving">
                        Cancel
                    </button>

                    <button type="button"
                            class="btn btn-primary"
                            @onclick="SaveEditedMedicationAsync"
                            disabled="@isSaving">
                        @(isSaving ? "Saving..." : "Save Changes")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Patient? patient;
    private string? statusMessage;
    private string statusCssClass = "alert-info";
    private bool isLoading = true;
    private bool isSaving = false;
    private string activeTab = "overview";

    private List<PatientDateEvent> orderedDateEvents = new();
    private List<AdmissionUnitCatalog> admissionUnits = new();
    private List<Medication> medications = new();

    // These flags are the source for the notification badges.
    private bool isOverviewDirty;
    private bool isSummaryDirty;
    private bool isTimelineDirty;
    private bool isNeurologyDirty;

    // Separate EditContexts let us know which section changed.
    private EditContext? overviewEditContext;
    private EditContext? summaryEditContext;
    private EditContext? timelineEditContext;
    private EditContext? neurologyEditContext;

    // Modal state for adding a reusable medication to the shared catalog.
    private bool showAddMedicationModal;
    private string newMedicationName = string.Empty;
    private string newMedicationFrequency = string.Empty;
    private string? newMedicationErrorMessage;

    // Modal state for editing an existing reusable medication
    // from the shared catalog.
    private bool showEditMedicationModal;
    private int selectedMedicationToEditId;
    private string editMedicationName = string.Empty;
    private string editMedicationFrequency = string.Empty;
    private string? editMedicationErrorMessage;

    protected override async Task OnParametersSetAsync()
    {
        await LoadPatientAsync();
    }

    private async Task LoadPatientAsync()
    {
        isLoading = true;

        admissionUnits = await PatientService.GetAdmissionUnitsAsync();
        medications = await PatientService.GetMedicationsAsync();
        patient = await PatientService.GetByIdAsync(Id);

        if (patient is null)
        {
            statusMessage = "The requested patient was not found.";
            statusCssClass = "alert-warning";
            orderedDateEvents = new List<PatientDateEvent>();
        }
        else
        {
            EnsurePatientChildObjects();

            CreateEditContexts();
            ResetDirtyFlags();

            statusMessage = null;
            statusCssClass = "alert-info";
        }

        isLoading = false;
    }

    // Make sure all child objects exist before the page tries to bind to them.
    private void EnsurePatientChildObjects()
    {
        if (patient is null)
            return;

        patient.PatientSummary ??= new PatientSummary
        {
            PatientId = patient.Id
        };

        patient.PatientDateEvents ??= new List<PatientDateEvent>();

        patient.Neurology ??= new Neurology
        {
            PatientId = patient.Id
        };

        patient.Neurology.Medications ??= new List<NeurologyMedication>();

        orderedDateEvents = patient.PatientDateEvents
            .OrderBy(e => e.EventDate)
            .ToList();
    }

    // Create one EditContext per section and subscribe to change tracking.
    private void CreateEditContexts()
    {
        if (patient is null)
            return;

        DisposeEditContexts();

        overviewEditContext = new EditContext(patient);
        overviewEditContext.OnFieldChanged += HandleOverviewFieldChanged;

        summaryEditContext = new EditContext(patient.PatientSummary!);
        summaryEditContext.OnFieldChanged += HandleSummaryFieldChanged;

        timelineEditContext = new EditContext(new TimelineEditorModel
        {
            Events = orderedDateEvents
        });
        timelineEditContext.OnFieldChanged += HandleTimelineFieldChanged;

        neurologyEditContext = new EditContext(patient.Neurology!);
        neurologyEditContext.OnFieldChanged += HandleNeurologyFieldChanged;
    }

    private void HandleOverviewFieldChanged(object? sender, FieldChangedEventArgs e)
    {
        isOverviewDirty = true;
        InvokeAsync(StateHasChanged);
    }

    private void HandleSummaryFieldChanged(object? sender, FieldChangedEventArgs e)
    {
        isSummaryDirty = true;
        InvokeAsync(StateHasChanged);
    }

    private void HandleTimelineFieldChanged(object? sender, FieldChangedEventArgs e)
    {
        isTimelineDirty = true;
        InvokeAsync(StateHasChanged);
    }

    private void HandleNeurologyFieldChanged(object? sender, FieldChangedEventArgs e)
    {
        isNeurologyDirty = true;
        InvokeAsync(StateHasChanged);
    }

    private void ResetDirtyFlags()
    {
        isOverviewDirty = false;
        isSummaryDirty = false;
        isTimelineDirty = false;
        isNeurologyDirty = false;
    }

    private async Task SaveOverviewAsync()
    {
        if (patient is null)
            return;

        try
        {
            isSaving = true;

            await PatientService.UpdateAsync(patient);

            isOverviewDirty = false;

            statusMessage = "Overview changes saved successfully.";
            statusCssClass = "alert-success";
        }
        catch (Exception ex)
        {
            statusMessage = $"Error while saving overview changes: {ex.Message}";
            statusCssClass = "alert-danger";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task SaveSummaryAsync()
    {
        if (patient is null)
            return;

        try
        {
            isSaving = true;

            await PatientService.UpdateAsync(patient);

            isSummaryDirty = false;

            statusMessage = "Summary changes saved successfully.";
            statusCssClass = "alert-success";
        }
        catch (Exception ex)
        {
            statusMessage = $"Error while saving summary changes: {ex.Message}";
            statusCssClass = "alert-danger";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task SaveTimelineAsync()
    {
        if (patient is null)
            return;

        try
        {
            isSaving = true;

            patient.PatientDateEvents = orderedDateEvents
                .OrderBy(e => e.EventDate)
                .ToList();

            await PatientService.UpdateAsync(patient);

            // Reload after timeline save so new events get real database Ids.
            patient = await PatientService.GetByIdAsync(Id);

            if (patient is not null)
            {
                EnsurePatientChildObjects();
                CreateEditContexts();
            }

            isTimelineDirty = false;

            statusMessage = "Timeline changes saved successfully.";
            statusCssClass = "alert-success";
        }
        catch (Exception ex)
        {
            statusMessage = $"Error while saving timeline changes: {ex.Message}";
            statusCssClass = "alert-danger";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task SaveNeurologyAsync()
    {
        if (patient is null)
            return;

        try
        {
            isSaving = true;

            // Make sure the neurology section exists and is linked to this patient.
            patient.Neurology ??= new Neurology
            {
                PatientId = patient.Id
            };

            patient.Neurology.PatientId = patient.Id;
            patient.Neurology.Medications ??= new List<NeurologyMedication>();

            await PatientService.UpdateAsync(patient);

            // Reload after save so new medication rows get real database Ids
            // and so Medication navigation properties are refreshed.
            patient = await PatientService.GetByIdAsync(Id);

            if (patient is not null)
            {
                EnsurePatientChildObjects();
                CreateEditContexts();
            }

            isNeurologyDirty = false;

            statusMessage = "Neurology changes saved successfully.";
            statusCssClass = "alert-success";
        }
        catch (Exception ex)
        {
            statusMessage = $"Error while saving neurology changes: {ex.Message}";
            statusCssClass = "alert-danger";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void AddTimelineEvent()
    {
        if (patient is null)
            return;

        var newEvent = new PatientDateEvent
        {
            PatientId = patient.Id,
            EventDate = DateTime.Today
        };

        orderedDateEvents.Add(newEvent);
        orderedDateEvents = orderedDateEvents
            .OrderBy(e => e.EventDate)
            .ToList();

        CreateEditContexts();
        isTimelineDirty = true;
    }

    private void RemoveTimelineEvent(PatientDateEvent item)
    {
        orderedDateEvents.Remove(item);
        orderedDateEvents = orderedDateEvents
            .OrderBy(e => e.EventDate)
            .ToList();

        CreateEditContexts();
        isTimelineDirty = true;
    }

    private void AddNeurologyMedication(NeurologyMedicationCategory category)
    {
        if (patient?.Neurology is null)
            return;

        patient.Neurology.Medications.Add(new NeurologyMedication
        {
            Category = category
        });

        CreateEditContexts();
        isNeurologyDirty = true;
    }

    private void RemoveNeurologyMedication(NeurologyMedication item)
    {
        if (patient?.Neurology is null)
            return;

        patient.Neurology.Medications.Remove(item);

        CreateEditContexts();
        isNeurologyDirty = true;
    }

    private IEnumerable<NeurologyMedication> GetNeurologyMedicationsByCategory(NeurologyMedicationCategory category)
    {
        if (patient?.Neurology?.Medications is null)
            return Enumerable.Empty<NeurologyMedication>();

        return patient.Neurology.Medications
            .Where(x => x.Category == category)
            .ToList();
    }

