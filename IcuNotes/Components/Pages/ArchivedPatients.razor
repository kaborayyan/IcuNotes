@page "/archived-patients"
@using IcuNotes.Models
@inject IcuNotes.Services.PatientService PatientService

<PageTitle>Archived Patients</PageTitle>

<h3>Archived Patients</h3>

<div class="mb-3">
    <!--
        Simple live search by patient name.
        The list updates as the user types.
    -->
    <input class="form-control"
           placeholder="Search by name..."
           @bind="searchText"
           @bind:event="oninput" />
</div>

@if (!string.IsNullOrWhiteSpace(statusMessage))
{
    <div class="alert @statusCssClass">
        @statusMessage
    </div>
}

@if (archivedPatients is null)
{
    <p>Loading...</p>
}
else if (!FilteredArchivedPatients.Any())
{
    if (string.IsNullOrWhiteSpace(searchText))
    {
        <p>No archived patients found.</p>
    }
    else
    {
        <p>No archived patients match your search.</p>
    }
}
else
{
    <p class="text-muted">
        Showing @FilteredArchivedPatients.Count() of @archivedPatients.Count archived patients
    </p>

    <table class="table table-striped table-bordered align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th>Age</th>
                <th>Weight</th>
                <th>Diagnosis</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var patient in FilteredArchivedPatients)
            {
                <tr>
                    <td>@patient.Name</td>
                    <td>@patient.Age</td>
                    <td>@patient.Weight</td>
                    <td>@patient.Diagnosis</td>                    
                    <td>
                        @if (pendingDeleteId == patient.Id)
                        {
                            <div class="d-flex flex-column gap-2">
                                <div class="text-danger small">
                                    Delete @patient.Name permanently?
                                </div>

                                <div>
                                    <button class="btn btn-danger btn-sm me-2"
                                            @onclick="() => DeleteArchivedPatientAsync(patient.Id)">
                                        Yes, Delete
                                    </button>

                                    <button class="btn btn-secondary btn-sm"
                                            @onclick="CancelDelete">
                                        Cancel
                                    </button>
                                </div>
                            </div>
                        }
                        else
                        {
                            <button class="btn btn-success btn-sm me-2"
                                    @onclick="() => RestorePatientAsync(patient.Id)">
                                Restore
                            </button>

                            <button class="btn btn-danger btn-sm"
                                    @onclick="() => AskToDelete(patient.Id)">
                                Delete
                            </button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    // Status message text shown above the table
    private string? statusMessage;

    // Bootstrap class used for the status message style
    private string statusCssClass = "alert-info";

    // Helper method to set a message and its color/style
    private void SetStatus(string message, string cssClass = "alert-info")
    {
        statusMessage = message;
        statusCssClass = cssClass;
    }

    // All archived patients loaded from the database
    private List<ArchivedPatient>? archivedPatients;

    // Current text typed in the search box
    private string searchText = string.Empty;

    // Stores the archived patient Id currently waiting for delete confirmation.
    // If null, no row is currently in delete-confirm mode.
    private int? pendingDeleteId;

    // Returns either all archived patients or only the ones
    // whose names match the current search text.
    private IEnumerable<ArchivedPatient> FilteredArchivedPatients =>
        string.IsNullOrWhiteSpace(searchText)
            ? archivedPatients ?? Enumerable.Empty<ArchivedPatient>()
            : (archivedPatients ?? Enumerable.Empty<ArchivedPatient>())
                .Where(p =>
                    !string.IsNullOrWhiteSpace(p.Name) &&
                    p.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        await LoadArchivedPatientsAsync();
    }

    // Load all archived patients from the database
    private async Task LoadArchivedPatientsAsync()
    {
        archivedPatients = await PatientService.GetArchivedAsync();
    }

    // Restore one archived patient back to the active patients list
    private async Task RestorePatientAsync(int archivedPatientId)
    {
        // If a delete confirmation is showing, cancel it first
        pendingDeleteId = null;

        await PatientService.RestorePatientAsync(archivedPatientId);
        await LoadArchivedPatientsAsync();

        SetStatus("Patient restored successfully.", "alert-success");
    }

    // First click on Delete puts only that row into confirmation mode
    private void AskToDelete(int archivedPatientId)
    {
        pendingDeleteId = archivedPatientId;
        SetStatus("Please confirm permanent deletion.", "alert-warning");
    }

    // Cancel delete confirmation mode
    private void CancelDelete()
    {
        pendingDeleteId = null;
        SetStatus("Deletion cancelled.", "alert-info");
    }

    // Permanently delete the archived patient after confirmation
    private async Task DeleteArchivedPatientAsync(int archivedPatientId)
    {
        await PatientService.DeleteArchivedAsync(archivedPatientId);
        pendingDeleteId = null;
        await LoadArchivedPatientsAsync();

        SetStatus("Archived patient deleted permanently.", "alert-success");
    }
}