@page "/archived-patients"
@using IcuNotes.Models
@inject IcuNotes.Services.PatientService PatientService

<PageTitle>Archived Patients</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="pa-3">

    <MudStack Spacing="3">

        <!--
            Page header.

            This page is now designed as a mobile-first archive screen.
            Archived patients are shown as cards instead of a table because
            cards are easier to read and tap on a phone.
        -->
        <MudPaper Elevation="0" Outlined="true" Class="pa-4 rounded-lg">
            <MudStack Spacing="2">
                <MudStack Row="true"
                          AlignItems="AlignItems.Center"
                          Justify="Justify.SpaceBetween">
                    <div>
                        <MudText Typo="Typo.h5">
                            Archived Patients
                        </MudText>

                        <MudText Typo="Typo.body2"
                                 Color="Color.Secondary">
                            Restore previous patients or permanently delete archived records.
                        </MudText>
                    </div>

                    <MudIcon Icon="@Icons.Material.Filled.Inventory2"
                             Color="Color.Secondary"
                             Size="Size.Large" />
                </MudStack>

                <!--
                    Immediate=true makes the search update while typing,
                    similar to the previous @bind:event="oninput" behavior.
                -->
                <MudTextField T="string"
                              @bind-Value="searchText"
                              Label="Search by name"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Immediate="true"
                              Clearable="true"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search" />

                @if (archivedPatients is not null)
                {
                    <MudText Typo="Typo.caption"
                             Color="Color.Secondary">
                        Showing @FilteredArchivedPatients.Count() of @archivedPatients.Count archived patients
                    </MudText>
                }
            </MudStack>
        </MudPaper>

        @if (!string.IsNullOrWhiteSpace(statusMessage))
        {
            <!--
                MudAlert replaces the old Bootstrap alert classes.
                The color is controlled by the Severity enum in code.
            -->
            <MudAlert Severity="statusSeverity"
                      Variant="Variant.Filled"
                      Dense="true">
                @statusMessage
            </MudAlert>
        }

        @if (archivedPatients is null)
        {
            <!--
                Loading state shown while the database query is running.
            -->
            <MudPaper Elevation="0" Outlined="true" Class="pa-5 rounded-lg">
                <MudStack AlignItems="AlignItems.Center" Spacing="2">
                    <MudProgressCircular Indeterminate="true" />
                    <MudText Typo="Typo.body2"
                             Color="Color.Secondary">
                        Loading archived patients...
                    </MudText>
                </MudStack>
            </MudPaper>
        }
        else if (!FilteredArchivedPatients.Any())
        {
            <!--
                Empty state.

                We show a friendlier message instead of a plain paragraph.
            -->
            <MudPaper Elevation="0" Outlined="true" Class="pa-5 rounded-lg">
                <MudStack AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.SearchOff"
                             Size="Size.Large"
                             Color="Color.Secondary" />

                    <MudText Typo="Typo.subtitle1"
                             Align="Align.Center">
                        @EmptyStateTitle
                    </MudText>

                    <MudText Typo="Typo.body2"
                             Color="Color.Secondary"
                             Align="Align.Center">
                        @EmptyStateMessage
                    </MudText>
                </MudStack>
            </MudPaper>
        }
        else
        {
            <!--
                Mobile-first archived patient list.

                Each patient is a card with:
                - name
                - age / weight chips
                - diagnosis
                - restore and delete actions

                This avoids the horizontal crowding of a table on phones.
            -->
            @foreach (var patient in FilteredArchivedPatients)
            {
                <MudPaper Elevation="0" Outlined="true" Class="pa-3 rounded-lg">
                    <MudStack Spacing="2">

                        <MudStack Row="true"
                                  AlignItems="AlignItems.Start"
                                  Justify="Justify.SpaceBetween">
                            <div>
                                <MudText Typo="Typo.subtitle1">
                                    @patient.Name
                                </MudText>

                                <MudText Typo="Typo.caption"
                                         Color="Color.Secondary">
                                    Archived patient record
                                </MudText>
                            </div>

                            <MudIcon Icon="@Icons.Material.Filled.Archive"
                                     Color="Color.Secondary" />
                        </MudStack>

                        <MudStack Row="true" Spacing="1">
                            <MudChip T="string"
                                     Variant="Variant.Outlined"
                                     Color="Color.Info"
                                     Size="Size.Small">
                                Age: @patient.Age
                            </MudChip>

                            <MudChip T="string"
                                     Variant="Variant.Outlined"
                                     Color="Color.Info"
                                     Size="Size.Small">
                                Weight: @patient.Weight kg
                            </MudChip>
                        </MudStack>

                        <MudDivider />

                        <div>
                            <MudText Typo="Typo.caption"
                                     Color="Color.Secondary">
                                Diagnosis
                            </MudText>

                            <MudText Typo="Typo.body2">
                                @GetDiagnosisText(patient)
                            </MudText>
                        </div>

                        @if (pendingDeleteId == patient.Id)
                        {
                            <!--
                                Inline delete confirmation.

                                Only one patient card enters confirmation mode at a time.
                                This keeps the dangerous action close to the selected record.
                            -->
                            <MudAlert Severity="Severity.Warning"
                                      Variant="Variant.Outlined"
                                      Dense="true">
                                Permanently delete @patient.Name?
                            </MudAlert>

                            <MudStack Row="true" Spacing="2">
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Error"
                                           StartIcon="@Icons.Material.Filled.DeleteForever"
                                           OnClick="() => DeleteArchivedPatientAsync(patient.Id)">
                                    Delete
                                </MudButton>

                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Default"
                                           OnClick="CancelDelete">
                                    Cancel
                                </MudButton>
                            </MudStack>
                        }
                        else
                        {
                            <MudStack Row="true" Spacing="2">
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Success"
                                           StartIcon="@Icons.Material.Filled.Restore"
                                           OnClick="() => RestorePatientAsync(patient.Id)">
                                    Restore
                                </MudButton>

                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Error"
                                           StartIcon="@Icons.Material.Filled.Delete"
                                           OnClick="() => AskToDelete(patient.Id)">
                                    Delete
                                </MudButton>
                            </MudStack>
                        }

                    </MudStack>
                </MudPaper>
            }
        }

    </MudStack>

</MudContainer>

@code {
    // Status message text shown above the archived patient list.
    private string? statusMessage;

    // MudBlazor alert severity replaces the old Bootstrap CSS alert classes.
    private Severity statusSeverity = Severity.Info;

    // Helper method to set a message and its MudBlazor alert color.
    private void SetStatus(string message, Severity severity = Severity.Info)
    {
        statusMessage = message;
        statusSeverity = severity;
    }

    // All archived patients loaded from the database.
    private List<ArchivedPatient>? archivedPatients;

    // Current text typed in the search box.
    private string searchText = string.Empty;

    // Stores the archived patient Id currently waiting for delete confirmation.
    // If null, no patient card is currently in delete-confirm mode.
    private int? pendingDeleteId;

    // Returns either all archived patients or only the ones
    // whose names match the current search text.
    private IEnumerable<ArchivedPatient> FilteredArchivedPatients =>
        string.IsNullOrWhiteSpace(searchText)
            ? archivedPatients ?? Enumerable.Empty<ArchivedPatient>()
            : (archivedPatients ?? Enumerable.Empty<ArchivedPatient>())
                .Where(p =>
                    !string.IsNullOrWhiteSpace(p.Name) &&
                    p.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase));

    // Friendly empty-state title shown when the archive list has no visible records.
    private string EmptyStateTitle =>
        string.IsNullOrWhiteSpace(searchText)
            ? "No archived patients found"
            : "No matching archived patients";

    // Friendly empty-state details shown below the empty-state title.
    private string EmptyStateMessage =>
        string.IsNullOrWhiteSpace(searchText)
            ? "Archived patients will appear here after you archive them from the active patients list."
            : "Try a different name or clear the search box.";

    protected override async Task OnInitializedAsync()
    {
        await LoadArchivedPatientsAsync();
    }

    // Load all archived patients from the database.
    private async Task LoadArchivedPatientsAsync()
    {
        archivedPatients = await PatientService.GetArchivedAsync();
    }

    // Restore one archived patient back to the active patients list.
    private async Task RestorePatientAsync(int archivedPatientId)
    {
        // If a delete confirmation is showing, cancel it first.
        pendingDeleteId = null;

        await PatientService.RestorePatientAsync(archivedPatientId);
        await LoadArchivedPatientsAsync();

        SetStatus("Patient restored successfully.", Severity.Success);
    }

    // First click on Delete puts only that patient card into confirmation mode.
    private void AskToDelete(int archivedPatientId)
    {
        pendingDeleteId = archivedPatientId;
        SetStatus("Please confirm permanent deletion.", Severity.Warning);
    }

    // Cancel delete confirmation mode.
    private void CancelDelete()
    {
        pendingDeleteId = null;
        SetStatus("Deletion cancelled.", Severity.Info);
    }

    // Permanently delete the archived patient after confirmation.
    private async Task DeleteArchivedPatientAsync(int archivedPatientId)
    {
        await PatientService.DeleteArchivedAsync(archivedPatientId);
        pendingDeleteId = null;
        await LoadArchivedPatientsAsync();

        SetStatus("Archived patient deleted permanently.", Severity.Success);
    }

    // Keeps the markup cleaner and avoids showing a blank diagnosis area.
    private static string GetDiagnosisText(ArchivedPatient patient)
    {
        return string.IsNullOrWhiteSpace(patient.Diagnosis)
            ? "No diagnosis recorded."
            : patient.Diagnosis;
    }
}