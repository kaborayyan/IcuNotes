@using System.ComponentModel.DataAnnotations
@using IcuNotes.Models
@using Microsoft.AspNetCore.Components.Forms

@* This component contains the Neurology section UI.
   The parent PatientDetails page still owns:
   - patient loading
   - dirty tracking
   - saving
   - reloading

   This file focuses only on the visible Neurology form.*@

@if (Patient is not null)
{
    <EditForm EditContext="NeurologyEditContext">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <MudStack Spacing="3">

            @* Section title.
               This gives the Neurology page a clear Material-style entry point
               instead of copying the old design. *@
            <MudPaper Elevation="0" Outlined="true" Class="pa-3">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h6">Neurology</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Glasgow Coma Scale, neurological examination, and neuro-related medications.
                    </MudText>
                </MudStack>
            </MudPaper>

            @* Glasgow Coma Scale.
               MudSelect is used for the three GCS response fields.
               The selected enum values remain bound directly to Patient.Neurology. *@
            <MudPaper Elevation="0" Outlined="true" Class="pa-3">
                <MudStack Spacing="2">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2">
                        <MudText Typo="Typo.subtitle1">Glasgow Coma Scale</MudText>

                        @if (Patient.Neurology!.GcsTotal.HasValue)
                        {
                            <MudChip T="string"
                                     Color="Color.Primary"
                                     Variant="Variant.Filled"
                                     Size="Size.Small">
                                GCS @Patient.Neurology.GcsTotal.Value
                            </MudChip>
                        }
                        else
                        {
                            <MudChip T="string"
                                     Color="Color.Default"
                                     Variant="Variant.Outlined"
                                     Size="Size.Small">
                                Incomplete
                            </MudChip>
                        }
                    </MudStack>

                    <MudGrid Spacing="2">
                        <MudItem xs="12" sm="4">
                            <MudSelect T="GcsEyeResponse?"
                                       Label="Eye response"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       Disabled="@IsSaving"
                                       Value="Patient.Neurology!.GcsEye"
                                       ValueChanged="HandleGcsEyeChanged">
                                <MudSelectItem T="GcsEyeResponse?" Value="@((GcsEyeResponse?)null)">
                                    Select eye response
                                </MudSelectItem>

                                @foreach (var eye in Enum.GetValues<GcsEyeResponse>())
                                {
                                    <MudSelectItem T="GcsEyeResponse?" Value="@((GcsEyeResponse?)eye)">
                                        @GetEnumDisplayName(eye)
                                    </MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>

                        <MudItem xs="12" sm="4">
                            <MudSelect T="GcsVerbalResponse?"
                                       Label="Verbal response"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       Disabled="@IsSaving"
                                       Value="Patient.Neurology!.GcsVerbal"
                                       ValueChanged="HandleGcsVerbalChanged">
                                <MudSelectItem T="GcsVerbalResponse?" Value="@((GcsVerbalResponse?)null)">
                                    Select verbal response
                                </MudSelectItem>

                                @foreach (var verbal in Enum.GetValues<GcsVerbalResponse>())
                                {
                                    <MudSelectItem T="GcsVerbalResponse?" Value="@((GcsVerbalResponse?)verbal)">
                                        @GetEnumDisplayName(verbal)
                                    </MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>

                        <MudItem xs="12" sm="4">
                            <MudSelect T="GcsMotorResponse?"
                                       Label="Motor response"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       Disabled="@IsSaving"
                                       Value="Patient.Neurology!.GcsMotor"
                                       ValueChanged="HandleGcsMotorChanged">
                                <MudSelectItem T="GcsMotorResponse?" Value="@((GcsMotorResponse?)null)">
                                    Select motor response
                                </MudSelectItem>

                                @foreach (var motor in Enum.GetValues<GcsMotorResponse>())
                                {
                                    <MudSelectItem T="GcsMotorResponse?" Value="@((GcsMotorResponse?)motor)">
                                        @GetEnumDisplayName(motor)
                                    </MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                    </MudGrid>

                    @if (!Patient.Neurology.GcsTotal.HasValue)
                    {
                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                            Complete eye, verbal, and motor responses to calculate the total GCS.
                        </MudAlert>
                    }
                </MudStack>
            </MudPaper>

            @* Examination.
               MudTextField is used for the free-text examination fields. *@
            <MudPaper Elevation="0" Outlined="true" Class="pa-3">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.subtitle1">Neurological examination</MudText>

                    <MudGrid Spacing="2">
                        <MudItem xs="12" sm="6">
                            <MudTextField T="string"
                                          Label="Pupils"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Disabled="@IsSaving"
                                          Value="Patient.Neurology!.Pupils"
                                          ValueChanged="HandlePupilsChanged" />
                        </MudItem>

                        <MudItem xs="12" sm="6">
                            <MudTextField T="string"
                                          Label="Motor status"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Disabled="@IsSaving"
                                          Value="Patient.Neurology!.MotorStatus"
                                          ValueChanged="HandleMotorStatusChanged" />
                        </MudItem>
                    </MudGrid>
                </MudStack>
            </MudPaper>

            @* This reusable manager handles adding/editing the shared medication catalog.
               It is a separate component, so its internal UI will be migrated later when we work on
               MedicationsManager.razor. *@
            <MudPaper Elevation="0" Outlined="true" Class="pa-3">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.subtitle1">Medication catalog</MudText>

                    <MedicationsManager Medications="Medications"
                                        IsDisabled="IsSaving"
                                        OnMedicationsChanged="HandleMedicationsChangedAsync"
                                        OnStatusMessage="HandleStatusMessageAsync" />
                </MudStack>
            </MudPaper>

            @* Sedation medications. *@
            <MudPaper Elevation="0" Outlined="true" Class="pa-3">
                <MudStack Spacing="2">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2">
                        <MudText Typo="Typo.subtitle1">Sedation medications</MudText>

                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   Disabled="@IsSaving"
                                   OnClick="() => HandleAddNeurologyMedicationAsync(NeurologyMedicationCategory.Sedation)">
                            Add
                        </MudButton>
                    </MudStack>

                    @if (GetNeurologyMedicationsByCategory(NeurologyMedicationCategory.Sedation).Any())
                    {
                        @foreach (var item in GetNeurologyMedicationsByCategory(NeurologyMedicationCategory.Sedation))
                        {
                            <MudPaper Elevation="0" Outlined="true" Class="pa-3">
                                <MudGrid Spacing="2">
                                    <MudItem xs="12" md="7">
                                        <MudSelect T="int"
                                                   Label="Medication"
                                                   Variant="Variant.Outlined"
                                                   Margin="Margin.Dense"
                                                   Disabled="@IsSaving"
                                                   Value="item.MedicationId"
                                                   ValueChanged="@(value => HandleMedicationIdChanged(item, value))">
                                            <MudSelectItem T="int" Value="0">Select medication</MudSelectItem>

                                            @foreach (var medication in Medications)
                                            {
                                                <MudSelectItem T="int" Value="@medication.Id">
                                                    @medication.Name
                                                </MudSelectItem>
                                            }
                                        </MudSelect>

                                        @if (!string.IsNullOrWhiteSpace(GetMedicationFrequency(item.MedicationId)))
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                Default frequency: @GetMedicationFrequency(item.MedicationId)
                                            </MudText>
                                        }
                                    </MudItem>

                                    <MudItem xs="7" md="3">
                                        <MudNumericField T="decimal?"
                                                         Label="Dose"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         Disabled="@IsSaving"
                                                         Value="item.Dose"
                                                         ValueChanged="@(value => HandleMedicationDoseChanged(item, value))" />
                                    </MudItem>

                                    <MudItem xs="5" md="2">
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Error"
                                                   FullWidth="true"
                                                   StartIcon="@Icons.Material.Filled.Delete"
                                                   Disabled="@IsSaving"
                                                   OnClick="() => HandleRemoveNeurologyMedicationAsync(item)">
                                            Remove
                                        </MudButton>
                                    </MudItem>
                                </MudGrid>
                            </MudPaper>
                        }
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                            No sedation medications added yet.
                        </MudAlert>
                    }
                </MudStack>
            </MudPaper>

            @* Other neuro medications. *@
            <MudPaper Elevation="0" Outlined="true" Class="pa-3">
                <MudStack Spacing="2">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2">
                        <MudText Typo="Typo.subtitle1">Other medications</MudText>

                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   Disabled="@IsSaving"
                                   OnClick="() => HandleAddNeurologyMedicationAsync(NeurologyMedicationCategory.Neuro)">
                            Add
                        </MudButton>
                    </MudStack>

                    @if (GetNeurologyMedicationsByCategory(NeurologyMedicationCategory.Neuro).Any())
                    {
                        @foreach (var item in GetNeurologyMedicationsByCategory(NeurologyMedicationCategory.Neuro))
                        {
                            <MudPaper Elevation="0" Outlined="true" Class="pa-3">
                                <MudGrid Spacing="2">
                                    <MudItem xs="12" md="7">
                                        <MudSelect T="int"
                                                   Label="Medication"
                                                   Variant="Variant.Outlined"
                                                   Margin="Margin.Dense"
                                                   Disabled="@IsSaving"
                                                   Value="item.MedicationId"
                                                   ValueChanged="@(value => HandleMedicationIdChanged(item, value))">
                                            <MudSelectItem T="int" Value="0">Select medication</MudSelectItem>

                                            @foreach (var medication in Medications)
                                            {
                                                <MudSelectItem T="int" Value="@medication.Id">
                                                    @medication.Name
                                                </MudSelectItem>
                                            }
                                        </MudSelect>

                                        @if (!string.IsNullOrWhiteSpace(GetMedicationFrequency(item.MedicationId)))
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                Default frequency: @GetMedicationFrequency(item.MedicationId)
                                            </MudText>
                                        }
                                    </MudItem>

                                    <MudItem xs="7" md="3">
                                        <MudNumericField T="decimal?"
                                                         Label="Dose"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         Disabled="@IsSaving"
                                                         Value="item.Dose"
                                                         ValueChanged="@(value => HandleMedicationDoseChanged(item, value))" />
                                    </MudItem>

                                    <MudItem xs="5" md="2">
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Error"
                                                   FullWidth="true"
                                                   StartIcon="@Icons.Material.Filled.Delete"
                                                   Disabled="@IsSaving"
                                                   OnClick="() => HandleRemoveNeurologyMedicationAsync(item)">
                                            Remove
                                        </MudButton>
                                    </MudItem>
                                </MudGrid>
                            </MudPaper>
                        }
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                            No other medications added yet.
                        </MudAlert>
                    }
                </MudStack>
            </MudPaper>

            @* Save and reload buttons intentionally stay outside this section.
               PatientDetailsActionBar handles Save/Reload for the active section. *@
        </MudStack>
    </EditForm>
}

@code {
    // The parent page passes the current patient object into this component.
    [Parameter, EditorRequired]
    public Patient? Patient { get; set; }

    // The parent page passes the reusable medication catalog for dropdown lists.
    [Parameter, EditorRequired]
    public List<Medication> Medications { get; set; } = new();

    // The parent page passes the EditContext so dirty tracking stays in one place.
    [Parameter, EditorRequired]
    public EditContext NeurologyEditContext { get; set; } = default!;

    // This flag disables buttons while the parent page is saving data.
    [Parameter]
    public bool IsSaving { get; set; }

    // The parent page provides the method that adds a medication row to the section.
    [Parameter, EditorRequired]
    public EventCallback<NeurologyMedicationCategory> OnAddNeurologyMedication { get; set; }

    // The parent page provides the method that removes a medication row from the section.
    [Parameter, EditorRequired]
    public EventCallback<NeurologyMedication> OnRemoveNeurologyMedication { get; set; }

    // This callback lets the parent page replace its medication catalog list
    // after the shared MedicationsManager adds or edits a catalog item.
    [Parameter]
    public EventCallback<List<Medication>> OnMedicationsChanged { get; set; }

    // This callback lets the component forward status messages to the parent page.
    [Parameter]
    public EventCallback<string> OnStatusMessage { get; set; }

    // This helper is the key part of dirty tracking for MudBlazor fields.
    // MudBlazor updates the value correctly, but we also manually notify the EditContext
    // so PatientDetails.razor can enable the bottom Save button.
    private void NotifyNeurologyFieldChanged(object model, string propertyName)
    {
        NeurologyEditContext.NotifyFieldChanged(new FieldIdentifier(model, propertyName));
    }

    // The next handlers update the GCS values and notify the parent EditContext.
    // This keeps the calculated GCS chip updated and marks Neurology as dirty.
    private void HandleGcsEyeChanged(GcsEyeResponse? value)
    {
        if (Patient?.Neurology is null)
            return;

        Patient.Neurology.GcsEye = value;
        NotifyNeurologyFieldChanged(Patient.Neurology, nameof(Patient.Neurology.GcsEye));
    }

    private void HandleGcsVerbalChanged(GcsVerbalResponse? value)
    {
        if (Patient?.Neurology is null)
            return;

        Patient.Neurology.GcsVerbal = value;
        NotifyNeurologyFieldChanged(Patient.Neurology, nameof(Patient.Neurology.GcsVerbal));
    }

    private void HandleGcsMotorChanged(GcsMotorResponse? value)
    {
        if (Patient?.Neurology is null)
            return;

        Patient.Neurology.GcsMotor = value;
        NotifyNeurologyFieldChanged(Patient.Neurology, nameof(Patient.Neurology.GcsMotor));
    }

    // Free-text examination fields also need explicit notification.
    private void HandlePupilsChanged(string? value)
    {
        if (Patient?.Neurology is null)
            return;

        Patient.Neurology.Pupils = value;
        NotifyNeurologyFieldChanged(Patient.Neurology, nameof(Patient.Neurology.Pupils));
    }

    private void HandleMotorStatusChanged(string? value)
    {
        if (Patient?.Neurology is null)
            return;

        Patient.Neurology.MotorStatus = value;
        NotifyNeurologyFieldChanged(Patient.Neurology, nameof(Patient.Neurology.MotorStatus));
    }

    // Medication row changes are patient-data changes, so they should mark Neurology dirty.
    // The shared medication catalog manager is different: it changes the catalog only,
    // so it intentionally does not call this helper.
    private void HandleMedicationIdChanged(NeurologyMedication item, int value)
    {
        item.MedicationId = value;
        NotifyNeurologyFieldChanged(item, nameof(item.MedicationId));
    }

    private void HandleMedicationDoseChanged(NeurologyMedication item, decimal? value)
    {
        item.Dose = value;
        NotifyNeurologyFieldChanged(item, nameof(item.Dose));
    }

    // This method asks the parent page to add a new neurology medication row.
    private async Task HandleAddNeurologyMedicationAsync(NeurologyMedicationCategory category)
    {
        await OnAddNeurologyMedication.InvokeAsync(category);
    }

    // This method asks the parent page to remove one neurology medication row.
    private async Task HandleRemoveNeurologyMedicationAsync(NeurologyMedication item)
    {
        await OnRemoveNeurologyMedication.InvokeAsync(item);
    }

    // This method receives the refreshed medication catalog from MedicationsManager.
    // It updates the local list immediately and then informs the parent page too.
    private async Task HandleMedicationsChangedAsync(List<Medication> refreshedMedications)
    {
        Medications = refreshedMedications ?? new List<Medication>();
        await OnMedicationsChanged.InvokeAsync(Medications);
        await InvokeAsync(StateHasChanged);
    }

    // This method forwards a success message to the parent page when available.
    private async Task HandleStatusMessageAsync(string message)
    {
        await OnStatusMessage.InvokeAsync(message);
    }

    // This helper returns the rows for only one medication category at a time.
    private IEnumerable<NeurologyMedication> GetNeurologyMedicationsByCategory(NeurologyMedicationCategory category)
    {
        if (Patient?.Neurology?.Medications is null)
            return Enumerable.Empty<NeurologyMedication>();

        return Patient.Neurology.Medications
            .Where(x => x.Category == category)
            .ToList();
    }

    // This helper looks up the default frequency text for the selected medication.
    private string? GetMedicationFrequency(int medicationId)
    {
        if (medicationId <= 0)
            return null;

        return Medications
            .FirstOrDefault(x => x.Id == medicationId)
            ?.Frequency;
    }

    // This helper shows friendly enum labels using the [Display] attribute.
    private static string GetEnumDisplayName<TEnum>(TEnum value) where TEnum : struct, Enum
    {
        var memberInfo = typeof(TEnum).GetMember(value.ToString()).FirstOrDefault();

        if (memberInfo is null)
            return value.ToString();

        var displayAttribute = memberInfo
            .GetCustomAttributes(typeof(DisplayAttribute), false)
            .OfType<DisplayAttribute>()
            .FirstOrDefault();

        return displayAttribute?.Name ?? value.ToString();
    }
}