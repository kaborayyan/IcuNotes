@using IcuNotes.Models
@using Microsoft.AspNetCore.Components.Forms
@using MudBlazor

@* This component contains the Cardiology section UI.
   Saving and reloading are controlled by PatientDetails.razor.

   Important:
   - This component edits cardiology data only.
   - It does not directly save to the database.
   - The parent page owns saving, dirty tracking, and reload.*@

@if (Patient?.Cardiology is not null)
{
    <EditForm EditContext="CardiologyEditContext">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <MudStack Spacing="3">

            @* Section heading.
               The saved/unsaved message lives in the fixed bottom action bar. *@
            <MudPaper Elevation="0" Outlined="true" Class="pa-3">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.h6">Cardiology</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Daily cardiovascular observations, hemodynamics, and cardiovascular medications.
                    </MudText>
                </MudStack>
            </MudPaper>

            @* Core daily cardiovascular observations.
               HR, SBP, and DBP are short numeric values, so a 3-column layout works well on mobile. *@
            <MudPaper Elevation="0" Outlined="true" Class="pa-3">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.overline" Color="Color.Secondary">
                        Basic Hemodynamics
                    </MudText>

                    <MudGrid Spacing="2">
                        <MudItem xs="4">
                            <MudNumericField T="int?"
                                             Label="HR"
                                             Variant="Variant.Outlined"
                                             Margin="Margin.Dense"
                                             FullWidth="true"
                                             Disabled="@IsSaving"
                                             Value="Patient.Cardiology.HeartRate"
                                             ValueChanged="HandleHeartRateChanged" />
                        </MudItem>

                        <MudItem xs="4">
                            <MudNumericField T="int?"
                                             Label="SBP"
                                             Variant="Variant.Outlined"
                                             Margin="Margin.Dense"
                                             FullWidth="true"
                                             Disabled="@IsSaving"
                                             Value="Patient.Cardiology.SystolicBloodPressure"
                                             ValueChanged="HandleSystolicBloodPressureChanged" />
                        </MudItem>

                        <MudItem xs="4">
                            <MudNumericField T="int?"
                                             Label="DBP"
                                             Variant="Variant.Outlined"
                                             Margin="Margin.Dense"
                                             FullWidth="true"
                                             Disabled="@IsSaving"
                                             Value="Patient.Cardiology.DiastolicBloodPressure"
                                             ValueChanged="HandleDiastolicBloodPressureChanged" />
                        </MudItem>
                    </MudGrid>

                    @* MAP is calculated in Cardiology.cs.
                       It is not directly edited and is not stored as a separate input field here. *@
                    @if (Patient.Cardiology.MeanArterialPressure.HasValue)
                    {
                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                            Calculated MAP: <strong>@Patient.Cardiology.MeanArterialPressure.Value</strong>
                        </MudAlert>
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Normal" Variant="Variant.Outlined">
                            Enter SBP and DBP to calculate MAP.
                        </MudAlert>
                    }
                </MudStack>
            </MudPaper>

            @* Additional common ICU cardiology measurements. *@
            <MudPaper Elevation="0" Outlined="true" Class="pa-3">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.overline" Color="Color.Secondary">
                        Volume / Echo Clues
                    </MudText>

                    <MudGrid Spacing="2">
                        <MudItem xs="6">
                            <MudNumericField T="int?"
                                             Label="CVP"
                                             Variant="Variant.Outlined"
                                             Margin="Margin.Dense"
                                             FullWidth="true"
                                             Disabled="@IsSaving"
                                             Value="Patient.Cardiology.CentralVenousPressure"
                                             ValueChanged="HandleCentralVenousPressureChanged" />
                        </MudItem>

                        <MudItem xs="6">
                            <MudNumericField T="int?"
                                             Label="IVC"
                                             Variant="Variant.Outlined"
                                             Margin="Margin.Dense"
                                             FullWidth="true"
                                             Disabled="@IsSaving"
                                             Value="Patient.Cardiology.InferiorVenaCava"
                                             ValueChanged="HandleInferiorVenaCavaChanged" />
                        </MudItem>
                    </MudGrid>
                </MudStack>
            </MudPaper>

            @* Advanced hemodynamic values.
               These are nullable because they are used only in selected patients. *@
            <MudPaper Elevation="0" Outlined="true" Class="pa-3">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.overline" Color="Color.Secondary">
                        Advanced Hemodynamics
                    </MudText>

                    <MudGrid Spacing="2">
                        <MudItem xs="6">
                            <MudNumericField T="decimal?"
                                             Label="CI"
                                             Variant="Variant.Outlined"
                                             Margin="Margin.Dense"
                                             FullWidth="true"
                                             Disabled="@IsSaving"
                                             Value="Patient.Cardiology.CardiacIndex"
                                             ValueChanged="HandleCardiacIndexChanged" />
                        </MudItem>

                        <MudItem xs="6">
                            <MudNumericField T="decimal?"
                                             Label="CO"
                                             Variant="Variant.Outlined"
                                             Margin="Margin.Dense"
                                             FullWidth="true"
                                             Disabled="@IsSaving"
                                             Value="Patient.Cardiology.CardiacOutput"
                                             ValueChanged="HandleCardiacOutputChanged" />
                        </MudItem>

                        <MudItem xs="6">
                            <MudNumericField T="int?"
                                             Label="SVR"
                                             Variant="Variant.Outlined"
                                             Margin="Margin.Dense"
                                             FullWidth="true"
                                             Disabled="@IsSaving"
                                             Value="Patient.Cardiology.SystemicVascularResistance"
                                             ValueChanged="HandleSystemicVascularResistanceChanged" />
                        </MudItem>

                        <MudItem xs="6">
                            <MudNumericField T="int?"
                                             Label="PCWP"
                                             Variant="Variant.Outlined"
                                             Margin="Margin.Dense"
                                             FullWidth="true"
                                             Disabled="@IsSaving"
                                             Value="Patient.Cardiology.PulmonaryCapillaryWedgePressure"
                                             ValueChanged="HandlePulmonaryCapillaryWedgePressureChanged" />
                        </MudItem>
                    </MudGrid>
                </MudStack>
            </MudPaper>

            @* Free text area for extra cardiology details that do not deserve
               their own database field yet. *@
            <MudPaper Elevation="0" Outlined="true" Class="pa-3">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.overline" Color="Color.Secondary">
                        Cardiology Notes
                    </MudText>

                    <MudTextField T="string"
                                  Label="Notes"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Lines="5"
                                  FullWidth="true"
                                  Disabled="@IsSaving"
                                  Value="Patient.Cardiology.Notes"
                                  ValueChanged="HandleNotesChanged" />

                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Examples: poor LV function, post PCI, temporary pacemaker, severe MR, echo findings.
                    </MudText>
                </MudStack>
            </MudPaper>

            @* This reusable manager handles adding and editing shared catalog medications.
               Cardiology stays focused only on cardiology-specific medication rows.
               Note: MedicationsManager may still contain Bootstrap until we migrate that component. *@
            <MudPaper Elevation="0" Outlined="true" Class="pa-3">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.overline" Color="Color.Secondary">
                        Medication Catalog
                    </MudText>

                    <MedicationsManager Medications="Medications"
                                        IsDisabled="IsSaving"
                                        OnMedicationsChanged="HandleMedicationsChangedAsync"
                                        OnStatusMessage="HandleStatusMessageAsync" />
                </MudStack>
            </MudPaper>

            @* This block edits vasopressor and inotrope medication rows. *@
            <MudPaper Elevation="0" Outlined="true" Class="pa-3">
                <MudStack Spacing="2">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2">
                        <MudText Typo="Typo.overline" Color="Color.Secondary">
                            Support Medications
                        </MudText>

                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   Disabled="@IsSaving"
                                   OnClick="@(() => HandleAddCardiologyMedicationAsync(CardiologyMedicationCategory.Support))">
                            Add
                        </MudButton>
                    </MudStack>

                    @if (GetCardiologyMedicationsByCategory(CardiologyMedicationCategory.Support).Any())
                    {
                        @foreach (var item in GetCardiologyMedicationsByCategory(CardiologyMedicationCategory.Support))
                        {
                            <MudPaper Elevation="0" Outlined="true" Class="pa-2">
                                <MudGrid Spacing="2" AlignItems="AlignItems.Center">
                                    <MudItem xs="12" sm="7">
                                        <MudSelect T="int"
                                                   Label="Medication"
                                                   Variant="Variant.Outlined"
                                                   Margin="Margin.Dense"
                                                   FullWidth="true"
                                                   Disabled="@IsSaving"
                                                   Value="item.MedicationId"
                                                   ValueChanged="@(value => HandleMedicationIdChanged(item, value))">
                                            <MudSelectItem T="int" Value="0">Select Medication</MudSelectItem>

                                            @foreach (var medication in Medications)
                                            {
                                                <MudSelectItem T="int" Value="@medication.Id">
                                                    @medication.Name
                                                </MudSelectItem>
                                            }
                                        </MudSelect>

                                        @if (!string.IsNullOrWhiteSpace(GetMedicationFrequency(item.MedicationId)))
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                Default frequency: @GetMedicationFrequency(item.MedicationId)
                                            </MudText>
                                        }
                                    </MudItem>

                                    <MudItem xs="8" sm="3">
                                        <MudNumericField T="decimal?"
                                                         Label="Dose"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         FullWidth="true"
                                                         Disabled="@IsSaving"
                                                         Value="item.Dose"
                                                         ValueChanged="@(value => HandleMedicationDoseChanged(item, value))" />
                                    </MudItem>

                                    <MudItem xs="4" sm="2">
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Error"
                                                   Size="Size.Small"
                                                   FullWidth="true"
                                                   Disabled="@IsSaving"
                                                   OnClick="@(() => HandleRemoveCardiologyMedicationAsync(item))">
                                            Remove
                                        </MudButton>
                                    </MudItem>
                                </MudGrid>
                            </MudPaper>
                        }
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Normal" Variant="Variant.Outlined">
                            No support medications added yet.
                        </MudAlert>
                    }
                </MudStack>
            </MudPaper>

            @* This block edits other cardiovascular medication rows. *@
            <MudPaper Elevation="0" Outlined="true" Class="pa-3">
                <MudStack Spacing="2">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2">
                        <MudText Typo="Typo.overline" Color="Color.Secondary">
                            Cardiovascular Medications
                        </MudText>

                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   Disabled="@IsSaving"
                                   OnClick="@(() => HandleAddCardiologyMedicationAsync(CardiologyMedicationCategory.Cardiovascular))">
                            Add
                        </MudButton>
                    </MudStack>

                    @if (GetCardiologyMedicationsByCategory(CardiologyMedicationCategory.Cardiovascular).Any())
                    {
                        @foreach (var item in GetCardiologyMedicationsByCategory(CardiologyMedicationCategory.Cardiovascular))
                        {
                            <MudPaper Elevation="0" Outlined="true" Class="pa-2">
                                <MudGrid Spacing="2" AlignItems="AlignItems.Center">
                                    <MudItem xs="12" sm="7">
                                        <MudSelect T="int"
                                                   Label="Medication"
                                                   Variant="Variant.Outlined"
                                                   Margin="Margin.Dense"
                                                   FullWidth="true"
                                                   Disabled="@IsSaving"
                                                   Value="item.MedicationId"
                                                   ValueChanged="@(value => HandleMedicationIdChanged(item, value))">
                                            <MudSelectItem T="int" Value="0">Select Medication</MudSelectItem>

                                            @foreach (var medication in Medications)
                                            {
                                                <MudSelectItem T="int" Value="@medication.Id">
                                                    @medication.Name
                                                </MudSelectItem>
                                            }
                                        </MudSelect>

                                        @if (!string.IsNullOrWhiteSpace(GetMedicationFrequency(item.MedicationId)))
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                Default frequency: @GetMedicationFrequency(item.MedicationId)
                                            </MudText>
                                        }
                                    </MudItem>

                                    <MudItem xs="8" sm="3">
                                        <MudNumericField T="decimal?"
                                                         Label="Dose"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         FullWidth="true"
                                                         Disabled="@IsSaving"
                                                         Value="item.Dose"
                                                         ValueChanged="@(value => HandleMedicationDoseChanged(item, value))" />
                                    </MudItem>

                                    <MudItem xs="4" sm="2">
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Error"
                                                   Size="Size.Small"
                                                   FullWidth="true"
                                                   Disabled="@IsSaving"
                                                   OnClick="@(() => HandleRemoveCardiologyMedicationAsync(item))">
                                            Remove
                                        </MudButton>
                                    </MudItem>
                                </MudGrid>
                            </MudPaper>
                        }
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Normal" Variant="Variant.Outlined">
                            No cardiovascular medications added yet.
                        </MudAlert>
                    }
                </MudStack>
            </MudPaper>

            @* Save and reload buttons are intentionally not here.
               The fixed PatientDetailsActionBar controls saving and reloading. *@
        </MudStack>
    </EditForm>
}
else
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
        Cardiology section is not ready for this patient.
    </MudAlert>
}

@code {
    // The parent page passes the current patient object into this component.
    [Parameter, EditorRequired]
    public Patient? Patient { get; set; }

    // The parent page passes the reusable medication catalog for dropdown lists.
    [Parameter, EditorRequired]
    public List<Medication> Medications { get; set; } = new();

    // The parent page passes the EditContext so dirty tracking stays in one place.
    [Parameter, EditorRequired]
    public EditContext CardiologyEditContext { get; set; } = default!;

    // This flag disables buttons while the parent page is saving data.
    [Parameter]
    public bool IsSaving { get; set; }

    // The parent page provides the method that adds a medication row to the section.
    [Parameter, EditorRequired]
    public EventCallback<CardiologyMedicationCategory> OnAddCardiologyMedication { get; set; }

    // The parent page provides the method that removes a medication row from the section.
    [Parameter, EditorRequired]
    public EventCallback<CardiologyMedication> OnRemoveCardiologyMedication { get; set; }

    // This callback lets the parent page replace its medication catalog list
    // after the shared MedicationsManager adds or edits a catalog item.
    [Parameter]
    public EventCallback<List<Medication>> OnMedicationsChanged { get; set; }

    // This callback lets the component forward status messages to the parent page.
    [Parameter]
    public EventCallback<string> OnStatusMessage { get; set; }

    // This helper is the key part of dirty tracking for MudBlazor fields.
    // MudBlazor updates the value correctly, but we also manually notify the EditContext
    // so PatientDetails.razor can enable the bottom Save button.
    private void NotifyCardiologyFieldChanged(object model, string propertyName)
    {
        CardiologyEditContext.NotifyFieldChanged(new FieldIdentifier(model, propertyName));
    }

    // Basic hemodynamic fields.
    // SBP and DBP also refresh the calculated MAP display because MAP is calculated from them.
    private void HandleHeartRateChanged(int? value)
    {
        if (Patient?.Cardiology is null)
            return;

        Patient.Cardiology.HeartRate = value;
        NotifyCardiologyFieldChanged(Patient.Cardiology, nameof(Patient.Cardiology.HeartRate));
    }

    private void HandleSystolicBloodPressureChanged(int? value)
    {
        if (Patient?.Cardiology is null)
            return;

        Patient.Cardiology.SystolicBloodPressure = value;
        NotifyCardiologyFieldChanged(Patient.Cardiology, nameof(Patient.Cardiology.SystolicBloodPressure));
    }

    private void HandleDiastolicBloodPressureChanged(int? value)
    {
        if (Patient?.Cardiology is null)
            return;

        Patient.Cardiology.DiastolicBloodPressure = value;
        NotifyCardiologyFieldChanged(Patient.Cardiology, nameof(Patient.Cardiology.DiastolicBloodPressure));
    }

    // Volume and echo clue fields.
    private void HandleCentralVenousPressureChanged(int? value)
    {
        if (Patient?.Cardiology is null)
            return;

        Patient.Cardiology.CentralVenousPressure = value;
        NotifyCardiologyFieldChanged(Patient.Cardiology, nameof(Patient.Cardiology.CentralVenousPressure));
    }

    private void HandleInferiorVenaCavaChanged(int? value)
    {
        if (Patient?.Cardiology is null)
            return;

        Patient.Cardiology.InferiorVenaCava = value;
        NotifyCardiologyFieldChanged(Patient.Cardiology, nameof(Patient.Cardiology.InferiorVenaCava));
    }

    // Advanced hemodynamic fields.
    private void HandleCardiacIndexChanged(decimal? value)
    {
        if (Patient?.Cardiology is null)
            return;

        Patient.Cardiology.CardiacIndex = value;
        NotifyCardiologyFieldChanged(Patient.Cardiology, nameof(Patient.Cardiology.CardiacIndex));
    }

    private void HandleCardiacOutputChanged(decimal? value)
    {
        if (Patient?.Cardiology is null)
            return;

        Patient.Cardiology.CardiacOutput = value;
        NotifyCardiologyFieldChanged(Patient.Cardiology, nameof(Patient.Cardiology.CardiacOutput));
    }

    private void HandleSystemicVascularResistanceChanged(int? value)
    {
        if (Patient?.Cardiology is null)
            return;

        Patient.Cardiology.SystemicVascularResistance = value;
        NotifyCardiologyFieldChanged(Patient.Cardiology, nameof(Patient.Cardiology.SystemicVascularResistance));
    }

    private void HandlePulmonaryCapillaryWedgePressureChanged(int? value)
    {
        if (Patient?.Cardiology is null)
            return;

        Patient.Cardiology.PulmonaryCapillaryWedgePressure = value;
        NotifyCardiologyFieldChanged(Patient.Cardiology, nameof(Patient.Cardiology.PulmonaryCapillaryWedgePressure));
    }

    // Free-text notes also need explicit notification.
    private void HandleNotesChanged(string? value)
    {
        if (Patient?.Cardiology is null)
            return;

        Patient.Cardiology.Notes = value;
        NotifyCardiologyFieldChanged(Patient.Cardiology, nameof(Patient.Cardiology.Notes));
    }

    // Medication row changes are patient-data changes, so they should mark Cardiology dirty.
    // The shared medication catalog manager is different: it changes the catalog only,
    // so it intentionally does not call this helper.
    private void HandleMedicationIdChanged(CardiologyMedication item, int value)
    {
        item.MedicationId = value;
        NotifyCardiologyFieldChanged(item, nameof(item.MedicationId));
    }

    private void HandleMedicationDoseChanged(CardiologyMedication item, decimal? value)
    {
        item.Dose = value;
        NotifyCardiologyFieldChanged(item, nameof(item.Dose));
    }

    // This method asks the parent page to add a new cardiology medication row.
    private async Task HandleAddCardiologyMedicationAsync(CardiologyMedicationCategory category)
    {
        await OnAddCardiologyMedication.InvokeAsync(category);
    }

    // This method asks the parent page to remove one cardiology medication row.
    private async Task HandleRemoveCardiologyMedicationAsync(CardiologyMedication item)
    {
        await OnRemoveCardiologyMedication.InvokeAsync(item);
    }

    // This method receives the refreshed medication catalog from MedicationsManager.
    // It updates the local list immediately and then informs the parent page too.
    private async Task HandleMedicationsChangedAsync(List<Medication> refreshedMedications)
    {
        Medications = refreshedMedications ?? new List<Medication>();
        await OnMedicationsChanged.InvokeAsync(Medications);
        await InvokeAsync(StateHasChanged);
    }

    // This method forwards a success message to the parent page when available.
    private async Task HandleStatusMessageAsync(string message)
    {
        await OnStatusMessage.InvokeAsync(message);
    }

    // This helper returns the rows for only one medication category at a time.
    private IEnumerable<CardiologyMedication> GetCardiologyMedicationsByCategory(CardiologyMedicationCategory category)
    {
        if (Patient?.Cardiology?.Medications is null)
            return Enumerable.Empty<CardiologyMedication>();

        return Patient.Cardiology.Medications
            .Where(x => x.Category == category)
            .ToList();
    }

    // This helper looks up the default frequency text for the selected medication.
    private string? GetMedicationFrequency(int medicationId)
    {
        if (medicationId <= 0)
            return null;

        return Medications
            .FirstOrDefault(x => x.Id == medicationId)
            ?.Frequency;
    }
}