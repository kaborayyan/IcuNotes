@using IcuNotes.Models
@using Microsoft.AspNetCore.Components.Forms

@* This component contains the Cardiology section UI.
   Saving and reloading are controlled by the fixed bottom bar in PatientDetails.razor.

   Important:
   - This component displays and edits cardiology data only.
   - It does not directly save to the database.
   - The parent PatientDetails.razor page owns saving, dirty tracking, and reload.
   - This update is UI-only: Bootstrap cards, compact spacing, and floating labels. *@

@if (Patient?.Cardiology is not null)
{
    <div class="card shadow-sm">
        <div class="card-body p-2 p-sm-3">
            @* Small section heading.
               The saved/unsaved message now lives in the fixed bottom bar in PatientDetails.razor. *@
            <h6 class="card-title mb-2">Cardiology</h6>
                        
            @* This form edits the cardiology fields.
               The EditContext still allows PatientDetails.razor to detect field changes. *@
            <EditForm EditContext="CardiologyEditContext">
                <DataAnnotationsValidator />
                <ValidationSummary />

                @* Core daily cardiovascular observations.
                   HR, SBP, and DBP are short numeric values, so they are kept narrow on mobile too. *@
                <div class="card mb-2">
                    <div class="card-body p-2 p-sm-3">
                        <h6 class="mb-2 small text-uppercase text-muted">Basic Hemodynamics</h6>

                        <div class="row g-2">
                            <div class="col-4">
                                <div class="form-floating">
                                    <InputNumber id="cardiologyHeartRate"
                                                 TValue="int?"
                                                 class="form-control"
                                                 placeholder=" "
                                                 @bind-Value="Patient.Cardiology.HeartRate" />
                                    <label for="cardiologyHeartRate">HR</label>
                                </div>
                            </div>

                            <div class="col-4">
                                <div class="form-floating">
                                    <InputNumber id="cardiologySbp"
                                                 TValue="int?"
                                                 class="form-control"
                                                 placeholder=" "
                                                 @bind-Value="Patient.Cardiology.SystolicBloodPressure" />
                                    <label for="cardiologySbp">SBP</label>
                                </div>
                            </div>

                            <div class="col-4">
                                <div class="form-floating">
                                    <InputNumber id="cardiologyDbp"
                                                 TValue="int?"
                                                 class="form-control"
                                                 placeholder=" "
                                                 @bind-Value="Patient.Cardiology.DiastolicBloodPressure" />
                                    <label for="cardiologyDbp">DBP</label>
                                </div>
                            </div>
                        </div>

                        @* MAP is calculated in Cardiology.cs.
                           It is not directly edited and not stored in the database. *@
                        <div class="alert alert-light border p-2 mt-2 mb-0 small">
                            <span class="fw-semibold">MAP:</span>

                            @if (Patient.Cardiology.MeanArterialPressure.HasValue)
                            {
                                <span>@Patient.Cardiology.MeanArterialPressure.Value</span>
                            }
                            else
                            {
                                <span class="text-muted">Enter SBP and DBP.</span>
                            }
                        </div>
                    </div>
                </div>

                @* Additional common ICU cardiology measurements. *@
                <div class="card mb-2">
                    <div class="card-body p-2 p-sm-3">
                        <h6 class="mb-2 small text-uppercase text-muted">Volume / Echo Clues</h6>

                        <div class="row g-2">
                            <div class="col-6">
                                <div class="form-floating">
                                    <InputNumber id="cardiologyCvp"
                                                 TValue="int?"
                                                 class="form-control"
                                                 placeholder=" "
                                                 @bind-Value="Patient.Cardiology.CentralVenousPressure" />
                                    <label for="cardiologyCvp">CVP</label>
                                </div>
                            </div>

                            <div class="col-6">
                                <div class="form-floating">
                                    <InputNumber id="cardiologyIvc"
                                                 TValue="int?"
                                                 class="form-control"
                                                 placeholder=" "
                                                 @bind-Value="Patient.Cardiology.InferiorVenaCava" />
                                    <label for="cardiologyIvc">IVC</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                @* Advanced hemodynamic values.
                   These are nullable because they are only used in selected patients. *@
                <div class="card mb-2">
                    <div class="card-body p-2 p-sm-3">
                        <h6 class="mb-2 small text-uppercase text-muted">Advanced Hemodynamics</h6>

                        <div class="row g-2">
                            <div class="col-6">
                                <div class="form-floating">
                                    <InputNumber id="cardiologyCi"
                                                 TValue="decimal?"
                                                 class="form-control"
                                                 placeholder=" "
                                                 @bind-Value="Patient.Cardiology.CardiacIndex" />
                                    <label for="cardiologyCi">CI</label>
                                </div>
                            </div>

                            <div class="col-6">
                                <div class="form-floating">
                                    <InputNumber id="cardiologyCo"
                                                 TValue="decimal?"
                                                 class="form-control"
                                                 placeholder=" "
                                                 @bind-Value="Patient.Cardiology.CardiacOutput" />
                                    <label for="cardiologyCo">CO</label>
                                </div>
                            </div>

                            <div class="col-6">
                                <div class="form-floating">
                                    <InputNumber id="cardiologySvr"
                                                 TValue="int?"
                                                 class="form-control"
                                                 placeholder=" "
                                                 @bind-Value="Patient.Cardiology.SystemicVascularResistance" />
                                    <label for="cardiologySvr">SVR</label>
                                </div>
                            </div>

                            <div class="col-6">
                                <div class="form-floating">
                                    <InputNumber id="cardiologyPcwp"
                                                 TValue="int?"
                                                 class="form-control"
                                                 placeholder=" "
                                                 @bind-Value="Patient.Cardiology.PulmonaryCapillaryWedgePressure" />
                                    <label for="cardiologyPcwp">PCWP</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                @* Free text area for extra cardiology details that do not deserve
                   their own database field yet. *@
                <div class="card mb-2">
                    <div class="card-body p-2 p-sm-3">
                        <div class="form-floating">
                            <InputTextArea id="cardiologyNotes"
                                           class="form-control"
                                           style="height: 7rem"
                                           placeholder=" "
                                           @bind-Value="Patient.Cardiology.Notes" />
                            <label for="cardiologyNotes">Cardiology Notes</label>
                        </div>

                        <div class="form-text small">
                            Examples: poor LV function, post PCI, temporary pacemaker, severe MR, echo findings.
                        </div>
                    </div>
                </div>

                @* This reusable manager handles adding and editing shared catalog medications.
               Cardiology stays focused only on cardiology-specific medication rows. *@
                <div class="mb-2">
                    <MedicationsManager Medications="Medications"
                                        IsDisabled="IsSaving"
                                        OnMedicationsChanged="HandleMedicationsChangedAsync"
                                        OnStatusMessage="HandleStatusMessageAsync" />
                </div>

                @* This block edits vasopressor and inotrope medication rows. *@
                <div class="card mb-2">
                    <div class="card-body p-2 p-sm-3">
                        <div class="d-flex flex-column flex-sm-row gap-2 justify-content-between align-items-stretch align-items-sm-center mb-2">
                            <h6 class="mb-0 small text-uppercase text-muted">Support Medications</h6>

                            <button type="button"
                                    class="btn btn-outline-primary btn-sm"
                                    @onclick="() => HandleAddCardiologyMedicationAsync(CardiologyMedicationCategory.Support)"
                                    disabled="@IsSaving">
                                Add Support
                            </button>
                        </div>

                        @if (GetCardiologyMedicationsByCategory(CardiologyMedicationCategory.Support).Any())
                        {
                            @foreach (var item in GetCardiologyMedicationsByCategory(CardiologyMedicationCategory.Support))
                            {
                                <div class="border rounded p-2 mb-2">
                                    <div class="row g-2">
                                        <div class="col-12 col-sm-8">
                                            <div class="form-floating">
                                                <InputSelect class="form-select"
                                                             @bind-Value="item.MedicationId">
                                                    <option value="0">Select Medication</option>

                                                    @foreach (var medication in Medications)
                                                    {
                                                        <option value="@medication.Id">@medication.Name</option>
                                                    }
                                                </InputSelect>
                                                <label>Medication</label>
                                            </div>

                                            @if (!string.IsNullOrWhiteSpace(GetMedicationFrequency(item.MedicationId)))
                                            {
                                                <div class="form-text small">
                                                    Default frequency: @GetMedicationFrequency(item.MedicationId)
                                                </div>
                                            }
                                        </div>

                                        <div class="col-8 col-sm-3">
                                            <div class="form-floating">
                                                <InputNumber TValue="decimal?"
                                                             class="form-control"
                                                             placeholder=" "
                                                             @bind-Value="item.Dose" />
                                                <label>Dose</label>
                                            </div>
                                        </div>

                                        <div class="col-4 col-sm-1 d-grid">
                                            <button type="button"
                                                    class="btn btn-outline-danger btn-sm"
                                                    @onclick="() => HandleRemoveCardiologyMedicationAsync(item)"
                                                    disabled="@IsSaving">
                                                Remove
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="alert alert-light border p-2 mb-0 small">
                                No support medications added yet.
                            </div>
                        }
                    </div>
                </div>

                @* This block edits other cardiovascular medication rows. *@
                <div class="card mb-0">
                    <div class="card-body p-2 p-sm-3">
                        <div class="d-flex flex-column flex-sm-row gap-2 justify-content-between align-items-stretch align-items-sm-center mb-2">
                            <h6 class="mb-0 small text-uppercase text-muted">Cardiovascular Medications</h6>

                            <button type="button"
                                    class="btn btn-outline-primary btn-sm"
                                    @onclick="() => HandleAddCardiologyMedicationAsync(CardiologyMedicationCategory.Cardiovascular)"
                                    disabled="@IsSaving">
                                Add CV Med
                            </button>
                        </div>

                        @if (GetCardiologyMedicationsByCategory(CardiologyMedicationCategory.Cardiovascular).Any())
                        {
                            @foreach (var item in GetCardiologyMedicationsByCategory(CardiologyMedicationCategory.Cardiovascular))
                            {
                                <div class="border rounded p-2 mb-2">
                                    <div class="row g-2">
                                        <div class="col-12 col-sm-8">
                                            <div class="form-floating">
                                                <InputSelect class="form-select"
                                                             @bind-Value="item.MedicationId">
                                                    <option value="0">Select Medication</option>

                                                    @foreach (var medication in Medications)
                                                    {
                                                        <option value="@medication.Id">@medication.Name</option>
                                                    }
                                                </InputSelect>
                                                <label>Medication</label>
                                            </div>

                                            @if (!string.IsNullOrWhiteSpace(GetMedicationFrequency(item.MedicationId)))
                                            {
                                                <div class="form-text small">
                                                    Default frequency: @GetMedicationFrequency(item.MedicationId)
                                                </div>
                                            }
                                        </div>

                                        <div class="col-8 col-sm-3">
                                            <div class="form-floating">
                                                <InputNumber TValue="decimal?"
                                                             class="form-control"
                                                             placeholder=" "
                                                             @bind-Value="item.Dose" />
                                                <label>Dose</label>
                                            </div>
                                        </div>

                                        <div class="col-4 col-sm-1 d-grid">
                                            <button type="button"
                                                    class="btn btn-outline-danger btn-sm"
                                                    @onclick="() => HandleRemoveCardiologyMedicationAsync(item)"
                                                    disabled="@IsSaving">
                                                Remove
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="alert alert-light border p-2 mb-0 small">
                                No cardiovascular medications added yet.
                            </div>
                        }
                    </div>
                </div>

                @* Save and reload buttons were intentionally removed from this section.
                   The fixed bottom bar in PatientDetails.razor now controls saving and reloading. *@
            </EditForm>
        </div>
    </div>
}
else
{
    <div class="alert alert-warning p-2">
        Cardiology section is not ready for this patient.
    </div>
}

@code {
    // The parent page passes the current patient object into this component.
    [Parameter, EditorRequired]
    public Patient? Patient { get; set; }

    // The parent page passes the reusable medication catalog for dropdown lists.
    [Parameter, EditorRequired]
    public List<Medication> Medications { get; set; } = new();

    // The parent page passes the EditContext so dirty tracking stays in one place.
    [Parameter, EditorRequired]
    public EditContext CardiologyEditContext { get; set; } = default!;

    // This flag disables buttons while the parent page is saving data.
    [Parameter]
    public bool IsSaving { get; set; }

    // The parent page provides the method that adds a medication row to the section.
    [Parameter, EditorRequired]
    public EventCallback<CardiologyMedicationCategory> OnAddCardiologyMedication { get; set; }

    // The parent page provides the method that removes a medication row from the section.
    [Parameter, EditorRequired]
    public EventCallback<CardiologyMedication> OnRemoveCardiologyMedication { get; set; }

    // This callback lets the parent page replace its medication catalog list
    // after the shared MedicationsManager adds or edits a catalog item.
    [Parameter]
    public EventCallback<List<Medication>> OnMedicationsChanged { get; set; }

    // This callback lets the component forward status messages to the parent page.
    [Parameter]
    public EventCallback<string> OnStatusMessage { get; set; }

    // This method asks the parent page to add a new cardiology medication row.
    private async Task HandleAddCardiologyMedicationAsync(CardiologyMedicationCategory category)
    {
        await OnAddCardiologyMedication.InvokeAsync(category);
    }

    // This method asks the parent page to remove one cardiology medication row.
    private async Task HandleRemoveCardiologyMedicationAsync(CardiologyMedication item)
    {
        await OnRemoveCardiologyMedication.InvokeAsync(item);
    }

    // This method receives the refreshed medication catalog from MedicationsManager.
    // It updates the local list immediately and then informs the parent page too.
    private async Task HandleMedicationsChangedAsync(List<Medication> refreshedMedications)
    {
        Medications = refreshedMedications ?? new List<Medication>();
        await OnMedicationsChanged.InvokeAsync(Medications);
        await InvokeAsync(StateHasChanged);
    }

    // This method forwards a success message to the parent page when available.
    private async Task HandleStatusMessageAsync(string message)
    {
        await OnStatusMessage.InvokeAsync(message);
    }

    // This helper returns the rows for only one medication category at a time.
    private IEnumerable<CardiologyMedication> GetCardiologyMedicationsByCategory(CardiologyMedicationCategory category)
    {
        if (Patient?.Cardiology?.Medications is null)
            return Enumerable.Empty<CardiologyMedication>();

        return Patient.Cardiology.Medications
            .Where(x => x.Category == category)
            .ToList();
    }

    // This helper looks up the default frequency text for the selected medication.
    private string? GetMedicationFrequency(int medicationId)
    {
        if (medicationId <= 0)
            return null;

        return Medications
            .FirstOrDefault(x => x.Id == medicationId)
            ?.Frequency;
    }
}