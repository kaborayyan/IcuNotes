@page "/not-found"
@layout MainLayout

<!--
    Simple MudBlazor Not Found page.

    This page is shown when the router cannot find a matching page.
    It is UI-only:
    - no database access
    - no services
    - no JavaScript
    - no Bootstrap classes
-->
<MudContainer MaxWidth="MaxWidth.Small" Class="not-found-container">

    <MudPaper Elevation="1" Class="not-found-card">

        <MudStack Spacing="3" AlignItems="AlignItems.Center">

            <!--
                A clear icon helps the user understand that this is a navigation problem,
                not a patient-data problem.
            -->
            <MudIcon Icon="@Icons.Material.Filled.SearchOff"
                     Color="Color.Warning"
                     Size="Size.Large" />

            <MudText Typo="Typo.h5" Align="Align.Center">
                Page not found
            </MudText>

            <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary">
                Sorry, the page you are looking for does not exist or was moved.
            </MudText>

            <MudStack Direction="Row" Spacing="2" Justify="Justify.Center" Class="not-found-actions">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Href="/">
                    Home
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           Href="/patients">
                    Active Patients
                </MudButton>
            </MudStack>

        </MudStack>

    </MudPaper>

</MudContainer>

<style>
    .not-found-container {
        padding-top: 2rem;
    }

    .not-found-card {
        padding: 1.5rem;
        border-radius: 16px;
    }

    .not-found-actions {
        flex-wrap: wrap;
    }
</style>
