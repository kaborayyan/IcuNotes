@using IcuNotes.Models
@using Microsoft.AspNetCore.Components.Forms

@* This component contains the Summary section UI.
   It edits the patient's long text notes but lets the parent page keep the save logic. *@
@if (Patient is not null)
{
    @* This block shows the Summary header and whether the section has unsaved changes. *@
    <div>
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">Patient Summary</h5>

            @if (IsSummaryDirty)
            {
                <span class="text-warning fw-semibold">You have unsaved summary changes.</span>
            }
            else
            {
                <span class="text-muted">Summary is saved.</span>
            }
        </div>

        @* This form edits the summary fields and sends the save action back to the parent page. *@
        <EditForm EditContext="SummaryEditContext" OnValidSubmit="HandleSaveSummaryAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />

            @* This field stores the main free-text clinical history and summary notes. *@
            <div class="mb-3">
                <label class="form-label">Combined History</label>
                <InputTextArea class="form-control"
                               rows="6"
                               @bind-Value="Patient.PatientSummary!.CombinedHistory" />
            </div>

            @* This field stores reminders, plans, or tasks related to the patient. *@
            <div class="mb-3">
                <label class="form-label">To Do</label>
                <InputTextArea class="form-control"
                               rows="5"
                               @bind-Value="Patient.PatientSummary!.EventsTodo" />
            </div>

            @* These buttons let the user either save just the Summary section or reload the patient data. *@
            <div class="d-flex gap-2">
                <button type="submit"
                        class="btn btn-primary"
                        disabled="@IsSaving">
                    @(IsSaving ? "Saving..." : "Save Summary Changes")
                </button>

                <button type="button"
                        class="btn btn-secondary"
                        @onclick="HandleReloadAsync"
                        disabled="@IsSaving">
                    Reload
                </button>
            </div>
        </EditForm>
    </div>
}

@code {
    // The parent page passes the current patient object into this component.
    [Parameter, EditorRequired]
    public Patient? Patient { get; set; }

    // The parent page passes the EditContext so dirty tracking still stays in one place.
    [Parameter, EditorRequired]
    public EditContext SummaryEditContext { get; set; } = default!;

    // This flag tells the component whether to show the unsaved warning for Summary.
    [Parameter]
    public bool IsSummaryDirty { get; set; }

    // This flag disables buttons while the parent page is saving data.
    [Parameter]
    public bool IsSaving { get; set; }

    // The parent page provides the actual save method for the Summary section.
    [Parameter, EditorRequired]
    public EventCallback OnSaveSummary { get; set; }

    // The parent page provides the reload method so this component stays UI-focused.
    [Parameter, EditorRequired]
    public EventCallback OnReload { get; set; }

    // This method calls the parent page when the Summary form is submitted.
    private async Task HandleSaveSummaryAsync()
    {
        await OnSaveSummary.InvokeAsync();
    }

    // This method asks the parent page to reload the patient data.
    private async Task HandleReloadAsync()
    {
        await OnReload.InvokeAsync();
    }
}