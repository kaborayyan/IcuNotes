@using IcuNotes.Models
@using Microsoft.AspNetCore.Components.Forms
@using MudBlazor
@using System.Runtime.CompilerServices

@* This component contains the Gastrointestinal Tract section UI.
   Saving, reloading, and dirty tracking are controlled by PatientDetails.razor.

   Important:
   - This component edits GIT data only.
   - It does not directly save to the database.
   - The parent page owns saving, dirty tracking, and reload.
   - This update is UI-only: Bootstrap has been replaced with MudBlazor. *@

@if (Patient?.GastroIntestinal is not null)
{
    <EditForm EditContext="GastroIntestinalEditContext">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <MudStack Spacing="3">

            @* Section heading.
               The fixed PatientDetailsActionBar still handles Save and Reload. *@
            <MudPaper Elevation="0" Outlined="true" Class="pa-3">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.h6">Gastrointestinal</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Feeding route, bowel motion, abdomen, fluids, formula, and GIT medications.
                    </MudText>
                </MudStack>
            </MudPaper>

            @* Main GIT assessment fields.
               Short numeric values are grouped together to save vertical space on mobile. *@
            <MudPaper Elevation="0" Outlined="true" Class="pa-3">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.overline" Color="Color.Secondary">
                        Assessment
                    </MudText>

                    <MudGrid Spacing="2">
                        <MudItem xs="12" sm="6">
                            <MudSelect T="string"
                                       Label="Feeding route"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       FullWidth="true"
                                       Disabled="@IsSaving"
                                       Value="@Patient.GastroIntestinal.FeedingRoute"
                                       ValueChanged="UpdateFeedingRoute">
                                @foreach (var route in FeedingRouteOptions)
                                {
                                    <MudSelectItem T="string" Value="@route">
                                        @route
                                    </MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>

                        <MudItem xs="12" sm="6">
                            <MudDatePicker Label="Last bowel motion"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           Disabled="@IsSaving"
                                           Date="Patient.GastroIntestinal.LastBowelMotionDate"
                                           DateChanged="UpdateLastBowelMotionDate" />
                        </MudItem>

                        <MudItem xs="6">
                            <MudNumericField T="int?"
                                             Label="IAP"
                                             HelperText="mmHg"
                                             Variant="Variant.Outlined"
                                             Margin="Margin.Dense"
                                             FullWidth="true"
                                             Disabled="@IsSaving"
                                             Value="Patient.GastroIntestinal.IntraAbdominalPressure"
                                             ValueChanged="UpdateIntraAbdominalPressure" />
                        </MudItem>

                        <MudItem xs="6">
                            <MudNumericField T="int?"
                                             Label="Girth"
                                             HelperText="cm"
                                             Variant="Variant.Outlined"
                                             Margin="Margin.Dense"
                                             FullWidth="true"
                                             Disabled="@IsSaving"
                                             Value="Patient.GastroIntestinal.AbdominalGirth"
                                             ValueChanged="UpdateAbdominalGirth" />
                        </MudItem>
                    </MudGrid>

                    <MudSwitch T="bool"
                               Label="GI bleeding"
                               Color="Color.Error"
                               Disabled="@IsSaving"
                               Value="Patient.GastroIntestinal.HasGiBleeding"
                               ValueChanged="UpdateHasGiBleeding" />

                    <MudTextField T="string"
                                  Label="GIT notes"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Lines="5"
                                  FullWidth="true"
                                  Disabled="@IsSaving"
                                  Value="@Patient.GastroIntestinal.GitNotes"
                                  ValueChanged="UpdateGitNotes" />
                </MudStack>
            </MudPaper>

            @* This reusable manager handles adding and editing shared catalog items.
               The same catalog is reused for formulas, IV fluids, and medications. *@
            <MudPaper Elevation="0" Outlined="true" Class="pa-3">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.overline" Color="Color.Secondary">
                        Shared Catalog
                    </MudText>

                    <MedicationsManager Medications="Medications"
                                        IsDisabled="IsSaving"
                                        OnMedicationsChanged="HandleMedicationsChangedAsync"
                                        OnStatusMessage="HandleStatusMessageAsync" />
                </MudStack>
            </MudPaper>

            @* Formula rows. *@
            <MudPaper Elevation="0" Outlined="true" Class="pa-3">
                <MudStack Spacing="2">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2">
                        <MudText Typo="Typo.overline" Color="Color.Secondary">
                            Formula
                        </MudText>

                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   Disabled="@IsSaving"
                                   OnClick="@(() => HandleAddGastroIntestinalItemAsync(GastroIntestinalItemCategory.Formula))">
                            Add
                        </MudButton>
                    </MudStack>

                    @if (GetGastroIntestinalItemsByCategory(GastroIntestinalItemCategory.Formula).Any())
                    {
                        @foreach (var item in GetGastroIntestinalItemsByCategory(GastroIntestinalItemCategory.Formula))
                        {
                            <MudPaper Elevation="0" Outlined="true" Class="pa-2" @key="item">
                                <MudGrid Spacing="2">
                                    <MudItem xs="12" sm="7">
                                        @RenderSearchableCatalogPicker(item, "Search formula...")
                                    </MudItem>

                                    <MudItem xs="8" sm="3">
                                        <MudNumericField T="decimal?"
                                                         Label="Rate"
                                                         HelperText="ml/hr"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         FullWidth="true"
                                                         Disabled="@IsSaving"
                                                         Value="item.DoseOrRate"
                                                         ValueChanged="@((decimal? value) => UpdateGastroIntestinalItemDoseOrRate(item, value))" />
                                    </MudItem>

                                    <MudItem xs="4" sm="2">
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Error"
                                                   Size="Size.Small"
                                                   FullWidth="true"
                                                   Disabled="@IsSaving"
                                                   OnClick="@(() => HandleRemoveGastroIntestinalItemAsync(item))">
                                            Remove
                                        </MudButton>
                                    </MudItem>
                                </MudGrid>
                            </MudPaper>
                        }
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Normal" Variant="Variant.Outlined">
                            No formula rows added yet.
                        </MudAlert>
                    }
                </MudStack>
            </MudPaper>

            @* IV fluid rows. *@
            <MudPaper Elevation="0" Outlined="true" Class="pa-3">
                <MudStack Spacing="2">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2">
                        <MudText Typo="Typo.overline" Color="Color.Secondary">
                            IV Fluids
                        </MudText>

                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   Disabled="@IsSaving"
                                   OnClick="@(() => HandleAddGastroIntestinalItemAsync(GastroIntestinalItemCategory.IVFluid))">
                            Add
                        </MudButton>
                    </MudStack>

                    @if (GetGastroIntestinalItemsByCategory(GastroIntestinalItemCategory.IVFluid).Any())
                    {
                        @foreach (var item in GetGastroIntestinalItemsByCategory(GastroIntestinalItemCategory.IVFluid))
                        {
                            <MudPaper Elevation="0" Outlined="true" Class="pa-2" @key="item">
                                <MudGrid Spacing="2">
                                    <MudItem xs="12" sm="7">
                                        @RenderSearchableCatalogPicker(item, "Search IV fluid...")
                                    </MudItem>

                                    <MudItem xs="8" sm="3">
                                        <MudNumericField T="decimal?"
                                                         Label="Rate"
                                                         HelperText="ml/hr"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         FullWidth="true"
                                                         Disabled="@IsSaving"
                                                         Value="item.DoseOrRate"
                                                         ValueChanged="@((decimal? value) => UpdateGastroIntestinalItemDoseOrRate(item, value))" />
                                    </MudItem>

                                    <MudItem xs="4" sm="2">
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Error"
                                                   Size="Size.Small"
                                                   FullWidth="true"
                                                   Disabled="@IsSaving"
                                                   OnClick="@(() => HandleRemoveGastroIntestinalItemAsync(item))">
                                            Remove
                                        </MudButton>
                                    </MudItem>
                                </MudGrid>
                            </MudPaper>
                        }
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Normal" Variant="Variant.Outlined">
                            No IV fluid rows added yet.
                        </MudAlert>
                    }
                </MudStack>
            </MudPaper>

            @* Other GIT medication rows. *@
            <MudPaper Elevation="0" Outlined="true" Class="pa-3">
                <MudStack Spacing="2">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2">
                        <MudText Typo="Typo.overline" Color="Color.Secondary">
                            Other GIT Medications
                        </MudText>

                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   Disabled="@IsSaving"
                                   OnClick="@(() => HandleAddGastroIntestinalItemAsync(GastroIntestinalItemCategory.OtherMedication))">
                            Add
                        </MudButton>
                    </MudStack>

                    @if (GetGastroIntestinalItemsByCategory(GastroIntestinalItemCategory.OtherMedication).Any())
                    {
                        @foreach (var item in GetGastroIntestinalItemsByCategory(GastroIntestinalItemCategory.OtherMedication))
                        {
                            <MudPaper Elevation="0" Outlined="true" Class="pa-2" @key="item">
                                <MudGrid Spacing="2">
                                    <MudItem xs="12" sm="7">
                                        @RenderSearchableCatalogPicker(item, "Search medication...")
                                    </MudItem>

                                    <MudItem xs="8" sm="3">
                                        <MudNumericField T="decimal?"
                                                         Label="Dose"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         FullWidth="true"
                                                         Disabled="@IsSaving"
                                                         Value="item.DoseOrRate"
                                                         ValueChanged="@((decimal? value) => UpdateGastroIntestinalItemDoseOrRate(item, value))" />
                                    </MudItem>

                                    <MudItem xs="4" sm="2">
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Error"
                                                   Size="Size.Small"
                                                   FullWidth="true"
                                                   Disabled="@IsSaving"
                                                   OnClick="@(() => HandleRemoveGastroIntestinalItemAsync(item))">
                                            Remove
                                        </MudButton>
                                    </MudItem>
                                </MudGrid>
                            </MudPaper>
                        }
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Normal" Variant="Variant.Outlined">
                            No other GIT medications added yet.
                        </MudAlert>
                    }
                </MudStack>
            </MudPaper>

            @* Save and reload buttons are intentionally not here.
               The fixed PatientDetailsActionBar controls saving and reloading. *@
        </MudStack>
    </EditForm>
}
else
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
        Gastrointestinal section is not ready for this patient.
    </MudAlert>
}

@code {
    // The parent page passes the current patient object into this component.
    [Parameter, EditorRequired]
    public Patient? Patient { get; set; }

    // The parent page passes the reusable medication catalog.
    // This catalog is reused for formulas, IV fluids, and medications.
    [Parameter, EditorRequired]
    public List<Medication> Medications { get; set; } = new();

    // The parent page passes the EditContext so dirty tracking stays in one place.
    [Parameter, EditorRequired]
    public EditContext GastroIntestinalEditContext { get; set; } = default!;

    // This flag disables buttons while the parent page is saving data.
    [Parameter]
    public bool IsSaving { get; set; }

    // The parent page provides the method that adds a new GIT row.
    [Parameter, EditorRequired]
    public EventCallback<GastroIntestinalItemCategory> OnAddGastroIntestinalItem { get; set; }

    // The parent page provides the method that removes a GIT row.
    [Parameter, EditorRequired]
    public EventCallback<GastroIntestinalItem> OnRemoveGastroIntestinalItem { get; set; }

    // This callback lets the parent page replace its medication catalog list
    // after MedicationsManager adds or edits a catalog item.
    [Parameter]
    public EventCallback<List<Medication>> OnMedicationsChanged { get; set; }

    // This callback lets the component forward status messages to the parent page.
    [Parameter]
    public EventCallback<string> OnStatusMessage { get; set; }

    // Fixed route choices requested by the user.
    // They are kept in the UI, not as a database enum.
    private static readonly string[] FeedingRouteOptions =
    {
        "Not inserted",
        "Oral",
        "NGT",
        "NJT",
        "OGT",
        "PEG"
    };

    // Each GIT row can have its own catalog search text.
    // The key is stable for saved rows by database Id and stable for new rows by object reference.
    private readonly Dictionary<string, string> searchTextByItemKey = new();

    // This method asks the parent page to add a new formula, IV fluid, or medication row.
    private async Task HandleAddGastroIntestinalItemAsync(GastroIntestinalItemCategory category)
    {
        await OnAddGastroIntestinalItem.InvokeAsync(category);

        // Adding a row changes patient-specific GIT data, so the bottom Save button should enable.
        NotifyGastroIntestinalFieldChanged(nameof(GastroIntestinal.Items));
    }

    // This method asks the parent page to remove one GIT row.
    private async Task HandleRemoveGastroIntestinalItemAsync(GastroIntestinalItem item)
    {
        searchTextByItemKey.Remove(GetItemKey(item));
        await OnRemoveGastroIntestinalItem.InvokeAsync(item);

        // Removing a row changes patient-specific GIT data, so the bottom Save button should enable.
        NotifyGastroIntestinalFieldChanged(nameof(GastroIntestinal.Items));
    }

    // This method receives the refreshed medication catalog from MedicationsManager.
    // It updates this component and then informs the parent page too.
    private async Task HandleMedicationsChangedAsync(List<Medication> refreshedMedications)
    {
        Medications = refreshedMedications ?? new List<Medication>();
        await OnMedicationsChanged.InvokeAsync(Medications);
        await InvokeAsync(StateHasChanged);
    }

    // This method forwards success messages from MedicationsManager to PatientDetails.
    private async Task HandleStatusMessageAsync(string message)
    {
        await OnStatusMessage.InvokeAsync(message);
    }

    // The methods below replace plain @bind-Value usage.
    // MudBlazor updates the model correctly, but explicit handlers let us also notify
    // the parent EditContext so PatientDetails.razor can enable the fixed bottom Save button.

    private void UpdateFeedingRoute(string? value)
    {
        if (Patient?.GastroIntestinal is null)
            return;

        Patient.GastroIntestinal.FeedingRoute = value;
        NotifyGastroIntestinalFieldChanged(nameof(GastroIntestinal.FeedingRoute));
    }

    private void UpdateLastBowelMotionDate(DateTime? value)
    {
        if (Patient?.GastroIntestinal is null)
            return;

        Patient.GastroIntestinal.LastBowelMotionDate = value;
        NotifyGastroIntestinalFieldChanged(nameof(GastroIntestinal.LastBowelMotionDate));
    }

    private void UpdateIntraAbdominalPressure(int? value)
    {
        if (Patient?.GastroIntestinal is null)
            return;

        Patient.GastroIntestinal.IntraAbdominalPressure = value;
        NotifyGastroIntestinalFieldChanged(nameof(GastroIntestinal.IntraAbdominalPressure));
    }

    private void UpdateAbdominalGirth(int? value)
    {
        if (Patient?.GastroIntestinal is null)
            return;

        Patient.GastroIntestinal.AbdominalGirth = value;
        NotifyGastroIntestinalFieldChanged(nameof(GastroIntestinal.AbdominalGirth));
    }

    private void UpdateHasGiBleeding(bool value)
    {
        if (Patient?.GastroIntestinal is null)
            return;

        Patient.GastroIntestinal.HasGiBleeding = value;
        NotifyGastroIntestinalFieldChanged(nameof(GastroIntestinal.HasGiBleeding));
    }

    private void UpdateGitNotes(string? value)
    {
        if (Patient?.GastroIntestinal is null)
            return;

        Patient.GastroIntestinal.GitNotes = value;
        NotifyGastroIntestinalFieldChanged(nameof(GastroIntestinal.GitNotes));
    }

    private void UpdateGastroIntestinalItemDoseOrRate(GastroIntestinalItem item, decimal? value)
    {
        item.DoseOrRate = value;
        NotifyGastroIntestinalItemFieldChanged(item, nameof(GastroIntestinalItem.DoseOrRate));
    }

    // Notify the EditContext about a field that belongs directly to the GIT section.
    // PatientDetails.razor listens to this EditContext and marks the GIT section dirty.
    private void NotifyGastroIntestinalFieldChanged(string fieldName)
    {
        if (Patient?.GastroIntestinal is null)
            return;

        GastroIntestinalEditContext.NotifyFieldChanged(
            new FieldIdentifier(Patient.GastroIntestinal, fieldName));
    }

    // Notify the EditContext about a field that belongs to one GIT row.
    // This is used for formula, IV fluid, and other GIT medication rows.
    private void NotifyGastroIntestinalItemFieldChanged(GastroIntestinalItem item, string fieldName)
    {
        GastroIntestinalEditContext.NotifyFieldChanged(
            new FieldIdentifier(item, fieldName));
    }

    // This helper returns only one visible group of GIT rows at a time.
    private IEnumerable<GastroIntestinalItem> GetGastroIntestinalItemsByCategory(GastroIntestinalItemCategory category)
    {
        if (Patient?.GastroIntestinal?.Items is null)
            return Enumerable.Empty<GastroIntestinalItem>();

        return Patient.GastroIntestinal.Items
            .Where(x => x.Category == category)
            .ToList();
    }

    // This is the Blazor-only searchable picker used by formula, IV fluid,
    // and other medication rows.
    // It is intentionally not a JavaScript autocomplete.
    private RenderFragment RenderSearchableCatalogPicker(GastroIntestinalItem item, string placeholder) => @<MudStack Spacing="1">
        @if (item.MedicationId > 0)
        {
            <MudPaper Elevation="0" Outlined="true" Class="pa-2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2">
                    <MudText Typo="Typo.body2">
                        <strong>Selected:</strong> @GetMedicationName(item.MedicationId)
                    </MudText>

                    @if (!string.IsNullOrWhiteSpace(GetMedicationFrequency(item.MedicationId)))
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info">
                            @GetMedicationFrequency(item.MedicationId)
                        </MudChip>
                    }
                </MudStack>
            </MudPaper>
        }

        <MudTextField T="string"
                      Label="@placeholder"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      FullWidth="true"
                      Immediate="true"
                      Disabled="@IsSaving"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Value="@GetSearchText(item)"
                      ValueChanged="@((string value) => SetSearchText(item, value))" />

        @if (ShouldShowSearchResults(item))
        {
            <MudPaper Elevation="0" Outlined="true" Class="pa-1">
                <MudStack Spacing="1">
                    @foreach (var medication in GetFilteredMedications(item))
                    {
                        <MudButton Variant="@GetCatalogButtonVariant(item, medication)"
                                   Color="@GetCatalogButtonColor(item, medication)"
                                   Size="Size.Small"
                                   FullWidth="true"
                                   Disabled="@IsSaving"
                                   OnClick="@(() => SelectMedicationForItemAsync(item, medication))">
                            @GetMedicationSearchDisplay(medication)
                        </MudButton>
                    }
                </MudStack>
            </MudPaper>
        }
        else if (item.MedicationId <= 0)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                Type to search the shared catalog.
            </MudText>
        }
    </MudStack>;

    // Store the current search text for a row.
    private void SetSearchText(GastroIntestinalItem item, string? value)
    {
        searchTextByItemKey[GetItemKey(item)] = value ?? string.Empty;
    }

    // Return the current search text for a row.
    private string GetSearchText(GastroIntestinalItem item)
    {
        return searchTextByItemKey.TryGetValue(GetItemKey(item), out var value)
            ? value
            : string.Empty;
    }

    // Search results should only appear after the user starts typing.
    private bool ShouldShowSearchResults(GastroIntestinalItem item)
    {
        return !string.IsNullOrWhiteSpace(GetSearchText(item)) && GetFilteredMedications(item).Any();
    }

    // Filter the shared catalog by name.
    // We limit the result count so the mobile screen does not become too crowded.
    private IEnumerable<Medication> GetFilteredMedications(GastroIntestinalItem item)
    {
        var searchText = GetSearchText(item).Trim();

        if (string.IsNullOrWhiteSpace(searchText))
            return Enumerable.Empty<Medication>();

        return Medications
            .Where(m => !string.IsNullOrWhiteSpace(m.Name) &&
                        m.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase))
            .OrderBy(m => m.Name)
            .Take(8)
            .ToList();
    }

    // Select the exact catalog item by Id.
    // This avoids guessing based on free text.
    private async Task SelectMedicationForItemAsync(GastroIntestinalItem item, Medication medication)
    {
        item.MedicationId = medication.Id;
        item.Medication = medication;

        searchTextByItemKey[GetItemKey(item)] = string.Empty;

        // Tell the parent EditContext that this row changed.
        // This activates the Unsaved badge and fixed bottom Save button behavior.
        NotifyGastroIntestinalItemFieldChanged(item, nameof(GastroIntestinalItem.MedicationId));

        await InvokeAsync(StateHasChanged);
    }

    // Look up the selected catalog item name.
    private string GetMedicationName(int medicationId)
    {
        if (medicationId <= 0)
            return "Not selected";

        return Medications
            .FirstOrDefault(x => x.Id == medicationId)
            ?.Name ?? "Selected catalog item";
    }

    // Look up the optional default frequency text from the catalog.
    private string? GetMedicationFrequency(int medicationId)
    {
        if (medicationId <= 0)
            return null;

        return Medications
            .FirstOrDefault(x => x.Id == medicationId)
            ?.Frequency;
    }

    // Display the catalog item in search results.
    private static string GetMedicationSearchDisplay(Medication medication)
    {
        var name = string.IsNullOrWhiteSpace(medication.Name)
            ? "Unnamed catalog item"
            : medication.Name!;

        if (string.IsNullOrWhiteSpace(medication.Frequency))
            return name;

        return $"{name} - {medication.Frequency}";
    }

    // Highlight the selected search result.
    private Variant GetCatalogButtonVariant(GastroIntestinalItem item, Medication medication)
    {
        return item.MedicationId == medication.Id
            ? Variant.Filled
            : Variant.Text;
    }

    // Highlight the selected search result.
    private Color GetCatalogButtonColor(GastroIntestinalItem item, Medication medication)
    {
        return item.MedicationId == medication.Id
            ? Color.Primary
            : Color.Default;
    }

    // This gives each row a stable key for its search box text.
    private static string GetItemKey(GastroIntestinalItem item)
    {
        return item.Id > 0
            ? $"saved-{item.Id}"
            : $"new-{RuntimeHelpers.GetHashCode(item)}";
    }
}