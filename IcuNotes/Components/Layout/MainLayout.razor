@inherits LayoutComponentBase

<!--
    MudBlazor providers.

    These are placed in the main layout so MudBlazor services are available
    throughout the whole app.

    Important:
    - The theme provider receives our app theme and dark-mode setting.
    - No database, model, service, or page logic is changed in this file.
-->
<MudThemeProvider Theme="@AppTheme" IsDarkMode="@_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<!--
    MudLayout is the MudBlazor replacement for the old Bootstrap layout wrapper.

    It gives us a proper app shell made from:
    - MudAppBar for the top bar
    - MudDrawer for the left side menu
    - MudMainContent for the page body
-->
<MudLayout Class="@RootLayoutClass" Style="@SafeAreaStyle">

    <!--
        Top app bar.

        The hamburger button opens the MudDrawer using normal Blazor state.
        No extra JavaScript is used.

        Important:
        The app bar is fixed again, but the old phone-width padding fallback
        has been removed. MudMainContent can now reserve the normal app-bar
        height without creating extra dead space.
    -->
    <MudAppBar Color="Color.Primary"
               Elevation="1"
               Fixed="true"
               Class="app-safe-top">

        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="ToggleDrawer"
                       AriaLabel="Open navigation menu" />

        <MudText Typo="Typo.h6"
                 Class="app-title">
            ICU Notes
        </MudText>

        <MudSpacer />

        <!--
            Light/dark theme toggle.

            This only changes the visual theme.
            It does not change saved data or app logic.
        -->
        <MudIconButton Icon="@ThemeIcon"
                       Color="Color.Inherit"
                       OnClick="ToggleTheme"
                       AriaLabel="@ThemeButtonLabel" />

    </MudAppBar>

    <!--
        Left navigation drawer.

        DrawerVariant.Temporary is mobile-friendly because it slides over the page
        and closes easily after navigation.
    -->
    <MudDrawer @bind-Open="_drawerOpen"
               Variant="@DrawerVariant.Temporary"
               Anchor="@Anchor.Start"
               Elevation="2">

        <MudDrawerHeader Class="app-safe-top">
            <MudText Typo="Typo.h6">
                Menu
            </MudText>
        </MudDrawerHeader>

        <!--
            MudNavMenu gives us Material-style navigation links.
            Routes are unchanged from the old layout.
        -->
        <MudNavMenu Dense="true"
                    Class="app-nav-menu">

            <MudNavLink Href="/"
                        Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Home"
                        OnClick="CloseDrawer">
                Home
            </MudNavLink>

            <MudNavLink Href="/patients"
                        Icon="@Icons.Material.Filled.People"
                        OnClick="CloseDrawer">
                Active Patients
            </MudNavLink>

            <MudNavLink Href="/archived-patients"
                        Icon="@Icons.Material.Filled.Inventory2"
                        OnClick="CloseDrawer">
                Archived Patients
            </MudNavLink>

        </MudNavMenu>

    </MudDrawer>

    <!--
        Main page content.

        Existing pages continue to render through @Body.
        This means we can migrate the app gradually, one page at a time.

        Because the app bar is fixed, MudMainContent reserves the standard
        MudBlazor app-bar height. We avoid adding our own manual top padding.
    -->
    <MudMainContent Class="app-main-content">
        <MudContainer MaxWidth="MaxWidth.False"
                      Class="app-body-container">
            @Body
        </MudContainer>
    </MudMainContent>

</MudLayout>

@code {
    // Tracks whether the left side navigation drawer is visible.
    private bool _drawerOpen = false;

    // Tracks whether the app is currently using the dark theme.
    // For now this resets when the app restarts.
    // Later we can persist it using Preferences if you want.
    private bool _isDarkMode = false;

    // Android WebView often does not report env(safe-area-inset-top) correctly.
    // We therefore apply a small Android-only top safe-area value from C#.
    // This avoids the old width-based CSS rule that also affected Windows when
    // the window was resized to phone width. No JavaScript is needed.
    private const string AndroidSafeAreaTop = "24px";

    // Adds an Android class only when the app is really running on Android.
    // Windows phone-width testing will not receive the Android spacing.
    private string RootLayoutClass => OperatingSystem.IsAndroid()
        ? "app-root app-android"
        : "app-root";

    // Exposes the safe-area value as a CSS variable used by the style block below.
    private string SafeAreaStyle => OperatingSystem.IsAndroid()
        ? $"--app-safe-top: {AndroidSafeAreaTop};"
        : "--app-safe-top: env(safe-area-inset-top, 0px);";

    // The icon changes depending on the current theme.
    // Brightness7 suggests switching back to light mode.
    // Brightness4 suggests switching to dark mode.
    private string ThemeIcon => _isDarkMode
        ? Icons.Material.Filled.Brightness7
        : Icons.Material.Filled.Brightness4;

    // A readable label for screen readers and accessibility tools.
    private string ThemeButtonLabel => _isDarkMode
        ? "Switch to light theme"
        : "Switch to dark theme";

    // App-wide MudBlazor theme.
    // We keep it here for now because MainLayout owns the app shell.
    // Later, if the theme grows, we can move it into a separate theme helper class.
    private readonly MudTheme AppTheme = new()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = Colors.Blue.Darken2,
            Secondary = Colors.Cyan.Darken1,
            Background = Colors.Gray.Lighten5,
            Surface = Colors.Shades.White,
            AppbarBackground = Colors.Blue.Darken2,
            AppbarText = Colors.Shades.White,
            DrawerBackground = Colors.Shades.White,
            DrawerText = Colors.Gray.Darken4
        },

        PaletteDark = new PaletteDark()
        {
            Primary = Colors.Blue.Lighten1,
            Secondary = Colors.Cyan.Lighten1,
            Background = "#121212",
            Surface = "#1E1E1E",
            AppbarBackground = "#1F2937",
            AppbarText = Colors.Shades.White,
            DrawerBackground = "#1E1E1E",
            DrawerText = Colors.Gray.Lighten3
        },

        LayoutProperties = new LayoutProperties()
        {
            DefaultBorderRadius = "12px"
        }
    };

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private void CloseDrawer()
    {
        _drawerOpen = false;
    }

    private void ToggleTheme()
    {
        _isDarkMode = !_isDarkMode;
    }
}

<style>
    /*
            Minimal safe-area CSS.

            Important:
            The old phone-width fallback used media (max-width: 768px).
    That was wrong because it also affected Windows when we resized the
    app to a phone-like width.

    This version uses a CSS variable from C#:
    - Android gets a small 24px fallback.
    - Windows keeps the normal env(safe-area-inset-top, 0px) value.
    */
    .app-safe-top {
        padding-top: var(--app-safe-top, 0px) !important;
    }

    /*
            On Android only, the app bar becomes taller because of the safe-area
            padding above. MudMainContent normally reserves only the standard
            app-bar height, so we add the same safe-area value to the content
            offset to prevent the page title from hiding under the app bar.
        */
    .app-root.app-android .app-main-content {
        padding-top: calc(var(--mud-appbar-height, 64px) + var(--app-safe-top, 0px)) !important;
    }

    /*
            Small spacing for the app title without using Bootstrap-style utility classes.
        */
    .app-title {
        margin-left: 8px;
    }

    /*
            Small horizontal padding for the drawer navigation links.
        */
    .app-nav-menu {
        padding-left: 8px;
        padding-right: 8px;
    }

    /*
            Keep the page background aligned with the selected MudBlazor theme.
        */
    .app-main-content {
        min-height: 100vh;
        background-color: var(--mud-palette-background);
        color: var(--mud-palette-text-primary);
    }

    /*
            Mobile-first page spacing.
            The bottom padding protects content from phone gesture bars and safe-area insets.
        */
    .app-body-container {
        padding: 12px;
        padding-bottom: calc(1rem + env(safe-area-inset-bottom, 0px)) !important;
    }
</style>