@inherits LayoutComponentBase

<div class="min-vh-100 d-flex flex-column bg-light">

    <!--
        Compact Bootstrap navbar.

        Most of the layout is Bootstrap:
        - navbar
        - navbar-dark
        - bg-dark
        - sticky-top
        - px / py spacing utilities

        app-safe-top is the only small custom helper.
        It protects the navbar from the Android status bar.
    -->
    <header class="navbar navbar-dark bg-dark sticky-top px-2 py-1 app-safe-top">
        <div class="container-fluid px-0">

            <!--
                Hamburger button.

                This opens the side menu using Blazor state.
                No JavaScript is used.
            -->
            <button class="btn btn-dark btn-sm px-2 py-1 me-2"
                    type="button"
                    @onclick="OpenMenu"
                    aria-label="Open navigation menu">
                ☰
            </button>

            <span class="navbar-brand mb-0 fs-6">
                ICU Notes
            </span>

        </div>
    </header>

    @if (isMenuOpen)
    {
        <!--
            Bootstrap-style offcanvas backdrop.

            We render it manually because we are not using Bootstrap JavaScript.
        -->
        <div class="offcanvas-backdrop fade show"
             @onclick="CloseMenu">
        </div>
    }

    <!--
        Bootstrap offcanvas menu.

        Bootstrap normally opens/closes this with JavaScript.
        Here Blazor controls it by adding/removing the "show" class.

        This avoids JavaScript while still using Bootstrap's offcanvas styling.
    -->
    <aside class="offcanvas offcanvas-start @(isMenuOpen ? "show" : "")"
           tabindex="-1"
           aria-labelledby="sideMenuTitle">

        <div class="offcanvas-header bg-dark text-white py-2 app-safe-top">
            <h5 class="offcanvas-title fs-6"
                id="sideMenuTitle">
                Menu
            </h5>

            <button type="button"
                    class="btn-close btn-close-white"
                    aria-label="Close navigation menu"
                    @onclick="CloseMenu">
            </button>
        </div>

        <div class="offcanvas-body p-2">

            <!--
                Bootstrap list-group gives us clean menu links
                without custom CSS.
            -->
            <nav class="list-group list-group-flush">
                <a class="list-group-item list-group-item-action"
                       href="/"
                       @onclick="CloseMenu">
                    Home
                </a>

                <a class="list-group-item list-group-item-action"
                       href="/patients"
                       @onclick="CloseMenu">
                    Active Patients
                </a>

                <a class="list-group-item list-group-item-action"
                       href="/archived-patients"
                       @onclick="CloseMenu">
                    Archived Patients
                </a>
            </nav>

        </div>
    </aside>

    <main class="flex-fill p-3">
        @Body
    </main>
</div>

@code {
    // Tracks whether the left side menu is currently visible.
    private bool isMenuOpen = false;

    private void OpenMenu()
    {
        isMenuOpen = true;
    }

    private void CloseMenu()
    {
        isMenuOpen = false;
    }
}

<style>
    /*
            Minimal custom CSS.

            Bootstrap handles almost everything else.

            This class protects the top navbar and offcanvas header from
            the Android status bar area.
        */
    .app-safe-top {
        padding-top: calc(0.25rem + env(safe-area-inset-top, 0px)) !important;
    }

    /*
            Some Android WebViews do not report safe-area-inset-top properly.
            This fallback keeps a small safe top space on phone-sized screens.
        */
    @@media (max-width: 768px) {
        .app-safe-top {
            padding-top: calc(0.25rem + max(env(safe-area-inset-top, 0px), 24px)) !important;
        }
    }
</style>